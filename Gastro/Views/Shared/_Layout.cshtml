<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>@ViewData["Title"] - TasteCebu</title>

    <!-- Apply saved theme BEFORE paint to prevent flash -->
    <script>
            (function () {
                var t = localStorage.getItem('theme') || 'dark';
                document.documentElement.setAttribute('data-theme', t);
            })();
    </script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Main CSS -->
    <link rel="stylesheet" href="~/css/site.css">

    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>
<body>
    <!-- STICKY NAVBAR -->
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <div class="logo">
                <a href="/">
                    <i class="fas fa-utensil-spoon"></i>
                    <span>Taste<span class="logo-highlight">Cebu</span></span>
                </a>
            </div>

            <div class="nav-links">
                @{
                    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
                }
                @if (User.Identity?.IsAuthenticated != true)
                {
                    <!-- Guest: show Home as the landing page link -->
                    <a href="/" class="nav-link @(controller == "Home" && action == "Index" ? "active" : "")">Home</a>
                }
                <a href="/Restaurants" class="nav-link @(controller == "Restaurants" ? "active" : "")">Eateries</a>
                <a href="/Dishes" class="nav-link @(controller == "Dishes" ? "active" : "")">Dishes</a>
                <a href="/Events" class="nav-link @(controller == "Events" ? "active" : "")">Events</a>
                <a href="/Stories" class="nav-link @(controller == "Stories" ? "active" : "")">Stories</a>
                <a href="/About" class="nav-link @(controller == "About" ? "active" : "")">About</a>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Dashboard" class="nav-link nav-link--admin @(controller == "Admin" ? "active" : "")"><i class="fas fa-shield-alt"></i> Dashboard</a>
                }
            </div>

            <div class="nav-actions">
                <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
                    <i class="fas fa-sun"></i>
                </button>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    var navUser = Context.RequestServices.GetService<GastroCebu.Services.SqliteDataStore>()
                        ?.FindUserById(int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"));
                    var navAvatarUrl = string.IsNullOrWhiteSpace(navUser?.AvatarUrl) ? "/images/default.jpg" : navUser.AvatarUrl;
                    <div class="user-menu">
                        <img src="@navAvatarUrl" id="navAvatarImg" class="user-avatar" alt="Profile" onerror="this.src='/images/default.jpg'">
                        <div class="user-dropdown">
                            <a href="/Account/Profile"><i class="fas fa-user"></i> My Food Journey</a>
                            <a href="/Account/Logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="btn-login">Sign In</a>
                    <a href="/Account/Register" class="btn-register">Join</a>
                }
            </div>

            <button class="mobile-menu-btn" id="mobileMenuBtn">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    <!-- MOBILE DRAWER -->
    <div class="mobile-drawer" id="mobileDrawer">
        <div class="drawer-header">
            <div class="logo">TasteCebu</div>
            <button class="close-drawer" id="closeDrawer">&times;</button>
        </div>
        <div class="drawer-links">
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a href="/"><i class="fas fa-home"></i> Home</a>
            }
            <a href="/Restaurants"><i class="fas fa-utensils"></i> Eateries</a>
            <a href="/Dishes"><i class="fas fa-drumstick-bite"></i> Dishes</a>
            <a href="/Events"><i class="fas fa-calendar-alt"></i> Events</a>
            <a href="/Stories"><i class="fas fa-book-open"></i> Stories</a>
            <a href="/About"><i class="fas fa-info-circle"></i> About</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a href="/Account/Profile"><i class="fas fa-user"></i> My Profile</a>
            }
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Dashboard" class="drawer-link--admin"><i class="fas fa-shield-alt"></i> Admin Dashboard</a>
            }
        </div>
        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="drawer-auth">
                <a href="/Account/Login" class="btn-login-mobile">Sign In</a>
                <a href="/Account/Register" class="btn-register-mobile">Join TasteCebu</a>
            </div>
        }
    </div>
    <div class="drawer-overlay" id="drawerOverlay"></div>

    <!-- MAIN CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <h3><i class="fas fa-utensil-spoon"></i> TasteCebu</h3>
                    <p>Your guide to Cebu's vibrant food scene — from legendary lechon to hidden cafes.</p>
                </div>
                <div class="footer-links">
                    <h4>Explore</h4>
                    <ul>
                        <li><a href="/Restaurants">Eateries</a></li>
                        <li><a href="/Dishes">Dishes</a></li>
                        <li><a href="/Events">Events</a></li>
                        <li><a href="/Stories">Food Stories</a></li>
                        <li><a href="/About">About</a></li>
                    </ul>
                </div>
                <div class="footer-links">
                    <h4>Account</h4>
                    <ul>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li><a href="/Account/Profile">My Profile</a></li>
                            <li><a href="/Account/Logout">Sign Out</a></li>
                        }
                        else
                        {
                            <li><a href="/Account/Login">Sign In</a></li>
                            <li><a href="/Account/Register">Join TasteCebu</a></li>
                        }
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year TasteCebu — Celebrating Cebu's Gastronomic Heritage</p>
                <div class="footer-bottom-links">
                    <a href="#">Privacy</a>
                    <a href="#">Terms</a>
                    <a href="#">Contact</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- BACK TO TOP -->
    <button class="back-to-top" id="backToTop">
        <i class="fas fa-arrow-up"></i>
    </button>

    <!-- GUEST SAVE MODAL -->
    <div id="guestSaveModal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.55); backdrop-filter:blur(4px); align-items:center; justify-content:center;">
        <div style="background:var(--bg-card); border-radius:20px; padding:2rem 2rem 1.8rem; max-width:360px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.4); position:relative;">
            <button onclick="closeGuestModal()" style="position:absolute; top:1rem; right:1rem; background:none; border:none; font-size:1.2rem; cursor:pointer; color:var(--text-secondary);">
                <i class="fas fa-times"></i>
            </button>
            <div style="font-size:2.4rem; margin-bottom:0.8rem;">🍽️</div>
            <h3 style="font-family:'Playfair Display',serif; font-size:1.35rem; margin-bottom:0.5rem; color:var(--text-primary);">Join to save your cravings</h3>
            <p id="guestModalMsg" style="color:var(--text-secondary); font-size:0.9rem; margin-bottom:1.5rem;">
                Create a free account to bookmark restaurants, track dishes you've tried, and register for events.
            </p>
            <a id="guestModalJoin" href="/Account/Register" class="btn-primary" style="display:block; text-decoration:none; padding:0.75rem; border-radius:50px; margin-bottom:1rem; font-weight:600; background:var(--gradient-warm); color:white;">
                Join TasteCebu — it's free
            </a>
            <a id="guestModalSignIn" href="/Account/Login" style="display:inline-block; color:var(--text-secondary); font-size:0.85rem; padding:0.3rem; font-weight:400; text-decoration:none;">
                Already have an account? <span style="color:var(--burnt-orange); font-weight:600;">Sign in</span>
            </a>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
