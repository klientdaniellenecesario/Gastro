@using GastroCebu.Models
@{
    var restaurant = (RestaurantListing)ViewData["Restaurant"]!;
    var reviews = (List<ReviewEntry>)ViewData["Reviews"]!;
    var names = (Dictionary<int, string>)ViewData["ReviewerNames"]!;
    var myIds = (HashSet<int>)(ViewData["UserReviewIds"] ?? new HashSet<int>());
    var currentUid = (int?)ViewData["CurrentUserId"];
    var isAuth = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = restaurant.Name + " - TasteCebu";

    // star helpers
    string RatingStars(decimal r)
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 1; i <= 5; i++)
        {
            if (r >= i) sb.Append("<i class=\"fas fa-star\"></i>");
            else if (r >= i - 0.5m) sb.Append("<i class=\"fas fa-star-half-alt\"></i>");
            else sb.Append("<i class=\"far fa-star\"></i>");
        }
        return sb.ToString();
    }
}

<!-- HERO BANNER -->
<section class="restaurant-hero">
    <div class="restaurant-hero-image">
        <img src="@restaurant.PhotoUrl" alt="@restaurant.Name">
    </div>
    <div class="restaurant-hero-overlay">
        <div class="restaurant-title-container">
            <h1>@restaurant.Name</h1>
            <div class="restaurant-actions-header">
                @if (isAuth)
                {
                    <button class="action-btn" onclick="addToCravings('@restaurant.Name', @restaurant.Id, 'restaurant')">
                        <i class="fas fa-heart"></i> Crave
                    </button>
                }
                <button class="action-btn share-btn" onclick="shareRestaurant()">
                    <i class="fas fa-share-alt"></i> Share
                </button>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="restaurant-detail-grid">
        <!-- LEFT COLUMN -->
        <div class="restaurant-info">
            <div class="info-card">
                <h3><i class="fas fa-info-circle"></i> About</h3>
                <p>@restaurant.Description</p>
            </div>

            <div class="info-card">
                <h3><i class="fas fa-tags"></i> Category</h3>
                <div class="vibe-tags">
                    <span class="vibe-tag"><i class="fas fa-utensils"></i> @restaurant.Category</span>
                </div>
            </div>

            <div class="info-card">
                <h3><i class="fas fa-map-marker-alt"></i> Location</h3>
                <p><strong>Address:</strong> @restaurant.Address</p>
                <button class="btn-get-directions" onclick="getDirections('@restaurant.Address')">
                    Get Directions <i class="fas fa-external-link-alt"></i>
                </button>
            </div>
        </div>

        <!-- RIGHT COLUMN - STATS -->
        <div class="restaurant-stats">
            <div class="stats-card">
                <div class="rating-large">
                    <span class="rating-number">@(restaurant.Rating > 0 ? restaurant.Rating.ToString("F1") : "—")</span>
                    <div class="rating-stars">
                        @Html.Raw(RatingStars(restaurant.Rating))
                    </div>
                    <span class="review-count">@reviews.Count @(reviews.Count == 1 ? "review" : "reviews")</span>
                </div>
                <div class="stats-grid">
                    <div class="stat">
                        <div class="stat-value">@reviews.Count</div>
                        <div class="stat-label">Total Reviews</div>
                    </div>
                    <div class="stat">
                        <div class="stat-value">@(restaurant.Rating > 0 ? restaurant.Rating.ToString("F1") : "N/A")</div>
                        <div class="stat-label">Avg Rating</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- REVIEWS SECTION -->
    <div class="reviews-section" id="reviewsSection">
        <div class="reviews-header">
            <h3>Customer Reviews (@reviews.Count)</h3>
        </div>

        <div class="reviews-list" id="reviewsList">
            @if (!reviews.Any())
            {
                <p class="no-reviews-msg">No reviews yet. Be the first to share your experience!</p>
            }
            @foreach (var review in reviews)
            {
                var canEdit = myIds.Contains(review.Id);
                var canDelete = canEdit || isAdmin;
                <div class="review-card" id="review-@review.Id">
                    <div class="reviewer-info">
                        <div class="reviewer-avatar">@names[review.Id][0]</div>
                        <div>
                            <h4>@names[review.Id]</h4>
                            <div class="review-stars">
                                @Html.Raw(RatingStars(review.Rating))
                            </div>
                            <p class="review-date">@review.CreatedAt.ToLocalTime().ToString("MMMM d, yyyy")</p>
                        </div>
                        @if (canDelete)
                        {
                            <div class="review-actions">
                                @if (canEdit)
                                {
                                    <button class="review-action-btn" onclick="openEditModal(@review.Id, @review.Rating, @Json.Serialize(review.Text))">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                }
                                <button class="review-action-btn delete" onclick="deleteReview(@review.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <p class="review-text">@review.Text</p>
                </div>
            }
        </div>

        <!-- LEAVE A REVIEW -->
        @if (isAuth)
        {
            <div class="leave-review" id="leaveReview">
                <h3>Leave a Review</h3>
                <div class="star-rating-selector" id="starRatingSelector">
                    <i class="far fa-star" onclick="restSetRating(1)"></i>
                    <i class="far fa-star" onclick="restSetRating(2)"></i>
                    <i class="far fa-star" onclick="restSetRating(3)"></i>
                    <i class="far fa-star" onclick="restSetRating(4)"></i>
                    <i class="far fa-star" onclick="restSetRating(5)"></i>
                </div>
                <textarea id="reviewText" placeholder="Share your experience..." rows="4"></textarea>
                <input type="hidden" id="ratingValue" value="0">
                <button class="btn-primary" onclick="submitReview()">Submit Review</button>
            </div>
        }
        else
        {
            <div class="leave-review login-prompt">
                <p><a href="/Account/Login?returnUrl=/Restaurants/Detail/@restaurant.Id">Sign in</a> to leave a review.</p>
            </div>
        }
    </div>
</section>

<!-- EDIT MODAL -->
<div id="editModal" class="modal-backdrop" style="display:none">
    <div class="modal-box">
        <h3>Edit Review</h3>
        <div class="star-rating-selector" id="editStars">
            <i class="far fa-star" onclick="restSetEditRating(1)"></i>
            <i class="far fa-star" onclick="restSetEditRating(2)"></i>
            <i class="far fa-star" onclick="restSetEditRating(3)"></i>
            <i class="far fa-star" onclick="restSetEditRating(4)"></i>
            <i class="far fa-star" onclick="restSetEditRating(5)"></i>
        </div>
        <textarea id="editReviewText" rows="4"></textarea>
        <div class="modal-actions">
            <button class="btn-primary" onclick="saveEdit()">Save</button>
            <button class="btn-secondary" onclick="closeEditModal()">Cancel</button>
        </div>
    </div>
</div>

<style>
    .restaurant-hero {
        position: relative;
        height: 50vh;
        min-height: 400px;
        overflow: hidden;
    }

    .restaurant-hero-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .restaurant-hero-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        padding: 2rem;
    }

    .restaurant-title-container {
        max-width: var(--container-width);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

        .restaurant-title-container h1 {
            font-size: 2.5rem;
            color: white;
        }

    .restaurant-actions-header {
        display: flex;
        gap: 1rem;
    }

    .action-btn {
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(8px);
        border: none;
        padding: 0.5rem 1.2rem;
        border-radius: 30px;
        color: white;
        cursor: pointer;
        transition: var(--transition);
    }

        .action-btn:hover {
            background: var(--burnt-orange);
        }

    .restaurant-detail-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .info-card {
        background: var(--bg-card);
        padding: 1.5rem;
        border-radius: 20px;
        margin-bottom: 1.5rem;
    }

        .info-card h3 {
            margin-bottom: 1rem;
        }

    .vibe-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .vibe-tag {
        background: var(--bg-elevated);
        padding: 0.3rem 1rem;
        border-radius: 30px;
        font-size: 0.85rem;
    }

    .btn-get-directions {
        background: var(--gradient-warm);
        color: white;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 30px;
        margin-top: 1rem;
        cursor: pointer;
    }

    .stats-card {
        background: var(--gradient-warm);
        padding: 2rem;
        border-radius: 20px;
        text-align: center;
        color: white;
    }

    .rating-large {
        margin-bottom: 1.5rem;
    }

    .rating-number {
        font-size: 3rem;
        font-weight: 700;
    }

    .rating-stars i {
        color: #fff;
        font-size: 1.1rem;
    }

    .review-count {
        display: block;
        font-size: 0.9rem;
        opacity: 0.85;
        margin-top: 0.3rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
    }

    .reviews-section {
        margin-top: 3rem;
    }

    .reviews-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

        .reviews-header h3 {
            font-size: 1.5rem;
        }

    .no-reviews-msg {
        color: var(--text-secondary);
        font-style: italic;
        margin-bottom: 1rem;
    }

    .review-card {
        background: var(--bg-card);
        padding: 1.5rem;
        border-radius: 16px;
        margin-bottom: 1rem;
    }

    .reviewer-info {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
        align-items: flex-start;
    }

    .reviewer-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--gradient-warm);
        color: white;
        font-weight: 700;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .reviewer-info h4 {
        margin: 0 0 0.2rem;
    }

    .review-stars i {
        color: var(--golden-yellow);
        font-size: 0.8rem;
    }

    .review-date {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin: 0;
    }

    .review-actions {
        margin-left: auto;
        display: flex;
        gap: 0.4rem;
    }

    .review-action-btn {
        background: none;
        border: 1px solid var(--text-muted);
        color: var(--text-secondary);
        width: 30px;
        height: 30px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
    }

        .review-action-btn:hover {
            border-color: var(--burnt-orange);
            color: var(--burnt-orange);
        }

        .review-action-btn.delete:hover {
            border-color: #e74c3c;
            color: #e74c3c;
        }

    .review-text {
        margin: 0;
        line-height: 1.6;
    }

    .leave-review {
        background: var(--bg-card);
        padding: 1.5rem;
        border-radius: 20px;
        margin-top: 2rem;
    }

        .leave-review h3 {
            margin-bottom: 1rem;
        }

    .star-rating-selector i {
        font-size: 1.5rem;
        cursor: pointer;
        color: var(--text-muted);
        margin-right: 0.3rem;
    }

        .star-rating-selector i.active {
            color: var(--golden-yellow);
        }

    .leave-review textarea {
        width: 100%;
        background: var(--bg-elevated);
        border: 1px solid var(--text-muted);
        color: var(--text-primary);
        padding: 0.8rem;
        border-radius: 12px;
        margin: 1rem 0;
        resize: vertical;
    }

    .login-prompt {
        text-align: center;
        color: var(--text-secondary);
    }

        .login-prompt a {
            color: var(--burnt-orange);
        }
    /* Modal */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-box {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 2rem;
        width: 90%;
        max-width: 480px;
    }

        .modal-box h3 {
            margin-bottom: 1rem;
        }

        .modal-box textarea {
            width: 100%;
            background: var(--bg-elevated);
            border: 1px solid var(--text-muted);
            color: var(--text-primary);
            padding: 0.8rem;
            border-radius: 12px;
            margin: 1rem 0;
            resize: vertical;
        }

    .modal-actions {
        display: flex;
        gap: 1rem;
    }

    @@media (max-width: 768px) {
        .restaurant-detail-grid {
            grid-template-columns: 1fr;
        }

        .restaurant-title-container h1 {
            font-size: 1.8rem;
        }

        .restaurant-hero {
            min-height: 300px;
        }
    }
</style>

<script>
    var currentRating = 0;
    var restaurantId = @restaurant.Id;

    function restSetRating(rating) {
        currentRating = rating;
        document.getElementById('ratingValue').value = rating;
        document.querySelectorAll('#starRatingSelector i').forEach(function(s, i) {
            s.className = i < rating ? 'fas fa-star active' : 'far fa-star';
        });
    }

    async function submitReview() {
        if (currentRating === 0) { showToast('Please select a rating first!'); return; }
        var text = document.getElementById('reviewText').value.trim();
        if (!text) { showToast('Please write your review!'); return; }
        var res = await fetch('/api/reviews', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ targetType: 'restaurant', targetId: restaurantId, rating: currentRating, text: text })
        });
        if (res.ok) {
            showToast('Review submitted!');
            document.getElementById('reviewText').value = '';
            restSetRating(0);
            location.reload();
        } else {
            var err = await res.json();
            showToast(err.message || 'Could not submit review.');
        }
    }

    // Edit modal
    var editingReviewId = 0;
    var editRating = 0;

    function openEditModal(id, rating, text) {
        editingReviewId = id;
        editRating = rating;
        document.getElementById('editReviewText').value = text;
        restSetEditRating(rating);
        document.getElementById('editModal').style.display = 'flex';
    }
    function closeEditModal() { document.getElementById('editModal').style.display = 'none'; }
    function restSetEditRating(rating) {
        editRating = rating;
        document.querySelectorAll('#editStars i').forEach(function(s, i) {
            s.className = i < rating ? 'fas fa-star active' : 'far fa-star';
        });
    }
    async function saveEdit() {
        var text = document.getElementById('editReviewText').value.trim();
        if (!editRating || !text) { showToast('Rating and text required.'); return; }
        var res = await fetch('/api/reviews/' + editingReviewId, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rating: editRating, text: text })
        });
        if (res.ok) { closeEditModal(); location.reload(); }
        else { var err = await res.json(); showToast(err.message || 'Update failed.'); }
    }

    async function deleteReview(id) {
        if (!confirm('Delete this review?')) return;
        var res = await fetch('/api/reviews/' + id, { method: 'DELETE' });
        if (res.ok) location.reload();
        else showToast('Could not delete review.');
    }

    function getDirections(address) {
        window.open('https://maps.google.com/?q=' + encodeURIComponent(address), '_blank');
    }
    function shareRestaurant() {
        navigator.clipboard.writeText(window.location.href);
        showToast('Link copied to clipboard!');
    }

    function showToast(message) {
        var t = document.createElement('div');
        t.className = 'toast-notification';
        t.textContent = message;
        document.body.appendChild(t);
        setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 3000);
    }
</script>
