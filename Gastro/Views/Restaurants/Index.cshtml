@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.SelectTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Restaurants & Cafes - TasteCebu";
    var restaurants = ViewData["DatabaseRestaurants"] as List<GastroCebu.Models.RestaurantListing> ?? new();
}

<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>🍽️ Explore Cebu's Dining Scene</h2>
        <p>From hole-in-walls to fine dining — find your next favorite spot</p>
    </div>

    @* SEARCH AND FILTERS *@
    <div class="filters-bar" data-aos="fade-up">
        @{
            var selectedCategory = ViewData["SelectedCategory"]?.ToString() ?? "";
            var selectedSort = ViewData["SelectedSort"]?.ToString() ?? "newest";

            string IsSelected(string value, string selected) => value == selected ? "selected" : "";
        }
        <form method="post" action="/Restaurants/Search" class="search-form" style="display: flex; gap: 1rem; align-items: center; flex: 1;">
            <div class="search-bar" style="flex: 1;">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search restaurants..." id="searchInput" name="query" value="@(ViewData["SearchQuery"] ?? "")">
            </div>

            <select name="category" class="filter-select">
                <option value="">All Categories</option>
                <option value="restaurant" @IsSelected("restaurant", selectedCategory)>Restaurant</option>
                <option value="cafe" @IsSelected("cafe", selectedCategory)>Cafe</option>
                <option value="bar" @IsSelected("bar", selectedCategory)>Bar</option>
                <option value="street food" @IsSelected("street food", selectedCategory)>Street Food</option>
            </select>

            <select name="sortBy" class="filter-select">
                <option value="newest" @IsSelected("newest", selectedSort)>Newest First</option>
                <option value="rating" @IsSelected("rating", selectedSort)>Highest Rated</option>
                <option value="name" @IsSelected("name", selectedSort)>Name A-Z</option>
            </select>

            <button type="submit" class="btn-primary" style="white-space: nowrap;">
                <i class="fas fa-search"></i> Search
            </button>
        </form>
    </div>

    @* SEARCH RESULTS SUMMARY *@
    @if (!string.IsNullOrEmpty(ViewData["SearchQuery"]?.ToString()))
    {
        <div class="search-summary" style="background: var(--bg-elevated); padding: 1rem; border-radius: 8px; margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
            <div>
                <p style="margin: 0; color: var(--text-secondary);">
                    Showing <strong>@restaurants.Count</strong> restaurant@(restaurants.Count != 1 ? "s" : "") for "<strong>@ViewData["SearchQuery"]</strong>"
                </p>
            </div>
            <a href="/Restaurants" class="btn-secondary" style="text-decoration: none; padding: 0.5rem 1rem; font-size: 0.9rem;">
                <i class="fas fa-times"></i> Clear Search
            </a>
        </div>
    }

    @* RESTAURANT GRID *@
    @if (!restaurants.Any())
    {
        <div class="empty-state" data-aos="fade-up">
            <div class="empty-state-icon">🍽️</div>
            <h3>No restaurants listed yet</h3>
            <p>The admin hasn't added any restaurants yet. Check back soon!</p>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Dashboard" class="btn-primary">Add a Restaurant →</a>
            }
        </div>
    }
    else
    {
        <div class="card-grid" id="restaurantsGrid">
            @foreach (var restaurant in restaurants)
            {
                <div class="restaurant-card"
                     data-category="@restaurant.Category.ToLowerInvariant()"
                     data-rating="@restaurant.Rating"
                     data-name="@restaurant.Name"
                     data-date="@restaurant.CreatedAt.ToString("yyyy-MM-dd")">
                    <div class="card-image">
                        <img src="@restaurant.PhotoUrl" alt="@restaurant.Name">
                        <span class="card-badge">@restaurant.Category.ToUpperInvariant()</span>
                        <span class="card-vibe"><i class="fas fa-utensils"></i> @restaurant.Category</span>
                    </div>
                    <div class="card-content">
                        <h3>@restaurant.Name</h3>
                        <p class="card-location"><i class="fas fa-map-marker-alt"></i> @restaurant.Address</p>
                        <div class="rating">
                            <i class="fas fa-star"></i>
                            <span>@restaurant.Rating.ToString("0.0")</span>
                        </div>
                        <p>@restaurant.Description</p>
                        <div class="card-actions">
                            <button class="btn-crave" onclick="addToCravings('@restaurant.Name', @restaurant.Id, 'restaurant')">
                                <i class="fas fa-heart"></i> Crave
                            </button>
                            <a href="/Restaurants/Detail/@restaurant.Id" class="btn-view">View →</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div style="text-align: center; margin-top: 3rem;">
            <button class="btn-primary" onclick="loadMore(this)">Load More →</button>
        </div>
    }
</section>

@* CEBU MAP SECTION *@
<section class="section" style="background: var(--bg-elevated);">
    <div class="section-header" data-aos="fade-up">
        <h2>🗺️ Find Your Next Meal</h2>
        <p>Explore restaurants across Cebu</p>
    </div>

    <div class="map-container" data-aos="fade-up">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d250694.5277624654!2d123.78480462785445!3d10.315699251624145!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x33a999a2a0b6f1a1%3A0x6b7b4f8e2b5c9a4!2sCebu%20City%2C%20Cebu!5e0!3m2!1sen!2sph!4v1700000000000!5m2!1sen!2sph"
                width="100%"
                height="400"
                style="border:0; border-radius: 24px;"
                allowfullscreen=""
                loading="lazy">
        </iframe>
    </div>
</section>

<style>
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--text-secondary);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        margin-bottom: 1.5rem;
    }

    .card-actions {
        display: flex;
        gap: 0.8rem;
        margin-top: 1rem;
    }

    .btn-crave, .btn-view {
        padding: 0.5rem 1rem;
        border-radius: 30px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        text-align: center;
        flex: 1;
    }

    .btn-crave {
        background: transparent;
        border: 1px solid var(--burnt-orange);
        color: var(--burnt-orange);
    }

        .btn-crave:hover {
            background: var(--burnt-orange);
            color: white;
        }

    .btn-view {
        background: var(--gradient-warm);
        color: white;
        border: none;
    }

        .btn-view:hover {
            transform: translateX(3px);
        }

    .filter-select, .sort-select {
        background: var(--bg-elevated);
        border: 1px solid var(--text-muted);
        color: var(--text-primary);
        padding: 0.75rem 1rem;
        border-radius: 30px;
        cursor: pointer;
        font-size: 0.9rem;
    }

    .map-container {
        border-radius: 24px;
        overflow: hidden;
    }
</style>

<script>
    // Live search — filters cards client-side as you type
    var searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('keyup', function () {
            var filter = this.value.toLowerCase().trim();
            document.querySelectorAll('.restaurant-card').forEach(function (card) {
                var name = (card.dataset.name || '').toLowerCase();
                var loc  = (card.querySelector('.card-location')?.innerText || '').toLowerCase();
                card.style.display = (!filter || name.includes(filter) || loc.includes(filter)) ? '' : 'none';
            });
        });
    }

    // Broken image fallback
    document.querySelectorAll('.card-image img').forEach(function (img) {
        img.addEventListener('error', function () {
            this.src = 'https://placehold.co/400x260/1a1a1a/888?text=No+Photo';
        });
    });
</script>
