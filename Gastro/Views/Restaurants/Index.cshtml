@{
    ViewData["Title"] = "Restaurants & Cafes - TasteCebu";
    var restaurants = ViewData["DatabaseRestaurants"] as List<GastroCebu.Models.RestaurantListing> ?? new();
}

<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>🍽️ Explore Cebu's Dining Scene</h2>
        <p>From hole-in-walls to fine dining — find your next favorite spot</p>
    </div>

    @* SEARCH AND FILTERS *@
    <div class="filters-bar" data-aos="fade-up">
        <div class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search restaurants..." id="searchInput" onkeyup="searchRestaurants()">
        </div>

        <div class="filter-tabs">
            <button class="filter-tab active" onclick="filterByCategory('all')">All</button>
            <button class="filter-tab" onclick="filterByCategory('restaurant')">Restaurant</button>
            <button class="filter-tab" onclick="filterByCategory('cafe')">Cafe</button>
            <button class="filter-tab" onclick="filterByCategory('bar')">Bar</button>
            <button class="filter-tab" onclick="filterByCategory('street food')">Street Food</button>
        </div>

        <select class="sort-select" id="sortSelect" onchange="sortRestaurants()">
            <option value="newest">Newest First</option>
            <option value="rating">Highest Rated</option>
            <option value="name">Name A-Z</option>
        </select>
    </div>

    @* RESTAURANT GRID *@
    @if (!restaurants.Any())
    {
        <div class="empty-state" data-aos="fade-up">
            <div class="empty-state-icon">🍽️</div>
            <h3>No restaurants listed yet</h3>
            <p>The admin hasn't added any restaurants yet. Check back soon!</p>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Dashboard" class="btn-primary">Add a Restaurant →</a>
            }
        </div>
    }
    else
    {
        <div class="card-grid" id="restaurantsGrid">
            @foreach (var restaurant in restaurants)
            {
                <div class="restaurant-card"
                     data-category="@restaurant.Category.ToLowerInvariant()"
                     data-rating="@restaurant.Rating"
                     data-name="@restaurant.Name"
                     data-date="@restaurant.CreatedAt.ToString("yyyy-MM-dd")">
                    <div class="card-image">
                        <img src="@restaurant.PhotoUrl" alt="@restaurant.Name">
                        <span class="card-badge">@restaurant.Category.ToUpperInvariant()</span>
                        <span class="card-vibe"><i class="fas fa-utensils"></i> @restaurant.Category</span>
                    </div>
                    <div class="card-content">
                        <h3>@restaurant.Name</h3>
                        <p class="card-location"><i class="fas fa-map-marker-alt"></i> @restaurant.Address</p>
                        <div class="rating">
                            <i class="fas fa-star"></i>
                            <span>@restaurant.Rating.ToString("0.0")</span>
                        </div>
                        <p>@restaurant.Description</p>
                        <div class="card-actions">
                            <button class="btn-crave" onclick="addToCravings('@restaurant.Name', @restaurant.Id, 'restaurant')">
                                <i class="fas fa-heart"></i> Crave
                            </button>
                            <a href="/Restaurants/Detail/@restaurant.Id" class="btn-view">View →</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div style="text-align: center; margin-top: 3rem;">
            <button class="btn-primary" onclick="loadMore(this)">Load More →</button>
        </div>
    }
</section>

@* CEBU MAP SECTION *@
<section class="section" style="background: var(--bg-elevated);">
    <div class="section-header" data-aos="fade-up">
        <h2>🗺️ Find Your Next Meal</h2>
        <p>Explore restaurants across Cebu</p>
    </div>

    <div class="map-container" data-aos="fade-up">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d250694.5277624654!2d123.78480462785445!3d10.315699251624145!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x33a999a2a0b6f1a1%3A0x6b7b4f8e2b5c9a4!2sCebu%20City%2C%20Cebu!5e0!3m2!1sen!2sph!4v1700000000000!5m2!1sen!2sph"
                width="100%"
                height="400"
                style="border:0; border-radius: 24px;"
                allowfullscreen=""
                loading="lazy">
        </iframe>
    </div>
</section>

<style>
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--text-secondary);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        margin-bottom: 1.5rem;
    }

    .card-actions {
        display: flex;
        gap: 0.8rem;
        margin-top: 1rem;
    }

    .btn-crave, .btn-view {
        padding: 0.5rem 1rem;
        border-radius: 30px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        text-align: center;
        flex: 1;
    }

    .btn-crave {
        background: transparent;
        border: 1px solid var(--burnt-orange);
        color: var(--burnt-orange);
    }

        .btn-crave:hover {
            background: var(--burnt-orange);
            color: white;
        }

    .btn-view {
        background: var(--gradient-warm);
        color: white;
        border: none;
    }

        .btn-view:hover {
            transform: translateX(3px);
        }

    .sort-select {
        background: var(--bg-elevated);
        border: 1px solid var(--text-muted);
        color: var(--text-primary);
        padding: 0.5rem 1rem;
        border-radius: 30px;
        cursor: pointer;
    }

    .map-container {
        border-radius: 24px;
        overflow: hidden;
    }
</style>

<script>
    function searchRestaurants() {
        const input = document.getElementById('searchInput');
        const filter = input.value.toLowerCase();
        const cards = document.querySelectorAll('.restaurant-card');

        cards.forEach(card => {
            const name = card.querySelector('h3').innerText.toLowerCase();
            const location = card.querySelector('.card-location').innerText.toLowerCase();
            card.style.display = (name.includes(filter) || location.includes(filter)) ? 'block' : 'none';
        });
    }

    function filterByCategory(category) {
        const cards = document.querySelectorAll('.restaurant-card');
        const buttons = document.querySelectorAll('.filter-tab');

        buttons.forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');

        cards.forEach(card => {
            card.style.display = (category === 'all' || card.dataset.category === category) ? 'block' : 'none';
        });
    }

    function sortRestaurants() {
        const sortBy = document.getElementById('sortSelect').value;
        const grid = document.getElementById('restaurantsGrid');
        if (!grid) return;
        const cards = Array.from(document.querySelectorAll('.restaurant-card'));

        cards.sort((a, b) => {
            if (sortBy === 'name') return a.dataset.name.localeCompare(b.dataset.name);
            if (sortBy === 'rating') return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
            if (sortBy === 'newest') return new Date(b.dataset.date) - new Date(a.dataset.date);
            return 0;
        });

        cards.forEach(card => grid.appendChild(card));
        showToast('Sorted! 🍽️');
    }
</script>
