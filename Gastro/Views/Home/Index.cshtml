@using GastroCebu.Models
@model GastroCebu.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Discover Cebu's Food Scene - TasteCebu";
    var featuredRestaurants = Model.FeaturedRestaurants;
    var trendingDishes = Model.TrendingDishes;
    var newDishes = Model.NewDishes;
    var upcomingEvents = Model.UpcomingEvents;
    var isAuth = User.Identity?.IsAuthenticated == true;
}

@* HERO SECTION *@
<section class="hero">
    <div class="hero-content" data-aos="fade-up">
        <div class="hero-badge">
            <i class="fas fa-utensil-spoon"></i> SUGBA • SIKAT • SABOR
        </div>
        <h1>Discover Cebu's<br><span class="hero-highlight">Boldest Bites</span></h1>
        <p>From legendary lechon to hidden cafes — your gastro journey starts here</p>
        <div class="hero-buttons">
            <a href="/Restaurants" class="btn-primary">Explore Eateries →</a>
            <a href="/Dishes" class="btn-secondary">Discover Dishes →</a>
        </div>
    </div>
</section>

@* STATS STRIP *@
<div class="stats-strip" data-aos="fade-up">
    <div class="stat-item">
        <div class="stat-number">@Model.RestaurantCount</div>
        <div class="stat-label">Restaurants</div>
    </div>
    <div class="stat-item">
        <div class="stat-number">@Model.DishCount</div>
        <div class="stat-label">Dishes</div>
    </div>
    <div class="stat-item">
        <div class="stat-number">@Model.EventCount</div>
        <div class="stat-label">Events</div>
    </div>
    <div class="stat-item">
        <div class="stat-number">@Model.UserCount</div>
        <div class="stat-label">Foodies</div>
    </div>
</div>

@* FEATURED RESTAURANTS *@
<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>Featured Restaurants 🍽️</h2>
        <p>Cebu's most loved spots, handpicked for you</p>
    </div>
    @if (!featuredRestaurants.Any())
    {
        <div class="home-empty-state" data-aos="fade-up">
            <div class="empty-icon">🍽️</div>
            <h3>No restaurants yet</h3>
            <p>The admin hasn't added any restaurants yet. Check back soon!</p>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Dashboard" class="btn-primary" style="display:inline-block;margin-top:1.5rem;">Add Restaurants →</a>
            }
        </div>
    }
    else
    {
        <div class="card-grid" id="restaurantGrid">
            @{
                var restaurantReviewMap = ViewData["RestaurantReviewStats"] as Dictionary<int, (decimal Avg, int Count)>;
            }
            @foreach (var r in featuredRestaurants)
            {
                var rStat = restaurantReviewMap != null && restaurantReviewMap.ContainsKey(r.Id) ? restaurantReviewMap[r.Id] : (Avg: 0m, Count: 0);
                <div class="restaurant-card" data-aos="fade-up">
                    <div class="card-image">
                        <img src="@r.PhotoUrl" alt="@r.Name" onerror="this.src='https://placehold.co/400x260/1a1a2e/888?text=No+Photo'">
                        <span class="card-badge">@r.Category.ToUpperInvariant()</span>
                        <span class="card-vibe"><i class="fas fa-utensils"></i> @r.Category</span>
                    </div>
                    <div class="card-content">
                        <h3>@r.Name</h3>
                        <p class="card-location"><i class="fas fa-map-marker-alt"></i> @r.Address</p>
                        @if (rStat.Count > 0)
                        {
                            <div class="rating">
                                <i class="fas fa-star"></i>
                                <span>@rStat.Avg.ToString("0.1") <small style="color:var(--text-secondary);">(@rStat.Count @(rStat.Count == 1 ? "review" : "reviews"))</small></span>
                            </div>
                        }
                        else
                        {
                            <div class="rating rating--none">
                                <i class="far fa-star"></i>
                                <span style="color:var(--text-secondary);font-size:0.8rem;">No reviews yet</span>
                            </div>
                        }
                        <p>@r.Description</p>
                        <div class="card-actions">
                            @if (isAuth)
                            {
                                <button class="btn-crave" onclick="addToCravings('@r.Name', @r.Id, 'restaurant')">
                                    <i class="fas fa-heart"></i> Crave
                                </button>
                            }
                            else
                            {
                                <button class="btn-crave btn-crave--guest" onclick="showGuestModal('/Restaurants/Detail/@r.Id')">
                                    <i class="fas fa-heart"></i> Crave
                                </button>
                            }
                            <a href="/Restaurants/Detail/@r.Id" class="btn-view">View →</a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div style="text-align:center;margin-top:2rem;">
            <a href="/Restaurants" class="btn-secondary">See All Restaurants →</a>
        </div>
    }
</section>

@* TRENDING DISHES — horizontal scroll *@
<section class="section" style="background: var(--bg-elevated);">
    <div class="section-header" data-aos="fade-up">
        <h2>🍜 Trending Right Now</h2>
        <p>Cebu's most talked-about dishes this week</p>
    </div>

    @if (!trendingDishes.Any())
    {
        <div class="home-empty-state" data-aos="fade-up">
            <div class="empty-icon">🥘</div>
            <h3>No trending dishes yet</h3>
            <p>Admin hasn't marked any dishes as trending yet.</p>
        </div>
    }
    else
    {
        <div class="horizontal-scroll" data-aos="fade-up">
            @foreach (var dish in trendingDishes)
            {
                <div class="dish-card" onclick="location.href='/Dishes/Detail/@dish.Id'">
                    <div class="card-image">
                        <img src="@dish.PhotoUrl" alt="@dish.Name" onerror="this.src='https://placehold.co/400x300/1a1a2e/888?text=No+Photo'">
                        <span class="card-badge new-badge">🌶️ VIRAL</span>
                    </div>
                    <div class="card-content">
                        <h3>@dish.Name</h3>
                        <p class="dish-price">PHP @dish.Price.ToString("0.##")</p>
                        @{
                            var dishReviewMap = ViewData["DishReviewStats"] as Dictionary<int, (decimal Avg, int Count)>;
                            var dStat = dishReviewMap != null && dishReviewMap.ContainsKey(dish.Id) ? dishReviewMap[dish.Id] : (Avg: 0m, Count: 0);
                        }
                        @if (dStat.Count > 0)
                        {
                            <div class="rating">
                                <i class="fas fa-star"></i>
                                <span>@dStat.Avg.ToString("0.1") <small style="color:var(--text-secondary);">(@dStat.Count @(dStat.Count == 1 ? "review" : "reviews"))</small></span>
                            </div>
                        }
                        else
                        {
                            <div class="rating rating--none">
                                <i class="far fa-star"></i>
                                <span style="color:var(--text-secondary);font-size:0.8rem;">No reviews yet</span>
                            </div>
                        }
                        @if (isAuth)
                        {
                            <button class="btn-tried" onclick="event.stopPropagation(); window.TasteCebu.triedDish('@dish.Name', @dish.Id)">
                                <i class="fas fa-check-circle"></i> I Tried This
                            </button>
                        }
                        else
                        {
                            <button class="btn-tried btn-tried--guest" onclick="event.stopPropagation(); showGuestModal('/Dishes/Detail/@dish.Id')">
                                <i class="fas fa-lock"></i> Sign in to Track
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</section>

@* NEW THIS MONTH *@
<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>🆕 New This Week</h2>
        <p>Freshly added restaurants and dishes</p>
    </div>

    @if (!newDishes.Any() && !featuredRestaurants.Any())
    {
        <div class="home-empty-state" data-aos="fade-up">
            <div class="empty-icon">🆕</div>
            <h3>Nothing new yet</h3>
            <p>Check back soon for new additions!</p>
        </div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var dish in newDishes)
            {
                <div class="dish-card" data-aos="fade-up">
                    <div class="card-image">
                        <img src="@dish.PhotoUrl" alt="@dish.Name" onerror="this.src='https://placehold.co/400x300/1a1a2e/888?text=No+Photo'">
                        <span class="card-badge new-badge">🆕 NEW</span>
                    </div>
                    <div class="card-content">
                        <h3>@dish.Name</h3>
                        <p class="dish-price">PHP @dish.Price.ToString("0.##")</p>
                        <div class="dish-tags">
                            @foreach (var tag in (dish.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="tag">@tag.Trim()</span>
                            }
                        </div>
                        @if (isAuth)
                        {
                            <button class="btn-tried" onclick="window.TasteCebu.triedDish('@dish.Name', @dish.Id)">
                                <i class="fas fa-check-circle"></i> I Tried This
                            </button>
                        }
                        else
                        {
                            <button class="btn-tried btn-tried--guest" onclick="showGuestModal('/Dishes/Detail/@dish.Id')">
                                <i class="fas fa-lock"></i> Sign in to Track
                            </button>
                        }
                    </div>
                </div>
            }
            @foreach (var ev in upcomingEvents.Take(1))
            {
                <div class="event-card" data-aos="fade-up" onclick="location.href='/Events/Detail/@ev.Id'" style="cursor:pointer;">
                    <div class="card-image">
                        <img src="@ev.PhotoUrl" alt="@ev.Title" onerror="this.src='https://placehold.co/400x260/1a1a2e/888?text=No+Photo'">
                        <span class="card-badge new-badge">🆕 EVENT</span>
                    </div>
                    <div class="card-content">
                        <h3>@ev.Title</h3>
                        <p class="card-location"><i class="far fa-calendar-alt"></i> @ev.Date.ToString("MMMM d, yyyy")</p>
                        <p>@ev.Description</p>
                    </div>
                </div>
            }
        </div>
    }
</section>

@* UPCOMING EVENTS *@
<section class="section" style="background: var(--bg-elevated);">
    <div class="section-header" data-aos="fade-up">
        <h2>📅 Upcoming Masterclasses & Events</h2>
        <p>Cook, learn, and celebrate with Cebu's culinary community</p>
    </div>

    @if (!upcomingEvents.Any())
    {
        <div class="home-empty-state" data-aos="fade-up">
            <div class="empty-icon">📅</div>
            <h3>No upcoming events yet</h3>
            <p>Admin hasn't scheduled any events or masterclasses yet.</p>
        </div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var ev in upcomingEvents)
            {
                <div class="event-card" data-aos="fade-up" onclick="location.href='/Events/Detail/@ev.Id'" style="cursor:pointer;">
                    <div class="card-image">
                        <img src="@ev.PhotoUrl" alt="@ev.Title" onerror="this.src='https://placehold.co/400x260/1a1a2e/888?text=No+Photo'">
                        <div class="date-badge">
                            <span class="date-month">@ev.Date.ToString("MMM").ToUpperInvariant()</span>
                            <span class="date-day">@ev.Date.Day</span>
                        </div>
                    </div>
                    <div class="card-content">
                        <h3>@ev.Title</h3>
                        <p class="card-location"><i class="fas fa-map-marker-alt"></i> @ev.Location</p>
                        <p class="event-time"><i class="far fa-clock"></i> @ev.Date.ToString("h:mm tt")</p>
                        <p>@ev.Description</p>
                        <div class="progress-bar">
                            <div class="progress" style="width: 45%"></div>
                        </div>
                        <p class="seats-left">@ev.AvailableSlots seats available</p>
                    </div>
                </div>
            }
        </div>
        <div style="text-align: center; margin-top: 2rem;">
            <a href="/Events" class="btn-secondary">View All Events →</a>
        </div>
    }
</section>

@* CEBU FOOD STORIES — always shown, static editorial content *@
<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>📖 Cebu Food Stories</h2>
        <p>Stories from our vibrant food culture</p>
    </div>

    <div class="card-grid">
        <div class="story-card" data-aos="fade-up">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1569694119452-2b7eae2e4cbc?w=600&amp;q=80" onerror="this.src='https://placehold.co/600x400/1a1a1a/888?text=Cebu+Lechon'" alt="Lechon History">
            </div>
            <div class="card-content">
                <h3>Why Cebu Lechon is the Best in the World</h3>
                <p class="card-location">By Maria Santos · 5 min read</p>
                <p>The secrets behind Cebu's most iconic dish, from family recipes to modern interpretations.</p>
                <a href="/Stories" class="read-more">Read Story →</a>
            </div>
        </div>

        <div class="story-card" data-aos="fade-up" data-aos-delay="100">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1537047902294-62a40c20a6ae?w=600&amp;q=80" onerror="this.src='https://placehold.co/600x400/1a1a1a/888?text=Sutukil+Story'" alt="Sutukil Story">
            </div>
            <div class="card-content">
                <h3>The Story Behind Sutukil</h3>
                <p class="card-location">By Chef Miguel · 4 min read</p>
                <p>How Sugba, Tula, Kilaw became the heart of Cebu's seafood culture.</p>
                <a href="/Stories" class="read-more">Read Story →</a>
            </div>
        </div>

        <div class="story-card" data-aos="fade-up" data-aos-delay="200">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1442512595331-e89e73853f31?w=600&amp;q=80" onerror="this.src='https://placehold.co/600x400/1a1a1a/888?text=Hidden+Cafes'" alt="Hidden Cafes">
            </div>
            <div class="card-content">
                <h3>Hidden Cafes in IT Park You Need to Try</h3>
                <p class="card-location">By Alex Reyes · 6 min read</p>
                <p>From secret rooftops to underground coffee spots.</p>
                <a href="/Stories" class="read-more">Read Story →</a>
            </div>
        </div>
    </div>
</section>

<style>
    .home-empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-secondary);
    }

        .home-empty-state .empty-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }

        .home-empty-state h3 {
            font-size: 1.5rem;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .home-empty-state p {
            margin-bottom: 1rem;
        }

    .card-actions {
        display: flex;
        gap: 0.8rem;
        margin-top: 1rem;
    }

    .btn-crave, .btn-view {
        padding: 0.5rem 1rem;
        border-radius: 30px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        text-align: center;
        flex: 1;
    }

    .btn-crave {
        background: transparent;
        border: 1px solid var(--burnt-orange);
        color: var(--burnt-orange);
    }

        .btn-crave:hover {
            background: var(--burnt-orange);
            color: white;
        }

    .btn-crave--guest {
        opacity: 0.85;
    }

        .btn-crave--guest:hover {
            opacity: 1;
        }

    .btn-view {
        background: var(--gradient-warm);
        color: white;
        border: none;
    }

        .btn-view:hover {
            transform: translateX(3px);
        }

    .btn-tried {
        background: none;
        border: 1px solid var(--burnt-orange);
        color: var(--burnt-orange);
        padding: 0.5rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        cursor: pointer;
        margin-top: 0.8rem;
        transition: var(--transition);
        width: 100%;
    }

        .btn-tried:hover {
            background: var(--burnt-orange);
            color: white;
        }

    .btn-tried--guest {
        opacity: 0.85;
    }

        .btn-tried--guest:hover {
            opacity: 1;
        }

    .dish-price {
        font-weight: 700;
        color: var(--burnt-orange);
        margin: 0.5rem 0;
    }

    .dish-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.8rem 0;
    }

    .tag {
        background: var(--bg-elevated);
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.7rem;
        color: var(--text-secondary);
    }

    .progress-bar {
        background: var(--bg-elevated);
        border-radius: 10px;
        height: 6px;
        margin: 0.8rem 0 0.5rem;
        overflow: hidden;
    }

    .progress {
        background: var(--gradient-warm);
        height: 100%;
        border-radius: 10px;
    }

    .seats-left {
        font-size: 0.75rem;
        color: var(--text-secondary);
    }

    .read-more {
        color: var(--burnt-orange);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-block;
        margin-top: 0.8rem;
    }

        .read-more:hover {
            text-decoration: underline;
        }

    .date-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: var(--bg-dark);
        border-radius: 12px;
        text-align: center;
        padding: 0.3rem 0.6rem;
        min-width: 50px;
    }

    .date-month {
        display: block;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--burnt-orange);
        text-transform: uppercase;
    }

    .date-day {
        display: block;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .event-time {
        color: var(--text-secondary);
        font-size: 0.85rem;
        margin: 0.3rem 0;
    }
</style>

<script>
    );
        }

        function triedDish(name, id) {
            // Delegated to window.TasteCebu.triedDish in site.js (handles auth + API call)
            window.TasteCebu.triedDish(name, id);
        }

        function showToast(message) {
            var toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = message;
            document.body.appendChild(toast);
            setTimeout(function () { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
        }
</script>
