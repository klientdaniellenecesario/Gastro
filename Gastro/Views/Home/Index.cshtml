@{
    ViewData["Title"] = "Discover Cebu's Food Scene - TasteCebu";
}

@* HERO SECTION *@
<section class="hero">
    <div class="hero-content" data-aos="fade-up">
        <div class="hero-badge">
            <i class="fas fa-utensil-spoon"></i> SUGBA • SIKAT • SABOR
        </div>
        <h1>Discover Cebu's<br><span class="hero-highlight">Boldest Bites</span></h1>
        <p>From legendary lechon to hidden cafes — your gastro journey starts here</p>
        <div class="hero-buttons">
            <a href="/Restaurants" class="btn-primary">Explore Eateries →</a>
            <a href="/Dishes" class="btn-secondary">Discover Dishes →</a>
        </div>
    </div>
</section>

@* STATS STRIP *@
<div class="stats-strip" data-aos="fade-up">
    <div class="stat-item">
        <div class="stat-number">200+</div>
        <div class="stat-label">Restaurants</div>
    </div>
    <div class="stat-item">
        <div class="stat-number">500+</div>
        <div class="stat-label">Dishes</div>
    </div>
    <div class="stat-item">
        <div class="stat-number">50+</div>
        <div class="stat-label">Events</div>
    </div>
    <div class="stat-item">
        <div class="stat-number">10k+</div>
        <div class="stat-label">Foodies</div>
    </div>
</div>

@* WHAT'S YOUR VIBE? *@
<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>What's Your Vibe Today? ✨</h2>
        <p>Find restaurants that match your mood</p>
    </div>

    <div class="vibe-selector" data-aos="fade-up" data-aos-delay="100">
        <button class="vibe-btn active" onclick="filterByVibe('all')"><i class="fas fa-heart"></i> All</button>
        <button class="vibe-btn" onclick="filterByVibe('chill')"><i class="fas fa-coffee"></i> Chill</button>
        <button class="vibe-btn" onclick="filterByVibe('romantic')"><i class="fas fa-heart"></i> Romantic</button>
        <button class="vibe-btn" onclick="filterByVibe('fun')"><i class="fas fa-music"></i> Loud & Fun</button>
        <button class="vibe-btn" onclick="filterByVibe('solo')"><i class="fas fa-user"></i> Solo Friendly</button>
        <button class="vibe-btn" onclick="filterByVibe('family')"><i class="fas fa-users"></i> Family</button>
    </div>

    <div class="card-grid" id="restaurantGrid">
        @* Featured Restaurant 1 *@
        <div class="restaurant-card" data-vibe="chill" data-aos="fade-up" data-aos-delay="150">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=600&h=400&fit=crop" alt="Good Cup Coffee">
                <span class="card-badge new-badge">✨ NEW</span>
                <span class="card-vibe"><i class="fas fa-coffee"></i> Chill</span>
            </div>
            <div class="card-content">
                <h3>Good Cup Coffee</h3>
                <p class="card-location"><i class="fas fa-map-marker-alt"></i> AS Fortuna, Mandaue</p>
                <div class="rating">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                    <span>4.8 (234 reviews)</span>
                </div>
                <p>Single-origin brews, minimalist industrial vibe, and award-winning pastries.</p>
            </div>
        </div>

        @* Featured Restaurant 2 *@
        <div class="restaurant-card" data-vibe="fun" data-aos="fade-up" data-aos-delay="200">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&h=400&fit=crop" alt="House of Lechon">
                <span class="card-badge">🔥 HOT</span>
                <span class="card-vibe"><i class="fas fa-music"></i> Loud & Fun</span>
            </div>
            <div class="card-content">
                <h3>House of Lechon</h3>
                <p class="card-location"><i class="fas fa-map-marker-alt"></i> Capitol Site, Cebu City</p>
                <div class="rating">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    <span>4.9 (1.2k reviews)</span>
                </div>
                <p>Authentic Cebu lechon with crispy skin and signature spicy vinegar.</p>
            </div>
        </div>

        @* Featured Restaurant 3 *@
        <div class="restaurant-card" data-vibe="romantic" data-aos="fade-up" data-aos-delay="250">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&h=400&fit=crop" alt="Pig and Palm">
                <span class="card-badge">⭐ RECOMMENDED</span>
                <span class="card-vibe"><i class="fas fa-heart"></i> Romantic</span>
            </div>
            <div class="card-content">
                <h3>Pig and Palm</h3>
                <p class="card-location"><i class="fas fa-map-marker-alt"></i> Nivel Hills, Lahug</p>
                <div class="rating">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    <span>4.9 (567 reviews)</span>
                </div>
                <p>Modern European with Cebuano soul — craft cocktails, stunning sunset views.</p>
            </div>
        </div>

        @* Featured Restaurant 4 *@
        <div class="restaurant-card" data-vibe="family" data-aos="fade-up" data-aos-delay="300">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1537047902294-62a40c20a6ae?w=600&h=400&fit=crop" alt="Lantaw Native Restaurant">
                <span class="card-badge">👪 FAMILY</span>
                <span class="card-vibe"><i class="fas fa-users"></i> Family</span>
            </div>
            <div class="card-content">
                <h3>Lantaw Native Restaurant</h3>
                <p class="card-location"><i class="fas fa-map-marker-alt"></i> Cordova, Cebu</p>
                <div class="rating">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                    <span>4.7 (890 reviews)</span>
                </div>
                <p>Floating cottages, fresh seafood, and spectacular sunset views.</p>
            </div>
        </div>
    </div>
</section>

