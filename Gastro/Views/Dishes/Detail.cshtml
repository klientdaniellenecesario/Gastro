@using GastroCebu.Models
@{
    var dish = (DishListing)ViewData["Dish"]!;
    var reviews = (List<ReviewEntry>)ViewData["Reviews"]!;
    var names = (Dictionary<int, string>)ViewData["ReviewerNames"]!;
    var myIds = (HashSet<int>)(ViewData["UserReviewIds"] ?? new HashSet<int>());
    var isAuth = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = dish.Name + " - TasteCebu";

    decimal avgRating = reviews.Count > 0 ? Math.Round((decimal)reviews.Average(r => r.Rating), 1) : 0m;

    string RatingStars(decimal r)
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 1; i <= 5; i++)
        {
            if (r >= i) sb.Append("<i class=\"fas fa-star\"></i>");
            else if (r >= i - 0.5m) sb.Append("<i class=\"fas fa-star-half-alt\"></i>");
            else sb.Append("<i class=\"far fa-star\"></i>");
        }
        return sb.ToString();
    }

    var tagList = dish.Tags.Split(',', System.StringSplitOptions.RemoveEmptyEntries)
                          .Select(t => t.Trim()).ToList();
}

<section class="detail-shell">
    <nav class="breadcrumb-trail">
        <a href="/">Home</a><span>/</span><a href="/Dishes">Dishes</a><span>/</span><strong>@dish.Name</strong>
    </nav>

    <div class="detail-hero-card">
        <div class="dish-img-wrap">
            <img src="@dish.PhotoUrl" alt="@dish.Name">
            @if (dish.IsTrending)
            {
                <span class="img-badge trending">🔥 Trending</span>
            }
            else if (dish.IsNewThisMonth)
            {
                <span class="img-badge new-badge">✨ New</span>
            }
        </div>
        <div class="detail-hero-copy">
            <span class="detail-kicker">
                @if (dish.IsTrending)
                {
                    <text>🔥 Trending Dish</text>
                }
                else if (dish.IsNewThisMonth)
                {

                    <text>✨ New This Month</text>
                }
                else
                {

                    <text>Cebu Specialty</text>
                }
            </span>
            <h1>@dish.Name</h1>
            <p class="dish-desc">@dish.Description</p>

            <div class="detail-meta">
                <div class="meta-pill price-pill">
                    <i class="fas fa-tag"></i>
                    <span>PHP @dish.Price.ToString("N0")</span>
                </div>
                @if (reviews.Count > 0)
                {
                    <div class="meta-pill rating-pill">
                        <i class="fas fa-star"></i>
                        <span>@avgRating.ToString("F1") <span class="review-pill-count">(@reviews.Count @(reviews.Count == 1 ? "review" : "reviews"))</span></span>
                    </div>
                }
                else
                {
                    <div class="meta-pill rating-pill muted">
                        <i class="far fa-star"></i>
                        <span>No reviews yet</span>
                    </div>
                }
            </div>

            <div class="detail-actions">
                @if (isAuth)
                {
                    <button class="btn-primary" onclick="addToCravings('@dish.Name', @dish.Id, 'dish')">
                        <i class="fas fa-heart"></i> Save Dish
                    </button>
                    <button class="btn-tried-detail" onclick="triedDish('@dish.Name', @dish.Id)">
                        <i class="fas fa-check-circle"></i> I Tried This
                    </button>
                }
                else
                {
                    <button class="btn-primary btn-guest-action" onclick="showGuestModal('/Dishes/Detail/@dish.Id')">
                        <i class="fas fa-heart"></i> Save Dish
                    </button>
                    <button class="btn-tried-detail btn-guest-action" onclick="showGuestModal('/Dishes/Detail/@dish.Id')">
                        <i class="fas fa-check-circle"></i> I Tried This
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="detail-grid">
        <!-- TAGS -->
        <div class="detail-panel">
            <h2><i class="fas fa-hashtag"></i> Food Tags</h2>
            <div class="vibe-tags">
                @foreach (var tag in tagList)
                {
                    <span class="vibe-tag">@tag</span>
                }
                @if (!tagList.Any())
                {
                    <span class="vibe-tag">Cebu Food</span>
                }
            </div>
        </div>

        <!-- REVIEW FORM -->
        <div class="detail-panel review-form-panel">
            <h2><i class="fas fa-pencil-alt"></i> Review This Dish</h2>
            @if (isAuth)
            {
                <div class="star-rating-selector" id="dishStars">
                    <i class="far fa-star" onclick="dishSetRating(1)"></i>
                    <i class="far fa-star" onclick="dishSetRating(2)"></i>
                    <i class="far fa-star" onclick="dishSetRating(3)"></i>
                    <i class="far fa-star" onclick="dishSetRating(4)"></i>
                    <i class="far fa-star" onclick="dishSetRating(5)"></i>
                </div>
                <textarea id="dishReviewText" rows="4" placeholder="What did you think of this dish?"></textarea>
                <button class="btn-primary" onclick="submitDishReview()">
                    <i class="fas fa-paper-plane"></i> Submit Review
                </button>
            }
            else
            {
                <div class="login-nudge">
                    <i class="fas fa-user-circle"></i>
                    <p><a href="/Account/Login?returnUrl=/Dishes/Detail/@dish.Id">Sign in</a> to leave a review.</p>
                </div>
            }
        </div>
    </div>

    <!-- REVIEWS LIST -->
    @if (reviews.Any())
    {
        <div class="reviews-section">
            <h2 class="reviews-heading">
                <i class="fas fa-comments"></i>
                @reviews.Count @(reviews.Count == 1 ? "Review" : "Reviews")
                @if (avgRating > 0)
                {
                    <span class="avg-badge">⭐ @avgRating.ToString("F1")</span>
                }
            </h2>
            @foreach (var review in reviews)
            {
                var canEdit = myIds.Contains(review.Id);
                var canDelete = canEdit || isAdmin;
                <div class="review-card" id="review-@review.Id">
                    <div class="reviewer-info">
                        <div class="reviewer-avatar">@names[review.Id][0]</div>
                        <div class="reviewer-text">
                            <h4>@names[review.Id]</h4>
                            <div class="review-stars">@Html.Raw(RatingStars(review.Rating))</div>
                            <p class="review-date">@review.CreatedAt.ToLocalTime().ToString("MMMM d, yyyy")</p>
                        </div>
                        @if (canDelete)
                        {
                            <div class="review-actions">
                                @if (canEdit)
                                {
                                    <button class="review-action-btn" onclick="openEditModal(@review.Id, @review.Rating, @Json.Serialize(review.Text))">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                }
                                <button class="review-action-btn delete" onclick="deleteReview(@review.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <p class="review-text">@review.Text</p>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-reviews-state">
            <i class="fas fa-comment-slash"></i>
            <p>No reviews yet — be the first to share your thoughts!</p>
        </div>
    }
</section>

<!-- EDIT MODAL -->
<div id="editModal" class="modal-backdrop" style="display:none">
    <div class="modal-box">
        <h3>Edit Review</h3>
        <div class="star-rating-selector" id="editStars">
            <i class="far fa-star" onclick="dishSetEditRating(1)"></i>
            <i class="far fa-star" onclick="dishSetEditRating(2)"></i>
            <i class="far fa-star" onclick="dishSetEditRating(3)"></i>
            <i class="far fa-star" onclick="dishSetEditRating(4)"></i>
            <i class="far fa-star" onclick="dishSetEditRating(5)"></i>
        </div>
        <textarea id="editReviewText" rows="4"></textarea>
        <div class="modal-actions">
            <button class="btn-primary" onclick="saveEdit()">Save</button>
            <button class="btn-secondary" onclick="closeEditModal()">Cancel</button>
        </div>
    </div>
</div>

<style>
    .detail-shell {
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 2rem;
    }

    .breadcrumb-trail {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        color: var(--text-secondary);
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

        .breadcrumb-trail a {
            color: var(--burnt-orange);
            text-decoration: none;
        }

    .detail-hero-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: start;
        background: var(--bg-card);
        border-radius: 20px;
        padding: 1.5rem;
    }

    .dish-img-wrap {
        position: relative;
    }

        .dish-img-wrap img {
            width: 100%;
            aspect-ratio: 4/3;
            object-fit: cover;
            border-radius: 16px;
            display: block;
        }

    .img-badge {
        position: absolute;
        top: 0.8rem;
        left: 0.8rem;
        padding: 0.3rem 0.8rem;
        border-radius: 30px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

        .img-badge.trending {
            background: rgba(231, 76, 60, 0.9);
            color: white;
        }

        .img-badge.new-badge {
            background: rgba(39, 174, 96, 0.9);
            color: white;
        }

    .detail-kicker {
        color: var(--burnt-orange);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.78rem;
        letter-spacing: 0.06em;
    }

    .detail-hero-copy h1 {
        font-size: 2.8rem;
        margin: 0.4rem 0 0.7rem;
        line-height: 1.1;
    }

    .dish-desc {
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: 1.2rem;
    }

    .detail-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-bottom: 1.4rem;
    }

    .meta-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.4rem 1rem;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .price-pill {
        background: rgba(var(--burnt-orange-rgb, 204, 85, 0), 0.12);
        color: var(--burnt-orange);
        border: 1px solid rgba(var(--burnt-orange-rgb, 204, 85, 0), 0.25);
    }

    .rating-pill {
        background: rgba(255, 193, 7, 0.12);
        color: var(--golden-yellow, #f1c40f);
        border: 1px solid rgba(255, 193, 7, 0.25);
    }

        .rating-pill.muted {
            background: var(--bg-elevated);
            color: var(--text-secondary);
            border-color: var(--border-color);
            font-weight: 400;
        }

    .review-pill-count {
        font-weight: 400;
        opacity: 0.8;
    }

    .detail-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .btn-tried-detail {
        background: none;
        border: 1.5px solid var(--burnt-orange);
        color: var(--burnt-orange);
        padding: 0.6rem 1.2rem;
        border-radius: 30px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: var(--transition);
        font-weight: 600;
    }

        .btn-tried-detail:hover {
            background: var(--burnt-orange);
            color: white;
        }

    .btn-guest-action::after {
        content: '🔒';
        font-size: 0.7rem;
        margin-left: 4px;
        vertical-align: middle;
    }

    /* Detail grid */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 1.5rem;
    }

    .detail-panel {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 1.5rem;
    }

        .detail-panel h2 {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1rem;
            font-size: 1.1rem;
            color: var(--text-primary);
        }

            .detail-panel h2 i {
                color: var(--burnt-orange);
                font-size: 0.95rem;
            }

    .vibe-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .vibe-tag {
        background: var(--bg-elevated);
        padding: 0.35rem 1rem;
        border-radius: 30px;
        font-size: 0.85rem;
        color: var(--text-secondary);
        transition: var(--transition);
    }

        .vibe-tag:hover {
            background: var(--burnt-orange);
            color: white;
        }

    /* Review form */
    .star-rating-selector {
        margin-bottom: 0.8rem;
    }

        .star-rating-selector i {
            color: var(--golden-yellow, #f1c40f);
            cursor: pointer;
            font-size: 1.6rem;
            margin-right: 0.2rem;
            transition: transform 0.1s;
        }

            .star-rating-selector i:hover {
                transform: scale(1.15);
            }

            .star-rating-selector i.active {
                color: var(--golden-yellow, #f1c40f);
            }

    .detail-panel textarea {
        width: 100%;
        margin: 0.8rem 0;
        background: var(--bg-elevated);
        color: var(--text-primary);
        border: 1px solid var(--border-color, var(--text-muted));
        border-radius: 12px;
        padding: 0.8rem;
        resize: vertical;
        font-size: 0.9rem;
        line-height: 1.5;
        transition: border-color 0.2s;
    }

        .detail-panel textarea:focus {
            outline: none;
            border-color: var(--burnt-orange);
        }

    .login-nudge {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1rem;
        background: var(--bg-elevated);
        border-radius: 12px;
        color: var(--text-secondary);
    }

        .login-nudge i {
            font-size: 1.8rem;
            color: var(--burnt-orange);
            opacity: 0.7;
        }

        .login-nudge a {
            color: var(--burnt-orange);
            font-weight: 600;
        }

    /* Reviews list */
    .reviews-section {
        margin-top: 2.5rem;
    }

    .reviews-heading {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 1.4rem;
        margin-bottom: 1.2rem;
    }

        .reviews-heading i {
            color: var(--burnt-orange);
        }

    .avg-badge {
        background: var(--bg-elevated);
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.2rem 0.7rem;
        border-radius: 30px;
        color: var(--text-secondary);
    }

    .review-card {
        background: var(--bg-card);
        padding: 1.5rem;
        border-radius: 16px;
        margin-bottom: 1rem;
        border-left: 3px solid transparent;
        transition: border-color 0.2s;
    }

        .review-card:hover {
            border-left-color: var(--burnt-orange);
        }

    .reviewer-info {
        display: flex;
        gap: 1rem;
        margin-bottom: 0.8rem;
        align-items: flex-start;
    }

    .reviewer-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--gradient-warm);
        color: white;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.1rem;
    }

    .reviewer-text h4 {
        margin: 0 0 0.2rem;
        font-size: 0.95rem;
    }

    .review-stars i {
        color: var(--golden-yellow, #f1c40f);
        font-size: 0.8rem;
    }

    .review-date {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin: 0.2rem 0 0;
    }

    .review-text {
        margin: 0;
        line-height: 1.6;
        color: var(--text-secondary);
    }

    .review-actions {
        margin-left: auto;
        display: flex;
        gap: 0.4rem;
    }

    .review-action-btn {
        background: none;
        border: 1px solid var(--border-color, var(--text-muted));
        color: var(--text-secondary);
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
    }

        .review-action-btn:hover {
            border-color: var(--burnt-orange);
            color: var(--burnt-orange);
        }

        .review-action-btn.delete:hover {
            border-color: #e74c3c;
            color: #e74c3c;
        }

    .no-reviews-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--text-secondary);
        background: var(--bg-card);
        border-radius: 16px;
        margin-top: 2rem;
    }

        .no-reviews-state i {
            font-size: 2.5rem;
            opacity: 0.3;
            display: block;
            margin-bottom: 0.8rem;
        }

    /* Modal */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-box {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 2rem;
        width: 90%;
        max-width: 480px;
    }

        .modal-box h3 {
            margin-bottom: 1rem;
        }

        .modal-box textarea {
            width: 100%;
            background: var(--bg-elevated);
            border: 1px solid var(--border-color, var(--text-muted));
            color: var(--text-primary);
            padding: 0.8rem;
            border-radius: 12px;
            margin: 1rem 0;
            resize: vertical;
        }

    .modal-actions {
        display: flex;
        gap: 1rem;
    }

    @@media (max-width: 768px) {
        .detail-hero-card, .detail-grid {
            grid-template-columns: 1fr;
        }

        .detail-hero-copy h1 {
            font-size: 2rem;
        }
    }
</style>

<script>
    var dishId = @dish.Id;
    var dishRating = 0;

    function dishSetRating(rating) {
        dishRating = rating;
        document.querySelectorAll('#dishStars i').forEach(function(s, i) {
            s.className = i < rating ? 'fas fa-star active' : 'far fa-star';
        });
    }

    async function submitDishReview() {
        var text = document.getElementById('dishReviewText').value.trim();
        if (!dishRating || !text) { showToast('Add a rating and review first.'); return; }
        var res = await fetch('/api/reviews', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ targetType: 'dish', targetId: dishId, rating: dishRating, text: text })
        });
        if (res.ok) {
            document.getElementById('dishReviewText').value = '';
            dishSetRating(0);
            location.reload();
        } else {
            var err = await res.json();
            showToast(err.message || 'Could not submit review.');
        }
    }

    var editingReviewId = 0, editRating = 0;
    function openEditModal(id, rating, text) {
        editingReviewId = id; editRating = rating;
        document.getElementById('editReviewText').value = text;
        dishSetEditRating(rating);
        document.getElementById('editModal').style.display = 'flex';
    }
    function closeEditModal() { document.getElementById('editModal').style.display = 'none'; }
    function dishSetEditRating(rating) {
        editRating = rating;
        document.querySelectorAll('#editStars i').forEach(function(s, i) {
            s.className = i < rating ? 'fas fa-star active' : 'far fa-star';
        });
    }
    async function saveEdit() {
        var text = document.getElementById('editReviewText').value.trim();
        if (!editRating || !text) { showToast('Rating and text required.'); return; }
        var res = await fetch('/api/reviews/' + editingReviewId, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rating: editRating, text: text })
        });
        if (res.ok) { closeEditModal(); location.reload(); }
        else { var err = await res.json(); showToast(err.message || 'Update failed.'); }
    }
    async function deleteReview(id) {
        if (!confirm('Delete this review?')) return;
        var res = await fetch('/api/reviews/' + id, { method: 'DELETE' });
        if (res.ok) location.reload();
        else showToast('Could not delete review.');
    }

    function showToast(message) {
        var t = document.createElement('div');
        t.className = 'toast-notification';
        t.textContent = message;
        document.body.appendChild(t);
        setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 3000);
    }
</script>
