@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.SelectTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Dish Discovery - TasteCebu";
    var dishes = ViewData["DatabaseDishes"] as List<GastroCebu.Models.DishListing> ?? new();
    var featuredDish = dishes.FirstOrDefault(d => d.IsTrending) ?? dishes.FirstOrDefault();
    var isAuth = User.Identity?.IsAuthenticated == true;
}

@* DISH OF THE DAY HERO — only shown when there is at least one dish *@
@if (featuredDish != null)
{
    <section class="dish-of-day" style="background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);">
        <div class="dish-of-day-container">
            <div class="dish-of-day-content" data-aos="fade-right">
                <span class="dish-of-day-badge">DISH OF THE DAY</span>
                <h2>@featuredDish.Name</h2>
                <p>@(string.IsNullOrWhiteSpace(featuredDish.Tags) ? "A must-try dish in Cebu!" : string.Join(" · ", featuredDish.Tags.Split(',').Select(t => t.Trim())))</p>
                <div class="dish-meta">
                    <span><i class="fas fa-tag"></i> PHP @featuredDish.Price.ToString("0.##")</span>
                    @if (featuredDish.IsTrending)
                    {
                        <span><i class="fas fa-fire"></i> Trending</span>
                    }
                    @if (featuredDish.IsNewThisMonth)
                    {
                        <span><i class="fas fa-certificate"></i> New This Month</span>
                    }
                </div>
                <div class="dish-actions">
                    @if (isAuth)
                    {
                        <button class="btn-tried" onclick="triedDish('@featuredDish.Name', @featuredDish.Id)"><i class="fas fa-check-circle"></i> I Tried This</button>
                    }
                    else
                    {
                        <button class="btn-tried btn-tried--guest" onclick="showGuestModal(window.location.pathname)"><i class="fas fa-lock"></i> Sign in to Track</button>
                    }
                    @if (isAuth)
                    {
                        <button class="btn-crave" onclick="addToCravings('@featuredDish.Name', @featuredDish.Id, 'dish')"><i class="fas fa-heart"></i> Add to Cravings</button>
                    }
                    else
                    {
                        <button class="btn-crave btn-crave--guest" onclick="showGuestModal(window.location.pathname)"><i class="fas fa-lock"></i> Sign in to Save</button>
                    }
                </div>
            </div>
            <div class="dish-of-day-image" data-aos="fade-left">
                <img src="@featuredDish.PhotoUrl" alt="@featuredDish.Name">
            </div>
        </div>
    </section>
}

<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>Explore Dishes</h2>
        <p>Discover trending, classic, and hidden gem dishes around Cebu</p>
    </div>

    @* FILTERS *@
    <div class="filters-bar" data-aos="fade-up">
        @{
            var selectedTags = ViewData["SelectedTags"]?.ToString() ?? "";
            var selectedSort2 = ViewData["SelectedSort"]?.ToString() ?? "newest";

            string IsSelected(string value, string selected) => value == selected ? "selected" : "";
        }
        <form method="post" action="/Dishes/Search" class="search-form" style="display: flex; gap: 1rem; align-items: center; flex: 1;">
            <div class="search-bar" style="flex: 1;">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search dishes..." id="dishSearch" name="query" value="@(ViewData["SearchQuery"] ?? "")">
            </div>

            <select name="tags" class="filter-select">
                <option value="">All Tags</option>
                <option value="trending" @IsSelected("trending", selectedTags)>Trending</option>
                <option value="new" @IsSelected("new", selectedTags)>New This Month</option>
                <option value="seafood" @IsSelected("seafood", selectedTags)>Seafood</option>
                <option value="spicy" @IsSelected("spicy", selectedTags)>Spicy</option>
                <option value="vegetarian" @IsSelected("vegetarian", selectedTags)>Vegetarian</option>
            </select>

            <select name="sortBy" class="filter-select">
                <option value="newest" @IsSelected("newest", selectedSort2)>Newest</option>
                <option value="trending" @IsSelected("trending", selectedSort2)>Trending</option>
                <option value="new" @IsSelected("new", selectedSort2)>New This Month</option>
                <option value="price-low" @IsSelected("price-low", selectedSort2)>Price: Low to High</option>
                <option value="price-high" @IsSelected("price-high", selectedSort2)>Price: High to Low</option>
            </select>

            <button type="submit" class="btn-primary" style="white-space: nowrap;">
                <i class="fas fa-search"></i> Search
            </button>
        </form>
    </div>

    @* SEARCH RESULTS SUMMARY *@
    @if (!string.IsNullOrEmpty(ViewData["SearchQuery"]?.ToString()))
    {
        <div class="search-summary" style="background: var(--bg-elevated); padding: 1rem; border-radius: 8px; margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
            <div>
                <p style="margin: 0; color: var(--text-secondary);">
                    Showing <strong>@dishes.Count</strong> dish@(dishes.Count != 1 ? "es" : "") for "<strong>@ViewData["SearchQuery"]</strong>"
                </p>
            </div>
            <a href="/Dishes" class="btn-secondary" style="text-decoration: none; padding: 0.5rem 1rem; font-size: 0.9rem;">
                <i class="fas fa-times"></i> Clear Search
            </a>
        </div>
    }

    @if (!dishes.Any())
    {
        <div class="empty-state" data-aos="fade-up">
            <div class="empty-state-icon">🥘</div>
            <h3>No dishes added yet</h3>
            <p>The admin hasn't added any dishes yet. Check back soon!</p>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Dashboard" class="btn-primary">Add a Dish →</a>
            }
        </div>
    }
    else
    {
        <div class="masonry-grid" id="dishesGrid">
            @if (dishes.Any(d => d.IsTrending))
            {
                <div class="section-group">
                    <div class="section-label">
                        <h3><i class="fas fa-fire"></i> Trending Now</h3>
                    </div>
                    <div class="section-group-cards">
                        @foreach (var dish in dishes.Where(d => d.IsTrending))
                        {
                            <div class="dish-card" data-category="trending" data-name="@dish.Name">
                                <div class="card-image">
                                    <img src="@dish.PhotoUrl" alt="@dish.Name">
                                    <div class="card-badges"><span class="card-badge trending-badge">TRENDING</span></div>
                                </div>
                                <div class="card-content">
                                    <h3>@dish.Name</h3>
                                    <p class="dish-price">PHP @dish.Price.ToString("0.##")</p>
                                    <div class="dish-tags">
                                        @foreach (var tag in (dish.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span class="tag">@tag.Trim()</span>
                                        }
                                    </div>
                                    @if (isAuth)
                                    {
                                        <button class="btn-tried" onclick="triedDish('@dish.Name', @dish.Id)">I Tried This</button>
                                    }
                                    else
                                    {
                                        <button class="btn-tried btn-tried--guest" onclick="showGuestModal(window.location.pathname)"><i class="fas fa-lock"></i> Sign in to Track</button>
                                    }
                                    @if (isAuth)
                                    {
                                        <button class="btn-crave" onclick="addToCravings('@dish.Name', @dish.Id, 'dish')">Add to Cravings</button>
                                    }
                                    else
                                    {
                                        <button class="btn-crave btn-crave--guest" onclick="showGuestModal(window.location.pathname)"><i class="fas fa-lock"></i> Sign in to Save</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (dishes.Any(d => d.IsNewThisMonth))
            {
                <div class="section-group">
                    <div class="section-label">
                        <h3><i class="fas fa-certificate"></i> New This Month</h3>
                    </div>
                    <div class="section-group-cards">
                        @foreach (var dish in dishes.Where(d => d.IsNewThisMonth))
                        {
                            <div class="dish-card" data-category="new" data-name="@dish.Name">
                                <div class="card-image">
                                    <img src="@dish.PhotoUrl" alt="@dish.Name">
                                    <div class="card-badges"><span class="card-badge new-badge">NEW</span></div>
                                </div>
                                <div class="card-content">
                                    <h3>@dish.Name</h3>
                                    <p class="dish-price">PHP @dish.Price.ToString("0.##")</p>
                                    <div class="dish-tags">
                                        @foreach (var tag in (dish.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span class="tag">@tag.Trim()</span>
                                        }
                                    </div>
                                    @if (isAuth)
                                    {
                                        <button class="btn-tried" onclick="triedDish('@dish.Name', @dish.Id)">I Tried This</button>
                                    }
                                    else
                                    {
                                        <button class="btn-tried btn-tried--guest" onclick="showGuestModal(window.location.pathname)"><i class="fas fa-lock"></i> Sign in to Track</button>
                                    }
                                    @if (isAuth)
                                    {
                                        <button class="btn-crave" onclick="addToCravings('@dish.Name', @dish.Id, 'dish')">Add to Cravings</button>
                                    }
                                    else
                                    {
                                        <button class="btn-crave btn-crave--guest" onclick="showGuestModal(window.location.pathname)"><i class="fas fa-lock"></i> Sign in to Save</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @{
                var otherDishes = dishes.Where(d => !d.IsTrending && !d.IsNewThisMonth).ToList();
            }
            @if (otherDishes.Any())
            {
                <div class="section-group">
                    <div class="section-label">
                        <h3><i class="fas fa-utensils"></i> All Dishes</h3>
                    </div>
                    <div class="section-group-cards">
                        @foreach (var dish in otherDishes)
                        {
                            var firstTag = (dish.Tags ?? "dish").Split(',').FirstOrDefault()?.Trim().ToLowerInvariant().Replace(" ", "-") ?? "dish";
                            <div class="dish-card" data-category="@firstTag" data-name="@dish.Name">
                                <div class="card-image">
                                    <img src="@dish.PhotoUrl" alt="@dish.Name">
                                    <div class="card-badges"><span class="card-badge">@(dish.Tags?.Split(',').FirstOrDefault()?.Trim().ToUpperInvariant() ?? "DISH")</span></div>
                                </div>
                                <div class="card-content">
                                    <h3>@dish.Name</h3>
                                    <p class="dish-price">PHP @dish.Price.ToString("0.##")</p>
                                    <div class="dish-tags">
                                        @foreach (var tag in (dish.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span class="tag">@tag.Trim()</span>
                                        }
                                    </div>
                                    @if (isAuth)
                                    {
                                        <button class="btn-tried" onclick="triedDish('@dish.Name', @dish.Id)">I Tried This</button>
                                    }
                                    else
                                    {
                                        <button class="btn-tried btn-tried--guest" onclick="showGuestModal(window.location.pathname)"><i class="fas fa-lock"></i> Sign in to Track</button>
                                    }
                                    @if (isAuth)
                                    {
                                        <button class="btn-crave" onclick="addToCravings('@dish.Name', @dish.Id, 'dish')">Add to Cravings</button>
                                    }
                                    else
                                    {
                                        <button class="btn-crave btn-crave--guest" onclick="showGuestModal(window.location.pathname)"><i class="fas fa-lock"></i> Sign in to Save</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</section>

<style>
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--text-secondary);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        margin-bottom: 1.5rem;
    }

    .dish-of-day {
        padding: 4rem 2rem;
        min-height: 70vh;
        display: flex;
        align-items: center;
    }

    .dish-of-day-container {
        max-width: var(--container-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
    }

    .dish-of-day-badge {
        display: inline-block;
        background: rgba(231, 111, 81, 0.2);
        padding: 0.3rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        color: var(--burnt-orange);
        margin-bottom: 1rem;
    }

    .dish-of-day-content h2 {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .dish-meta {
        display: flex;
        gap: 1.5rem;
        margin: 1.5rem 0;
        color: var(--text-secondary);
    }

        .dish-meta i {
            color: var(--burnt-orange);
            margin-right: 5px;
        }

    .dish-of-day-image img {
        width: 100%;
        border-radius: 30px;
        box-shadow: var(--shadow-lg);
    }

    .dish-actions {
        display: flex;
        gap: 1rem;
    }

    .masonry-grid {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .section-group {
        margin-bottom: 2.5rem;
    }

    .section-label {
        margin: 0 0 1rem;
        padding-left: 0.5rem;
        border-left: 4px solid var(--burnt-orange);
    }

    .section-group-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .dish-card, .restaurant-card {
        margin-bottom: 0;
    }

    .dish-price {
        font-weight: 700;
        color: var(--burnt-orange);
        margin: 0.5rem 0;
    }

    .dish-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.8rem 0;
    }

    .tag {
        background: var(--bg-elevated);
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.7rem;
        color: var(--text-secondary);
    }

    .filter-select {
        background: var(--bg-elevated);
        border: 1px solid var(--text-muted);
        color: var(--text-primary);
        padding: 0.75rem 1rem;
        border-radius: 30px;
        cursor: pointer;
        font-size: 0.9rem;
    }

    .btn-tried, .btn-crave {
        background: none;
        border: 1px solid var(--burnt-orange);
        color: var(--burnt-orange);
        padding: 0.5rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        cursor: pointer;
        margin-top: 0.8rem;
        transition: var(--transition);
        width: 100%;
    }

        .btn-tried:hover, .btn-crave:hover {
            background: var(--burnt-orange);
            color: white;
        }

    .btn-crave--guest {
        display: block;
        text-align: center;
        text-decoration: none;
        opacity: 0.8;
        width: 100%;
    }

        .btn-crave--guest:hover {
            opacity: 1;
        }

    .btn-tried--guest {
        display: block;
        text-align: center;
        text-decoration: none;
        opacity: 0.8;
        width: 100%;
    }

        .btn-tried--guest:hover {
            opacity: 1;
        }

    @@media (max-width: 1024px) {
        .section-group-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .dish-of-day-container {
            grid-template-columns: 1fr;
        }

        .section-group-cards {
            grid-template-columns: 1fr;
        }

        .dish-of-day-content h2 {
            font-size: 2rem;
        }

        .dish-actions {
            flex-direction: column;
        }
    }
</style>

<script>
    function filterDishCategory(category) {
        var cards = document.querySelectorAll('.dish-card');
        var sections = document.querySelectorAll('.section-label');
        var buttons = document.querySelectorAll('.filter-tab');

        buttons.forEach(b => b.classList.remove('active'));
        if (event && event.target) event.target.classList.add('active');

        cards.forEach(card => {
            card.style.display = (category === 'all' || card.dataset.category === category) ? 'block' : 'none';
        });

        showToast('Showing ' + category + ' dishes');
    }

    var dishSearch = document.getElementById('dishSearch');
    if (dishSearch) {
        dishSearch.addEventListener('keyup', function () {
            var filter = this.value.toLowerCase();
            document.querySelectorAll('.dish-card').forEach(card => {
                var name = card.querySelector('h3')?.innerText.toLowerCase() ?? '';
                card.style.display = name.includes(filter) ? '' : 'none';
            });
        });
    }

    // Broken image fallback for all dish photos
    document.querySelectorAll('.card-image img, .dish-of-day-image img').forEach(function (img) {
        img.addEventListener('error', function () {
            this.src = 'https://placehold.co/400x300/1a1a1a/888?text=No+Photo';
        });
    });

    function showToast(message) {
        var toast = document.createElement('div');
        toast.className = 'toast-notification';
        toast.innerHTML = message;
        document.body.appendChild(toast);
        setTimeout(function () { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
    }
</script>
