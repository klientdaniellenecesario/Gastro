@{
    ViewData["Title"] = "Dish Discovery - TasteCebu";
    var dishes = ViewData["DatabaseDishes"] as List<GastroCebu.Models.DishListing> ?? new();
    var featuredDish = dishes.FirstOrDefault(d => d.IsTrending) ?? dishes.FirstOrDefault();
}

@* DISH OF THE DAY HERO — only shown when there is at least one dish *@
@if (featuredDish != null)
{
    <section class="dish-of-day" style="background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);">
        <div class="dish-of-day-container">
            <div class="dish-of-day-content" data-aos="fade-right">
                <span class="dish-of-day-badge">DISH OF THE DAY</span>
                <h2>@featuredDish.Name</h2>
                <p>@(string.IsNullOrWhiteSpace(featuredDish.Tags) ? "A must-try dish in Cebu!" : string.Join(" · ", featuredDish.Tags.Split(',').Select(t => t.Trim())))</p>
                <div class="dish-meta">
                    <span><i class="fas fa-tag"></i> PHP @featuredDish.Price.ToString("0.##")</span>
                    @if (featuredDish.IsTrending)
                    {
                        <span><i class="fas fa-fire"></i> Trending</span>
                    }
                    @if (featuredDish.IsNewThisMonth)
                    {
                        <span><i class="fas fa-certificate"></i> New This Month</span>
                    }
                </div>
                <div class="dish-actions">
                    <button class="btn-tried" onclick="triedDish('@featuredDish.Name', @featuredDish.Id)"><i class="fas fa-check-circle"></i> I Tried This</button>
                    <button class="btn-crave" onclick="addToCravings('@featuredDish.Name', @featuredDish.Id, 'dish')"><i class="fas fa-heart"></i> Add to Cravings</button>
                </div>
            </div>
            <div class="dish-of-day-image" data-aos="fade-left">
                <img src="@featuredDish.PhotoUrl" alt="@featuredDish.Name">
            </div>
        </div>
    </section>
}

<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>Explore Dishes</h2>
        <p>Discover trending, classic, and hidden gem dishes around Cebu</p>
    </div>

    @* FILTERS *@
    <div class="filters-bar" data-aos="fade-up">
        <div class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search dishes..." id="dishSearch">
        </div>

        <div class="filter-tabs">
            <button class="filter-tab active" onclick="filterDishCategory('all')">All</button>
            <button class="filter-tab" onclick="filterDishCategory('trending')">Trending</button>
            <button class="filter-tab" onclick="filterDishCategory('new')">New This Month</button>
            <button class="filter-tab" onclick="filterDishCategory('seafood')">Seafood</button>
            <button class="filter-tab" onclick="filterDishCategory('spicy')">Spicy</button>
            <button class="filter-tab" onclick="filterDishCategory('vegetarian')">Vegetarian</button>
        </div>
    </div>

    @if (!dishes.Any())
    {
        <div class="empty-state" data-aos="fade-up">
            <div class="empty-state-icon">🥘</div>
            <h3>No dishes added yet</h3>
            <p>The admin hasn't added any dishes yet. Check back soon!</p>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Dashboard" class="btn-primary">Add a Dish →</a>
            }
        </div>
    }
    else
    {
        <div class="masonry-grid" id="dishesGrid">
            @if (dishes.Any(d => d.IsTrending))
            {
                <div class="section-label">
                    <h3><i class="fas fa-fire"></i> Trending Now</h3>
                </div>
                @foreach (var dish in dishes.Where(d => d.IsTrending))
                {
                    <div class="dish-card" data-category="trending" data-name="@dish.Name">
                        <div class="card-image">
                            <img src="@dish.PhotoUrl" alt="@dish.Name">
                            <span class="card-badge">TRENDING</span>
                        </div>
                        <div class="card-content">
                            <h3>@dish.Name</h3>
                            <p class="dish-price">PHP @dish.Price.ToString("0.##")</p>
                            <div class="dish-tags">
                                @foreach (var tag in (dish.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="tag">@tag.Trim()</span>
                                }
                            </div>
                            <button class="btn-tried" onclick="triedDish('@dish.Name', @dish.Id)">I Tried This</button>
                            <button class="btn-crave" onclick="addToCravings('@dish.Name', @dish.Id, 'dish')">Add to Cravings</button>
                        </div>
                    </div>
                }
            }

            @if (dishes.Any(d => d.IsNewThisMonth))
            {
                <div class="section-label">
                    <h3><i class="fas fa-certificate"></i> New This Month</h3>
                </div>
                @foreach (var dish in dishes.Where(d => d.IsNewThisMonth))
                {
                    <div class="dish-card" data-category="new" data-name="@dish.Name">
                        <div class="card-image">
                            <img src="@dish.PhotoUrl" alt="@dish.Name">
                            <span class="card-badge new-badge">NEW</span>
                        </div>
                        <div class="card-content">
                            <h3>@dish.Name</h3>
                            <p class="dish-price">PHP @dish.Price.ToString("0.##")</p>
                            <div class="dish-tags">
                                @foreach (var tag in (dish.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="tag">@tag.Trim()</span>
                                }
                            </div>
                            <button class="btn-tried" onclick="triedDish('@dish.Name', @dish.Id)">I Tried This</button>
                            <button class="btn-crave" onclick="addToCravings('@dish.Name', @dish.Id, 'dish')">Add to Cravings</button>
                        </div>
                    </div>
                }
            }

            @{
                var otherDishes = dishes.Where(d => !d.IsTrending && !d.IsNewThisMonth).ToList();
            }
            @if (otherDishes.Any())
            {
                <div class="section-label">
                    <h3><i class="fas fa-utensils"></i> All Dishes</h3>
                </div>
                @foreach (var dish in otherDishes)
                {
                    var firstTag = (dish.Tags ?? "dish").Split(',').FirstOrDefault()?.Trim().ToLowerInvariant().Replace(" ", "-") ?? "dish";
                    <div class="dish-card" data-category="@firstTag" data-name="@dish.Name">
                        <div class="card-image">
                            <img src="@dish.PhotoUrl" alt="@dish.Name">
                            <span class="card-badge">@(dish.Tags?.Split(',').FirstOrDefault()?.Trim().ToUpperInvariant() ?? "DISH")</span>
                        </div>
                        <div class="card-content">
                            <h3>@dish.Name</h3>
                            <p class="dish-price">PHP @dish.Price.ToString("0.##")</p>
                            <div class="dish-tags">
                                @foreach (var tag in (dish.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="tag">@tag.Trim()</span>
                                }
                            </div>
                            <button class="btn-tried" onclick="triedDish('@dish.Name', @dish.Id)">I Tried This</button>
                            <button class="btn-crave" onclick="addToCravings('@dish.Name', @dish.Id, 'dish')">Add to Cravings</button>
                        </div>
                    </div>
                }
            }
        </div>
    }
</section>

<style>
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--text-secondary);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        margin-bottom: 1.5rem;
    }

    .dish-of-day {
        padding: 4rem 2rem;
        min-height: 70vh;
        display: flex;
        align-items: center;
    }

    .dish-of-day-container {
        max-width: var(--container-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
    }

    .dish-of-day-badge {
        display: inline-block;
        background: rgba(231, 111, 81, 0.2);
        padding: 0.3rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        color: var(--burnt-orange);
        margin-bottom: 1rem;
    }

    .dish-of-day-content h2 {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .dish-meta {
        display: flex;
        gap: 1.5rem;
        margin: 1.5rem 0;
        color: var(--text-secondary);
    }

        .dish-meta i {
            color: var(--burnt-orange);
            margin-right: 5px;
        }

    .dish-of-day-image img {
        width: 100%;
        border-radius: 30px;
        box-shadow: var(--shadow-lg);
    }

    .dish-actions {
        display: flex;
        gap: 1rem;
    }

    .masonry-grid {
        column-count: 3;
        column-gap: 1.5rem;
    }

    .section-label {
        column-span: all;
        margin: 2rem 0 1rem;
        padding-left: 0.5rem;
        border-left: 4px solid var(--burnt-orange);
    }

    .dish-card, .restaurant-card {
        break-inside: avoid;
        margin-bottom: 1.5rem;
    }

    .dish-price {
        font-weight: 700;
        color: var(--burnt-orange);
        margin: 0.5rem 0;
    }

    .dish-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.8rem 0;
    }

    .tag {
        background: var(--bg-elevated);
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.7rem;
        color: var(--text-secondary);
    }

    .btn-tried, .btn-crave {
        background: none;
        border: 1px solid var(--burnt-orange);
        color: var(--burnt-orange);
        padding: 0.5rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        cursor: pointer;
        margin-top: 0.8rem;
        transition: var(--transition);
        width: 100%;
    }

        .btn-tried:hover, .btn-crave:hover {
            background: var(--burnt-orange);
            color: white;
        }

    @@media (max-width: 1024px) {
        .masonry-grid {
            column-count: 2;
        }
    }

    @@media (max-width: 768px) {
        .dish-of-day-container {
            grid-template-columns: 1fr;
        }

        .masonry-grid {
            column-count: 1;
        }

        .dish-of-day-content h2 {
            font-size: 2rem;
        }

        .dish-actions {
            flex-direction: column;
        }
    }
</style>

<script>
    function filterDishCategory(category) {
        var cards = document.querySelectorAll('.dish-card');
        var sections = document.querySelectorAll('.section-label');
        var buttons = document.querySelectorAll('.filter-tab');

        buttons.forEach(b => b.classList.remove('active'));
        if (event && event.target) event.target.classList.add('active');

        cards.forEach(card => {
            card.style.display = (category === 'all' || card.dataset.category === category) ? 'block' : 'none';
        });

        showToast('Showing ' + category + ' dishes');
    }

    var dishSearch = document.getElementById('dishSearch');
    if (dishSearch) {
        dishSearch.addEventListener('keyup', function () {
            var filter = this.value.toLowerCase();
            document.querySelectorAll('.dish-card').forEach(card => {
                var name = card.querySelector('h3')?.innerText.toLowerCase() ?? '';
                card.style.display = name.includes(filter) ? 'block' : 'none';
            });
        });
    }

    function triedDish(dishName, dishId) {
        showToast('You tried ' + dishName + '! Added to your food journey.');
    }

    function addToCravings(itemName, itemId, type) {
        showToast(itemName + ' added to your Cravings List!');
    }

    function showToast(message) {
        var toast = document.createElement('div');
        toast.className = 'toast-notification';
        toast.innerHTML = message;
        document.body.appendChild(toast);
        setTimeout(function () { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
    }
</script>
