@{
    ViewData["Title"] = "Dish Discovery - TasteCebu";
}

<!-- DISH OF THE DAY HERO -->
<section class="dish-of-day" style="background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);">
    <div class="dish-of-day-container">
        <div class="dish-of-day-content" data-aos="fade-right">
            <span class="dish-of-day-badge">DISH OF THE DAY</span>
            <h2>Cebu Lechon</h2>
            <p>The Philippines' most famous roasted pig - crispy skin, juicy meat, and signature spicy vinegar. A must-try when in Cebu!</p>
            <div class="dish-meta">
                <span><i class="fas fa-utensils"></i> At House of Lechon</span>
                <span><i class="fas fa-tag"></i> $450 / serving</span>
            </div>
            <div class="dish-actions">
                <button class="btn-tried" onclick="triedDish('Cebu Lechon', 1)"><i class="fas fa-check-circle"></i> I Tried This</button>
                <button class="btn-crave" onclick="addToCravings('Cebu Lechon', 1, 'dish')"><i class="fas fa-heart"></i> Add to Cravings</button>
            </div>
        </div>
        <div class="dish-of-day-image" data-aos="fade-left">
            <img src="https://images.unsplash.com/photo-1615937722923-69f6dde0c6f3?w=600&h=500&fit=crop" alt="Cebu Lechon">
        </div>
    </div>
</section>

<section class="section">
    <div class="section-header" data-aos="fade-up">
        <h2>Explore Dishes</h2>
        <p>Discover trending, classic, and hidden gem dishes around Cebu</p>
    </div>

    <!-- FILTERS -->
    <div class="filters-bar" data-aos="fade-up">
        <div class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search dishes..." id="dishSearch">
        </div>

        <div class="filter-tabs">
            <button class="filter-tab active" onclick="filterDishCategory('all')">All</button>
            <button class="filter-tab" onclick="filterDishCategory('cebu-specialty')">Cebu Specialties</button>
            <button class="filter-tab" onclick="filterDishCategory('seafood')">Seafood</button>
            <button class="filter-tab" onclick="filterDishCategory('spicy')">Spicy</button>
            <button class="filter-tab" onclick="filterDishCategory('vegetarian')">Vegetarian</button>
            <button class="filter-tab" onclick="filterDishCategory('street-food')">Street Food</button>
        </div>
    </div>

    <!-- MASONRY DISH GRID -->
    <div class="masonry-grid" id="dishesGrid">
        <!-- Cebu Specialties Section -->
        <div class="section-label" data-category="cebu-specialty">
            <h3><i class="fas fa-crown"></i> Cebu Specialties</h3>
        </div>

        <div class="dish-card" data-category="cebu-specialty" data-name="Lechon">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1615937722923-69f6dde0c6f3?w=600&h=400&fit=crop" alt="Lechon">
                <span class="card-badge">ICONIC</span>
            </div>
            <div class="card-content">
                <h3>Lechon Cebu</h3>
                <p class="card-location">at House of Lechon</p>
                <p class="dish-price">$450 - $1,200</p>
                <div class="dish-tags">
                    <span class="tag">Roasted</span>
                    <span class="tag">Crispy</span>
                    <span class="tag">Signature</span>
                </div>
                <button class="btn-tried" onclick="triedDish('Lechon Cebu', 1)">I Tried This</button>
            </div>
        </div>

        <div class="dish-card" data-category="cebu-specialty" data-name="Sutukil">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1559128010-7c1ad6e1b6a5?w=600&h=400&fit=crop" alt="Sutukil">
                <span class="card-badge">SEAFOOD</span>
            </div>
            <div class="card-content">
                <h3>Sutukil (Sugba, Tula, Kilaw)</h3>
                <p class="card-location">at STK ta Bay, Mactan</p>
                <p class="dish-price">$350 - $800</p>
                <div class="dish-tags">
                    <span class="tag">Grilled</span>
                    <span class="tag">Soup</span>
                    <span class="tag">Raw</span>
                </div>
                <button class="btn-tried" onclick="triedDish('Sutukil', 2)">I Tried This</button>
            </div>
        </div>

        <div class="dish-card" data-category="cebu-specialty" data-name="Ngohiong">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1601050690597-df0568f70950?w=600&h=400&fit=crop" alt="Ngohiong">
                <span class="card-badge">STREET FOOD</span>
            </div>
            <div class="card-content">
                <h3>Ngohiong</h3>
                <p class="card-location">at Colon Street</p>
                <p class="dish-price">$15 - $30</p>
                <div class="dish-tags">
                    <span class="tag">Street Food</span>
                    <span class="tag">Spring Roll</span>
                    <span class="tag">Savory</span>
                </div>
                <button class="btn-tried" onclick="triedDish('Ngohiong', 3)">I Tried This</button>
            </div>
        </div>

        <div class="dish-card" data-category="cebu-specialty" data-name="Puso">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1591267990532-e5bdb1b0f664?w=600&h=400&fit=crop" alt="Puso">
                <span class="card-badge">SIDES</span>
            </div>
            <div class="card-content">
                <h3>Puso (Hanging Rice)</h3>
                <p class="card-location">Available everywhere</p>
                <p class="dish-price">$5 - $10</p>
                <div class="dish-tags">
                    <span class="tag">Rice</span>
                    <span class="tag">Traditional</span>
                </div>
                <button class="btn-tried" onclick="triedDish('Puso', 4)">I Tried This</button>
            </div>
        </div>

        <!-- Seafood Dishes -->
        <div class="section-label" data-category="seafood">
            <h3><i class="fas fa-fish"></i> Fresh Seafood</h3>
        </div>

        <div class="dish-card" data-category="seafood" data-name="Kinilaw">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1615141982883-c7ad0a69fd62?w=600&h=400&fit=crop" alt="Kinilaw">
                <span class="card-badge">CEVICHE</span>
            </div>
            <div class="card-content">
                <h3>Kinilaw</h3>
                <p class="card-location">at Lantaw, Cordova</p>
                <p class="dish-price">$280 - $450</p>
                <div class="dish-tags">
                    <span class="tag">Raw</span>
                    <span class="tag">Citrus</span>
                    <span class="tag">Fresh</span>
                </div>
                <button class="btn-tried" onclick="triedDish('Kinilaw', 5)">I Tried This</button>
            </div>
        </div>

        <div class="dish-card" data-category="seafood" data-name="Grilled Scallops">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1589763472885-46dd5b282f52?w=600&h=400&fit=crop" alt="Scallops">
                <span class="card-badge">GRILLED</span>
            </div>
            <div class="card-content">
                <h3>Grilled Scallops with Kinilaw Sauce</h3>
                <p class="card-location">at STK ta Bay</p>
                <p class="dish-price">$220</p>
                <div class="dish-tags">
                    <span class="tag">Grilled</span>
                    <span class="tag">Seafood</span>
                </div>
                <button class="btn-tried" onclick="triedDish('Grilled Scallops', 6)">I Tried This</button>
            </div>
        </div>

        <!-- Trending / New Dishes -->
        <div class="section-label">
            <h3><i class="fas fa-fire"></i> Trending Now</h3>
        </div>

        <div class="dish-card" data-category="spicy" data-name="Lechon Ramen">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1591814468924-caf5d1237a2a?w=600&h=400&fit=crop" alt="Lechon Ramen">
                <span class="card-badge new-badge">VIRAL</span>
            </div>
            <div class="card-content">
                <h3>Lechon Ramen</h3>
                <p class="card-location">at Ramen Sage, Crossroads</p>
                <p class="dish-price">$390</p>
                <div class="dish-tags">
                    <span class="tag">Fusion</span>
                    <span class="tag">Spicy</span>
                </div>
                <button class="btn-tried" onclick="triedDish('Lechon Ramen', 7)">I Tried This</button>
            </div>
        </div>

        <div class="dish-card" data-category="street-food" data-name="Danggit">
            <div class="card-image">
                <img src="https://images.unsplash.com/photo-1523800503107-5bc3ba2a6f81?w=600&h=400&fit=crop" alt="Danggit">
                <span class="card-badge">BREAKFAST</span>
            </div>
            <div class="card-content">
                <h3>Danggit Lamayo</h3>
                <p class="card-location">at Any Local Eatery</p>
                <p class="dish-price">$120 - $250</p>
                <div class="dish-tags">
                    <span class="tag">Dried Fish</span>
                    <span class="tag">Breakfast</span>
                </div>
                <button class="btn-tried" onclick="triedDish('Danggit Lamayo', 8)">I Tried This</button>
            </div>
        </div>
    </div>
</section>

<style>
    .dish-of-day {
        padding: 4rem 2rem;
        min-height: 70vh;
        display: flex;
        align-items: center;
    }

    .dish-of-day-container {
        max-width: var(--container-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
    }

    .dish-of-day-badge {
        display: inline-block;
        background: rgba(231, 111, 81, 0.2);
        padding: 0.3rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        color: var(--burnt-orange);
        margin-bottom: 1rem;
    }

    .dish-of-day-content h2 {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .dish-meta {
        display: flex;
        gap: 1.5rem;
        margin: 1.5rem 0;
        color: var(--text-secondary);
    }

        .dish-meta i {
            color: var(--burnt-orange);
            margin-right: 5px;
        }

    .dish-of-day-image img {
        width: 100%;
        border-radius: 30px;
        box-shadow: var(--shadow-lg);
    }

    .dish-actions {
        display: flex;
        gap: 1rem;
    }

    .masonry-grid {
        column-count: 3;
        column-gap: 1.5rem;
    }

    .section-label {
        column-span: all;
        margin: 2rem 0 1rem;
        padding-left: 0.5rem;
        border-left: 4px solid var(--burnt-orange);
    }

    .dish-card, .restaurant-card {
        break-inside: avoid;
        margin-bottom: 1.5rem;
    }

    .dish-price {
        font-weight: 700;
        color: var(--burnt-orange);
        margin: 0.5rem 0;
    }

    .dish-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.8rem 0;
    }

    .tag {
        background: var(--bg-elevated);
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.7rem;
        color: var(--text-secondary);
    }

    .btn-tried {
        background: none;
        border: 1px solid var(--burnt-orange);
        color: var(--burnt-orange);
        padding: 0.5rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        cursor: pointer;
        margin-top: 0.8rem;
        transition: var(--transition);
        width: 100%;
    }

        .btn-tried:hover {
            background: var(--burnt-orange);
            color: white;
        }

    .btn-crave {
        background: none;
        border: 1px solid var(--burnt-orange);
        color: var(--burnt-orange);
        padding: 0.5rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        cursor: pointer;
        margin-top: 0.8rem;
        transition: var(--transition);
        width: 100%;
    }

        .btn-crave:hover {
            background: var(--burnt-orange);
            color: white;
        }
</style>

<style>
    @@media (max-width: 1024px) {
        .masonry-grid {
            column-count: 2;
        }
    }
</style>

<style>
    @@media (max-width: 768px) {
        .dish-of-day-container {
            grid-template-columns: 1fr;
        }

        .masonry-grid {
            column-count: 1;
        }

        .dish-of-day-content h2 {
            font-size: 2rem;
        }

        .dish-actions {
            flex-direction: column;
        }
    }
</style>

<script>
    function filterDishCategory(category) {
        var cards = document.querySelectorAll('.dish-card');
        var sections = document.querySelectorAll('.section-label');
        var buttons = document.querySelectorAll('.filter-tab');

        for (var i = 0; i < buttons.length; i++) {
            buttons[i].classList.remove('active');
        }

        if (event && event.target) {
            event.target.classList.add('active');
        }

        for (var i = 0; i < cards.length; i++) {
            if (category === 'all' || cards[i].dataset.category === category) {
                cards[i].style.display = 'block';
            } else {
                cards[i].style.display = 'none';
            }
        }

        for (var i = 0; i < sections.length; i++) {
            if (category === 'all') {
                sections[i].style.display = 'block';
            } else if (sections[i].dataset.category === category) {
                sections[i].style.display = 'block';
            } else if (!sections[i].dataset.category) {
                sections[i].style.display = 'block';
            } else {
                sections[i].style.display = 'none';
            }
        }

        var categoryText = category;
        if (category === 'cebu-specialty') {
            categoryText = 'Cebu Specialty';
        } else if (category === 'street-food') {
            categoryText = 'Street Food';
        }
        showToast('Showing ' + categoryText + ' dishes');
    }

    var dishSearch = document.getElementById('dishSearch');
    if (dishSearch) {
        dishSearch.addEventListener('keyup', function() {
            var filter = this.value.toLowerCase();
            var cards = document.querySelectorAll('.dish-card');

            for (var i = 0; i < cards.length; i++) {
                var nameElement = cards[i].querySelector('h3');
                var locationElement = cards[i].querySelector('.card-location');

                var name = nameElement ? nameElement.innerText.toLowerCase() : '';
                var restaurant = locationElement ? locationElement.innerText.toLowerCase() : '';

                if (name.indexOf(filter) !== -1 || restaurant.indexOf(filter) !== -1) {
                    cards[i].style.display = 'block';
                } else {
                    cards[i].style.display = 'none';
                }
            }
        });
    }

    function triedDish(dishName, dishId) {
        showToast('You tried ' + dishName + '! Added to your food journey.');
    }

    function addToCravings(itemName, itemId, type) {
        showToast(itemName + ' added to your Cravings List!');
    }

    function showToast(message) {
        var toast = document.createElement('div');
        toast.className = 'toast-notification';
        toast.innerHTML = message;
        document.body.appendChild(toast);

        setTimeout(function() {
            toast.style.opacity = '0';
            setTimeout(function() {
                toast.remove();
            }, 300);
        }, 3000);
    }
</script>