@{
    ViewData["Title"] = "Event Details - TasteCebu";
}

<section class="detail-shell">
    <nav class="breadcrumb-trail">
        <a href="/">Home</a><span>/</span><a href="/Events">Events</a><span>/</span><strong id="eventCrumb">Event</strong>
    </nav>

    <div class="detail-hero-card">
        <img id="eventImage" src="https://images.unsplash.com/photo-1556910104-525b138803e9?w=1000&h=650&fit=crop" alt="Event">
        <div class="detail-hero-copy">
            <span class="detail-kicker">Upcoming Event</span>
            <h1 id="eventTitle">Lechon Masterclass at Carbon</h1>
            <p id="eventDescription">Learn Cebu lechon prep, roasting, carving, and pairing from local cooks.</p>
            <div class="detail-meta">
                <span><i class="far fa-calendar"></i> <span id="eventDate">June 15, 2026</span></span>
                <span><i class="fas fa-map-marker-alt"></i> <span id="eventLocation">Carbon Market</span></span>
                <span><i class="fas fa-chair"></i> <span id="eventSeats">15 seats left</span></span>
            </div>
            <div class="countdown-timer" id="detailCountdown"></div>
            <button class="btn-primary" onclick="registerForDetailEvent()"><i class="fas fa-ticket-alt"></i> Register for Event</button>
        </div>
    </div>

    <div class="detail-panel event-registrants">
        <h2>Registered Users</h2>
        <p class="muted-text">Frontend demo list for admin presentation.</p>
        <div class="registrant-list">
            <span>Maria Santos</span><span>Juan Dela Cruz</span><span>Ana Lim</span><span>Carlos Tan</span>
        </div>
    </div>
</section>

<style>
    .detail-shell { max-width: var(--container-width); margin: 0 auto; padding: 2rem; }
    .breadcrumb-trail { display: flex; gap: 0.5rem; flex-wrap: wrap; color: var(--text-secondary); margin-bottom: 1rem; }
    .breadcrumb-trail a { color: var(--burnt-orange); text-decoration: none; }
    .detail-hero-card { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center; background: var(--bg-card); border-radius: 20px; padding: 1.5rem; }
    .detail-hero-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 16px; }
    .detail-kicker { color: var(--burnt-orange); font-weight: 700; text-transform: uppercase; font-size: 0.8rem; }
    .detail-hero-copy h1 { font-size: 2.6rem; margin: 0.5rem 0; }
    .detail-meta { display: flex; flex-wrap: wrap; gap: 1rem; margin: 1.2rem 0; color: var(--text-secondary); }
    .detail-panel { background: var(--bg-card); border-radius: 16px; padding: 1.5rem; margin-top: 1.5rem; }
    .muted-text { color: var(--text-secondary); }
    .registrant-list { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 1rem; }
    .registrant-list span { background: var(--bg-elevated); border-radius: 30px; padding: 0.5rem 1rem; }
    @@media (max-width: 768px) { .detail-hero-card { grid-template-columns: 1fr; } .detail-hero-copy h1 { font-size: 2rem; } }
</style>

<script>
    var events = [
        { title: 'Lechon Masterclass at Carbon', date: 'June 15, 2026', iso: '2026-06-15T09:00:00', location: 'Carbon Market, Cebu City', seats: '15 seats left', description: 'Learn Cebu lechon prep, roasting, carving, and pairing from local cooks.', image: 'https://images.unsplash.com/photo-1556910104-525b138803e9?w=1000&h=650&fit=crop' },
        { title: 'Cebu Street Food Crawl', date: 'June 22, 2026', iso: '2026-06-22T18:00:00', location: 'Colon Street and Carbon', seats: '32 spots left', description: 'Explore Cebu street food with guided tastings and vendor stories.', image: 'https://images.unsplash.com/photo-1590577976322-3d2d6e2130d5?w=1000&h=650&fit=crop' },
        { title: 'Coffee Cupping and Latte Art Workshop', date: 'June 30, 2026', iso: '2026-06-30T14:00:00', location: 'Current Coffee Roasters, Mandaue', seats: '20 spots left', description: 'Practice espresso tasting, milk texturing, and basic latte art.', image: 'https://images.unsplash.com/photo-1534087298023-017580581d8d?w=1000&h=650&fit=crop' }
    ];
    var eventIndex = Math.max(0, Math.min(events.length - 1, (@ViewData["ItemId"] ?? 1) - 1));
    var detailEvent = events[eventIndex];
    document.getElementById('eventTitle').innerText = detailEvent.title;
    document.getElementById('eventCrumb').innerText = detailEvent.title;
    document.getElementById('eventDate').innerText = detailEvent.date;
    document.getElementById('eventLocation').innerText = detailEvent.location;
    document.getElementById('eventSeats').innerText = detailEvent.seats;
    document.getElementById('eventDescription').innerText = detailEvent.description;
    document.getElementById('eventImage').src = detailEvent.image;
    function registerForDetailEvent() { if (window.registerForEvent) { window.registerForEvent(eventIndex + 1); } }
    if (window.TasteCebu && window.TasteCebu.startCountdown) { window.TasteCebu.startCountdown(new Date(detailEvent.iso).getTime(), 'detailCountdown'); }
</script>
