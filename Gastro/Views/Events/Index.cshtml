@{
    ViewData["Title"] = "Events and Masterclasses - TasteCebu";
    var events = ViewData["DatabaseEvents"] as List<GastroCebu.Models.FoodEvent> ?? new();
    var nextEvent = events.Where(e => e.Date >= DateTime.UtcNow).OrderBy(e => e.Date).FirstOrDefault();
}

<!-- HERO SECTION WITH COUNTDOWN -->
<section class="events-hero">
    <div class="events-hero-content" data-aos="fade-up">
        <h1>Upcoming Culinary Events</h1>
        <p>Masterclasses, food festivals, and food crawls in Cebu</p>
        @if (nextEvent != null)
        {
            <div class="next-event-countdown">
                <span>Next event in:</span>
                <div class="countdown-timer" id="countdownTimer"
                     data-target="@nextEvent.Date.ToString("yyyy-MM-ddTHH:mm:ss")Z"></div>
            </div>
        }
    </div>
</section>

<section class="section">
    <!-- VIEW TOGGLE -->
    <div class="view-toggle" data-aos="fade-up">
        <button class="view-btn active" onclick="toggleView('grid')"><i class="fas fa-th-large"></i> Grid View</button>
        <button class="view-btn" onclick="toggleView('calendar')"><i class="fas fa-calendar-alt"></i> Calendar View</button>
    </div>

    <!-- GRID VIEW -->
    <div id="gridView" class="card-grid">
        @if (!events.Any())
        {
            <div class="empty-state" style="grid-column: 1/-1;">
                <div class="empty-state-icon">📅</div>
                <h3>No events scheduled yet</h3>
                <p>The admin hasn't posted any events or masterclasses yet. Check back soon!</p>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Dashboard" class="btn-primary">Add an Event →</a>
                }
            </div>
        }
        else
        {
            @foreach (var foodEvent in events.OrderBy(e => e.Date))
            {
                <div class="event-card" data-date="@foodEvent.Date.ToString("yyyy-MM-dd")" data-aos="fade-up"
                     onclick="location.href='/Events/Detail/@foodEvent.Id'">
                    <div class="card-image">
                        <img src="@foodEvent.PhotoUrl" alt="@foodEvent.Title">
                        <div class="date-badge">
                            <span class="date-month">@foodEvent.Date.ToString("MMM").ToUpperInvariant()</span>
                            <span class="date-day">@foodEvent.Date.Day</span>
                        </div>
                    </div>
                    <div class="card-content">
                        <h3>@foodEvent.Title</h3>
                        <p class="card-location"><i class="fas fa-map-marker-alt"></i> @foodEvent.Location</p>
                        <p class="event-time"><i class="far fa-clock"></i> @foodEvent.Date.ToString("h:mm tt")</p>
                        <p>@foodEvent.Description</p>
                        <div class="seats-info">
                            <div class="progress-bar"><div class="progress" style="width: 45%"></div></div>
                            <p>@foodEvent.AvailableSlots seats available</p>
                        </div>
                        <button class="btn-register" onclick="event.stopPropagation(); registerEvent(@foodEvent.Id)">Register Now →</button>
                    </div>
                </div>
            }
        }
    </div>

    <!-- CALENDAR VIEW (hidden by default) -->
    <div id="calendarView" class="calendar-view" style="display: none;">
        <div class="calendar-header">
            <button class="calendar-nav" onclick="changeMonth(-1)"><i class="fas fa-chevron-left"></i></button>
            <h3 id="currentMonthYear"></h3>
            <button class="calendar-nav" onclick="changeMonth(1)"><i class="fas fa-chevron-right"></i></button>
        </div>
        <div class="calendar-grid" id="calendarGrid"></div>
    </div>

    @if (events.Any())
    {
        <!-- PAST EVENTS GALLERY -->
        <div class="past-events" data-aos="fade-up">
            <div class="section-header">
                <h2>Past Events Gallery</h2>
                <p>Relive the flavors from our previous gatherings</p>
            </div>
            <div class="gallery-grid">
                @foreach (var pastEvent in events.Where(e => e.Date < DateTime.UtcNow).Take(6))
                {
                    <div class="gallery-item">
                        <img src="@pastEvent.PhotoUrl" alt="@pastEvent.Title">
                    </div>
                }
                @if (!events.Any(e => e.Date < DateTime.UtcNow))
                {
                    <p style="color: var(--text-secondary); padding: 1rem;">No past events yet.</p>
                }
            </div>
        </div>
    }
</section>

<style>
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--text-secondary);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        margin-bottom: 1.5rem;
    }

    .events-hero {
        background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1511795409674-a7fcf7b6bde4?q=80&w=2070&auto=format');
        background-size: cover;
        background-position: center;
        padding: 4rem 2rem;
        text-align: center;
        color: white;
    }

    .events-hero-content h1 {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .next-event-countdown {
        margin-top: 2rem;
        font-size: 1.2rem;
    }

    .countdown-timer {
        font-size: 2rem;
        font-weight: 700;
        color: var(--burnt-orange);
        margin-top: 0.5rem;
    }

    .view-toggle {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .view-btn {
        background: var(--bg-elevated);
        border: none;
        padding: 0.5rem 1.5rem;
        border-radius: 30px;
        color: var(--text-primary);
        cursor: pointer;
        transition: var(--transition);
    }

        .view-btn.active {
            background: var(--gradient-warm);
        }

    .date-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: var(--bg-dark);
        border-radius: 12px;
        text-align: center;
        padding: 0.3rem 0.6rem;
        min-width: 50px;
    }

    .date-month {
        display: block;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--burnt-orange);
        text-transform: uppercase;
    }

    .date-day {
        display: block;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .event-time {
        color: var(--text-secondary);
        font-size: 0.85rem;
        margin: 0.3rem 0;
    }

    .btn-register {
        background: var(--gradient-warm);
        color: white;
        border: none;
        padding: 0.7rem 1.2rem;
        border-radius: 30px;
        width: 100%;
        margin-top: 1rem;
        cursor: pointer;
        font-weight: 600;
        transition: var(--transition);
    }

        .btn-register:hover {
            transform: translateY(-2px);
        }

    .calendar-view {
        background: var(--bg-card);
        border-radius: 24px;
        padding: 2rem;
    }

    .calendar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .calendar-nav {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: var(--text-primary);
        cursor: pointer;
        padding: 0.5rem;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 0.5rem;
        text-align: center;
    }

    .calendar-day-header {
        font-weight: 600;
        padding: 0.5rem;
        color: var(--burnt-orange);
    }

    .calendar-date {
        padding: 1rem;
        border-radius: 12px;
        cursor: pointer;
        transition: var(--transition);
    }

        .calendar-date:hover, .calendar-date.has-event {
            background: var(--burnt-orange);
            color: white;
        }

    .past-events {
        margin-top: 4rem;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
        margin-top: 2rem;
    }

    .gallery-item {
        border-radius: 16px;
        overflow: hidden;
        transition: var(--transition);
    }

        .gallery-item:hover {
            transform: scale(1.05);
        }

        .gallery-item img {
            width: 100%;
            height: 150px;
            object-fit: cover;
        }

    .progress-bar {
        background: var(--bg-elevated);
        border-radius: 10px;
        height: 6px;
        margin: 0.8rem 0 0.5rem;
        overflow: hidden;
    }

    .progress {
        background: var(--gradient-warm);
        height: 100%;
        border-radius: 10px;
    }

    .seats-info p {
        font-size: 0.75rem;
        color: var(--text-secondary);
    }

    @@media (max-width: 768px) {
        .events-hero-content h1 {
            font-size: 2rem;
        }

        .countdown-timer {
            font-size: 1.5rem;
        }

        .calendar-date {
            padding: 0.5rem;
        }
    }
</style>

<script>
    // Dynamic countdown from the next event's date
    (function () {
        var el = document.getElementById('countdownTimer');
        if (!el) return;
        var target = new Date(el.dataset.target).getTime();

        function update() {
            var dist = target - Date.now();
            if (dist < 0) { el.innerHTML = "Event Started!"; return; }
            var d = Math.floor(dist / 86400000);
            var h = Math.floor((dist % 86400000) / 3600000);
            var m = Math.floor((dist % 3600000) / 60000);
            var s = Math.floor((dist % 60000) / 1000);
            el.innerHTML = d + "d " + h + "h " + m + "m " + s + "s";
        }
        update();
        setInterval(update, 1000);
    })();

    var currentMonth = new Date().getMonth();
    var currentYear = new Date().getFullYear();

    function toggleView(view) {
        document.getElementById('gridView').style.display = view === 'grid' ? 'grid' : 'none';
        document.getElementById('calendarView').style.display = view === 'grid' ? 'none' : 'block';
        document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
        if (event && event.target) event.target.closest('.view-btn').classList.add('active');
        if (view === 'calendar') renderCalendar();
    }

    function renderCalendar() {
        var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
        document.getElementById('currentMonthYear').innerText = monthNames[currentMonth] + ' ' + currentYear;

        var firstDay = new Date(currentYear, currentMonth, 1).getDay();
        var totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();

        // collect event dates from rendered cards
        var eventDates = Array.from(document.querySelectorAll('.event-card[data-date]'))
            .map(c => new Date(c.dataset.date))
            .filter(d => d.getFullYear() === currentYear && d.getMonth() === currentMonth)
            .map(d => d.getDate());

        var html = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d => '<div class="calendar-day-header">' + d + '</div>').join('');
        for (var i = 0; i < firstDay; i++) html += '<div class="calendar-date"></div>';
        for (var date = 1; date <= totalDays; date++) {
            var cls = eventDates.includes(date) ? 'has-event' : '';
            html += '<div class="calendar-date ' + cls + '" onclick="showEventForDate(' + date + ')">' + date + '</div>';
        }
        document.getElementById('calendarGrid').innerHTML = html;
    }

    function changeMonth(delta) {
        currentMonth += delta;
        if (currentMonth < 0) { currentMonth = 11; currentYear--; }
        else if (currentMonth > 11) { currentMonth = 0; currentYear++; }
        renderCalendar();
    }

    function showEventForDate(date) {
        showToast('Check grid view for events on day ' + date);
    }

    function registerEvent(eventId) {
        if (window.registerForEvent) window.registerForEvent(eventId);
    }

    function showToast(message) {
        var toast = document.createElement('div');
        toast.className = 'toast-notification';
        toast.innerHTML = message;
        document.body.appendChild(toast);
        setTimeout(function () { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
    }
</script>
