@{
    ViewData["Title"] = "Events and Masterclasses - TasteCebu";
    var events = ViewData["DatabaseEvents"] as List<GastroCebu.Models.FoodEvent> ?? new();
    var upcomingEvents = events.Where(e => e.Date >= DateTime.UtcNow).OrderBy(e => e.Date).ToList();
    var pastEvents = events.Where(e => e.Date < DateTime.UtcNow).OrderByDescending(e => e.Date).ToList();
    var nextEvent = upcomingEvents.FirstOrDefault();
    var isAuth = User.Identity?.IsAuthenticated == true;
}

<!-- HERO SECTION WITH COUNTDOWN -->
<section class="events-hero">
    <div class="events-hero-content" data-aos="fade-up">
        <h1>Upcoming Culinary Events</h1>
        <p>Masterclasses, food festivals, and food crawls in Cebu</p>
        @if (nextEvent != null)
        {
            <div class="next-event-countdown">
                <span>Next event in:</span>
                <div class="countdown-timer" id="countdownTimer"
                     data-target="@nextEvent.Date.ToString("yyyy-MM-ddTHH:mm:ss")Z"></div>
            </div>
        }
    </div>
</section>

<section class="section">
    <!-- VIEW TOGGLE -->
    <div class="view-toggle" data-aos="fade-up">
        <button class="view-btn active" onclick="toggleView('grid', this)"><i class="fas fa-th-large"></i> Grid View</button>
        <button class="view-btn" onclick="toggleView('calendar', this)"><i class="fas fa-calendar-alt"></i> Calendar View</button>
    </div>

    <!-- GRID VIEW -->
    <div id="gridView" class="events-grid">
        @if (!upcomingEvents.Any())
        {
            <div class="empty-state" style="grid-column: 1/-1;">
                <div class="empty-state-icon">📅</div>
                <h3>No events scheduled yet</h3>
                <p>The admin hasn't posted any events or masterclasses yet. Check back soon!</p>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Dashboard" class="btn-primary">Add an Event →</a>
                }
            </div>
        }
        else
        {
            @foreach (var foodEvent in upcomingEvents)
            {
                var fillPct = foodEvent.TotalSlots > 0
                    ? (int)(((double)(foodEvent.TotalSlots - foodEvent.AvailableSlots) / foodEvent.TotalSlots) * 100)
                    : 0;
                var spotsLow = foodEvent.AvailableSlots <= 5;
                <div class="event-card" data-date="@foodEvent.Date.ToString("yyyy-MM-dd")" data-aos="fade-up"
                     onclick="location.href='/Events/Detail/@foodEvent.Id'">
                    <div class="card-image">
                        @if (!string.IsNullOrWhiteSpace(foodEvent.PhotoUrl))
                        {
                            <img src="@foodEvent.PhotoUrl" alt="@foodEvent.Title"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                            <div class="card-img-fallback" style="display:none">
                                <i class="fas fa-calendar-star"></i>
                                <span>@foodEvent.Title</span>
                            </div>
                        }
                        else
                        {
                            <div class="card-img-fallback">
                                <i class="fas fa-calendar-star"></i>
                                <span>@foodEvent.Title</span>
                            </div>
                        }
                        <div class="date-badge">
                            <span class="date-month">@foodEvent.Date.ToLocalTime().ToString("MMM").ToUpperInvariant()</span>
                            <span class="date-day">@foodEvent.Date.ToLocalTime().Day</span>
                        </div>
                        @if (spotsLow && foodEvent.AvailableSlots > 0)
                        {
                            <span class="card-badge badge-urgent">Almost Full</span>
                        }
                        else if (foodEvent.AvailableSlots == 0)
                        {
                            <span class="card-badge badge-full">Full</span>
                        }
                    </div>
                    <div class="card-content">
                        <h3>@foodEvent.Title</h3>
                        <p class="card-location"><i class="fas fa-map-marker-alt"></i> @foodEvent.Location</p>
                        <p class="event-time"><i class="far fa-clock"></i> @foodEvent.Date.ToLocalTime().ToString("h:mm tt · MMMM d, yyyy")</p>
                        <p class="event-desc">@foodEvent.Description</p>
                        <div class="seats-info">
                            <div class="progress-bar">
                                <div class="progress @(spotsLow ? "progress-warn" : "")" style="width: @fillPct%"></div>
                            </div>
                            <p class="@(spotsLow ? "seats-low" : "")">
                                @if (foodEvent.AvailableSlots == 0)
                                {
                                    <text>No seats left</text>
                                }
                                else
                                {
                                    <text>@foodEvent.AvailableSlots @(foodEvent.AvailableSlots == 1 ? "seat" : "seats") available</text>
                                }
                            </p>
                        </div>
                        @if (isAuth)
                        {
                            <button class="btn-register @(foodEvent.AvailableSlots == 0 ? "btn-register--full" : "")"
                                    onclick="event.stopPropagation(); registerEvent(@foodEvent.Id)"
                                @(foodEvent.AvailableSlots == 0 ? "disabled" : "")>
                                @(foodEvent.AvailableSlots == 0 ? "Fully Booked" : "Register Now →")
                            </button>
                        }
                        else
                        {
                            <a class="btn-register btn-register--guest" href="/Account/Login?returnUrl=/Events" onclick="event.stopPropagation()">
                                <i class="fas fa-lock"></i> Sign in to Register
                            </a>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <!-- CALENDAR VIEW (hidden by default) -->
    <div id="calendarView" class="calendar-view" style="display: none;">
        <div class="calendar-header">
            <button class="calendar-nav" onclick="changeMonth(-1)"><i class="fas fa-chevron-left"></i></button>
            <h3 id="currentMonthYear"></h3>
            <button class="calendar-nav" onclick="changeMonth(1)"><i class="fas fa-chevron-right"></i></button>
        </div>
        <div class="calendar-grid" id="calendarGrid"></div>
    </div>

    <!-- PAST EVENTS GALLERY -->
    <div class="past-events" data-aos="fade-up">
        <div class="section-header" style="text-align:center; margin-bottom:2rem;">
            <h2>Past Events Gallery</h2>
            <p>Relive the flavors from our previous gatherings</p>
        </div>
        @if (pastEvents.Any())
        {
            <div class="gallery-grid">
                @foreach (var pastEvent in pastEvents.Take(6))
                {
                    <div class="gallery-item" onclick="location.href='/Events/Detail/@pastEvent.Id'" title="@pastEvent.Title">
                        @if (!string.IsNullOrWhiteSpace(pastEvent.PhotoUrl))
                        {
                            <img src="@pastEvent.PhotoUrl" alt="@pastEvent.Title"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                            <div class="gallery-fallback" style="display:none">
                                <i class="fas fa-images"></i>
                            </div>
                        }
                        else
                        {
                            <div class="gallery-fallback">
                                <i class="fas fa-images"></i>
                            </div>
                        }
                        <div class="gallery-overlay">
                            <span>@pastEvent.Title</span>
                            <small>@pastEvent.Date.ToLocalTime().ToString("MMMM d, yyyy")</small>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="past-empty-state">
                <i class="fas fa-photo-video"></i>
                <p>No past events yet — photos from completed events will appear here.</p>
            </div>
        }
    </div>
</section>

<style>
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--text-secondary);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        margin-bottom: 1.5rem;
    }

    /* Hero */
    .events-hero {
        background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.75)), url('/images/culinary.jpg') center/cover no-repeat;
        padding: 5rem 2rem;
        text-align: center;
        color: white;
    }

    .events-hero-content h1 {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .events-hero-content p {
        font-size: 1.1rem;
        opacity: 0.85;
    }

    .next-event-countdown {
        margin-top: 2rem;
        font-size: 1.1rem;
    }

    .countdown-timer {
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--burnt-orange);
        margin-top: 0.4rem;
        letter-spacing: 0.02em;
    }

    /* View toggle */
    .view-toggle {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .view-btn {
        background: var(--bg-elevated);
        border: none;
        padding: 0.55rem 1.5rem;
        border-radius: 30px;
        color: var(--text-primary);
        cursor: pointer;
        transition: var(--transition);
        font-size: 0.92rem;
        font-weight: 500;
    }

        .view-btn.active {
            background: var(--gradient-warm);
            color: white;
        }

    /* Events grid — always 3 columns, wraps on smaller screens */
    .events-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-bottom: 3rem;
    }

    /* Card image fallback */
    .card-img-fallback {
        width: 100%;
        height: 100%;
        background: var(--bg-elevated);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        color: var(--text-muted);
        font-size: 2rem;
        padding: 1rem;
        text-align: center;
    }

        .card-img-fallback span {
            font-size: 0.85rem;
            color: var(--text-secondary);
            line-height: 1.3;
        }

    /* Badges */
    .badge-urgent {
        background: rgba(231, 76, 60, 0.85) !important;
        color: white !important;
    }

    .badge-full {
        background: rgba(100,100,100,0.85) !important;
        color: white !important;
    }

    /* Date badge */
    .date-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: white;
        color: #111;
        border-radius: 12px;
        text-align: center;
        padding: 0.3rem 0.7rem;
        min-width: 52px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.18);
    }

    .date-month {
        display: block;
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--burnt-orange);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .date-day {
        display: block;
        font-size: 1.3rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .event-time {
        color: var(--text-secondary);
        font-size: 0.82rem;
        margin: 0.3rem 0 0.6rem;
    }

    .event-desc {
        font-size: 0.88rem;
        color: var(--text-secondary);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Progress bar */
    .progress-bar {
        background: var(--bg-elevated);
        border-radius: 10px;
        height: 6px;
        margin: 0.8rem 0 0.4rem;
        overflow: hidden;
    }

    .progress {
        background: var(--gradient-warm);
        height: 100%;
        border-radius: 10px;
        transition: width 0.5s ease;
    }

    .progress-warn {
        background: linear-gradient(90deg, #e74c3c, #c0392b);
    }

    .seats-info p {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-bottom: 0;
    }

    .seats-low {
        color: #e74c3c !important;
        font-weight: 600;
    }

    /* Register button */
    .btn-register {
        background: var(--gradient-warm);
        color: white;
        border: none;
        padding: 0.7rem 1.2rem;
        border-radius: 30px;
        width: 100%;
        margin-top: 1rem;
        cursor: pointer;
        font-weight: 600;
        transition: var(--transition);
        display: block;
        text-align: center;
    }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .btn-register--full {
        background: var(--bg-elevated) !important;
        color: var(--text-secondary) !important;
        cursor: not-allowed;
    }

    .btn-register--guest {
        display: block;
        text-align: center;
        text-decoration: none;
        background: transparent;
        border: 2px solid var(--burnt-orange);
        color: var(--burnt-orange);
    }

        .btn-register--guest:hover {
            background: var(--burnt-orange);
            color: white;
            transform: translateY(-2px);
        }

    /* Calendar */
    .calendar-view {
        background: var(--bg-card);
        border-radius: 24px;
        padding: 2rem;
        margin-bottom: 3rem;
    }

    .calendar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .calendar-nav {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: var(--text-primary);
        cursor: pointer;
        padding: 0.5rem;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 0.5rem;
        text-align: center;
    }

    .calendar-day-header {
        font-weight: 600;
        padding: 0.5rem;
        color: var(--burnt-orange);
        font-size: 0.85rem;
    }

    .calendar-date {
        padding: 0.8rem;
        border-radius: 12px;
        cursor: pointer;
        transition: var(--transition);
        font-size: 0.9rem;
    }

        .calendar-date:hover {
            background: var(--bg-elevated);
        }

        .calendar-date.has-event {
            background: var(--burnt-orange);
            color: white;
            font-weight: 700;
        }

    /* Past events gallery */
    .past-events {
        margin-top: 4rem;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .gallery-item {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        cursor: pointer;
        aspect-ratio: 4/3;
        background: var(--bg-elevated);
    }

        .gallery-item:hover .gallery-overlay {
            opacity: 1;
        }

        .gallery-item:hover img {
            transform: scale(1.06);
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
            display: block;
        }

    .gallery-fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: var(--text-muted);
    }

    .gallery-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(transparent 40%, rgba(0,0,0,0.75));
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1rem;
        opacity: 0;
        transition: opacity 0.3s;
        color: white;
    }

        .gallery-overlay span {
            font-weight: 600;
            font-size: 0.9rem;
            line-height: 1.3;
        }

        .gallery-overlay small {
            font-size: 0.75rem;
            opacity: 0.8;
            margin-top: 0.2rem;
        }

    .past-empty-state {
        text-align: center;
        padding: 3rem;
        background: var(--bg-card);
        border-radius: 20px;
        color: var(--text-secondary);
    }

        .past-empty-state i {
            font-size: 3rem;
            opacity: 0.25;
            display: block;
            margin-bottom: 1rem;
        }

    @@media (max-width: 1024px) {
        .events-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .gallery-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .events-hero-content h1 {
            font-size: 2rem;
        }

        .countdown-timer {
            font-size: 1.5rem;
        }

        .events-grid {
            grid-template-columns: 1fr;
        }

        .gallery-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .calendar-date {
            padding: 0.5rem;
        }
    }
</style>

<script>
    (function () {
        var el = document.getElementById('countdownTimer');
        if (!el) return;
        var target = new Date(el.dataset.target).getTime();
        function update() {
            var dist = target - Date.now();
            if (dist < 0) { el.innerHTML = "Event Started!"; return; }
            var d = Math.floor(dist / 86400000);
            var h = Math.floor((dist % 86400000) / 3600000);
            var m = Math.floor((dist % 3600000) / 60000);
            var s = Math.floor((dist % 60000) / 1000);
            el.innerHTML = d + "d " + h + "h " + m + "m " + s + "s";
        }
        update();
        setInterval(update, 1000);
    })();

    var currentMonth = new Date().getMonth();
    var currentYear = new Date().getFullYear();

    function toggleView(view, btn) {
        document.getElementById('gridView').style.display = view === 'grid' ? 'grid' : 'none';
        document.getElementById('calendarView').style.display = view === 'grid' ? 'none' : 'block';
        document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        if (view === 'calendar') renderCalendar();
    }

    function renderCalendar() {
        var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
        document.getElementById('currentMonthYear').innerText = monthNames[currentMonth] + ' ' + currentYear;
        var firstDay = new Date(currentYear, currentMonth, 1).getDay();
        var totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();
        var eventDates = Array.from(document.querySelectorAll('.event-card[data-date]'))
            .map(c => new Date(c.dataset.date))
            .filter(d => d.getFullYear() === currentYear && d.getMonth() === currentMonth)
            .map(d => d.getDate());
        var html = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d => '<div class="calendar-day-header">' + d + '</div>').join('');
        for (var i = 0; i < firstDay; i++) html += '<div class="calendar-date"></div>';
        for (var date = 1; date <= totalDays; date++) {
            var cls = eventDates.includes(date) ? 'has-event' : '';
            html += '<div class="calendar-date ' + cls + '" onclick="showEventForDate(' + date + ')">' + date + '</div>';
        }
        document.getElementById('calendarGrid').innerHTML = html;
    }

    function changeMonth(delta) {
        currentMonth += delta;
        if (currentMonth < 0) { currentMonth = 11; currentYear--; }
        else if (currentMonth > 11) { currentMonth = 0; currentYear++; }
        renderCalendar();
    }

    function showEventForDate(date) {
        showToast('Check grid view for events on day ' + date);
    }

    async function registerEvent(eventId, btn) {
        btn.disabled = true;
        btn.textContent = 'Registering...';
        try {
            var res = await fetch('/api/events/' + eventId + '/register', { method: 'POST' });
            var data = await res.json();
            if (res.ok) {
                showToast(data.message || 'Registered successfully!');
                btn.className = btn.className.replace('btn-register', 'btn-register btn-register--registered');
                btn.innerHTML = '<i class="fas fa-check-circle"></i> Registered — Cancel';
                btn.disabled = false;
                btn.onclick = function(e) { e.stopPropagation(); cancelEvent(eventId, btn); };
                // update seat count
                var card = btn.closest('.event-card');
                if (card) {
                    var seatsEl = card.querySelector('.seats-info p');
                    if (seatsEl && !seatsEl.classList.contains('seats-low')) {
                        var match = seatsEl.textContent.match(/(\d+)/);
                        if (match) {
                            var n = parseInt(match[1]) - 1;
                            seatsEl.textContent = n + (n === 1 ? ' seat available' : ' seats available');
                        }
                    }
                }
            } else {
                showToast(data.message || 'Could not register.');
                btn.disabled = false;
                btn.textContent = 'Register Now →';
            }
        } catch (e) {
            showToast('Network error. Please try again.');
            btn.disabled = false;
            btn.textContent = 'Register Now →';
        }
    }

    async function cancelEvent(eventId, btn) {
        btn.disabled = true;
        btn.textContent = 'Cancelling...';
        try {
            var res = await fetch('/api/events/' + eventId + '/register', { method: 'DELETE' });
            var data = await res.json();
            if (res.ok) {
                showToast('Registration cancelled.');
                btn.className = btn.className.replace('btn-register--registered', '').trim();
                btn.innerHTML = 'Register Now →';
                btn.disabled = false;
                btn.onclick = function(e) { e.stopPropagation(); registerEvent(eventId, btn); };
                var card = btn.closest('.event-card');
                if (card) {
                    var seatsEl = card.querySelector('.seats-info p');
                    if (seatsEl) {
                        var match = seatsEl.textContent.match(/(\d+)/);
                        if (match) {
                            var n = parseInt(match[1]) + 1;
                            seatsEl.textContent = n + (n === 1 ? ' seat available' : ' seats available');
                        }
                    }
                }
            } else {
                showToast(data.message || 'Could not cancel.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check-circle"></i> Registered — Cancel';
            }
        } catch (e) {
            showToast('Network error. Please try again.');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check-circle"></i> Registered — Cancel';
        }
    }

    function showToast(message) {
        var toast = document.createElement('div');
        toast.className = 'toast-notification';
        toast.innerHTML = message;
        document.body.appendChild(toast);
        setTimeout(function () { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
    }
</script>
