</style>

<script>
    function toggleUserEdit(userId) {
        const row = document.getElementById('userEditRow-' + userId);
        if (row) row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
    }

    function showAdminPanel(panel) {
        var panels = ['restaurants', 'dishes', 'events', 'users', 'reviews'];
        var buttons = document.querySelectorAll('.admin-nav-btn');
        for (var i = 0; i < panels.length; i++) {
            var el = document.getElementById(panels[i] + 'Panel');
            if (el) el.classList.remove('active');
        }
        var active = document.getElementById(panel + 'Panel');
        if (active) active.classList.add('active');
        for (var i = 0; i < buttons.length; i++) buttons[i].classList.remove('active');
        if (event && event.target) {
            var btn = event.target.closest('.admin-nav-btn');
            if (btn) btn.classList.add('active');
        }
    }

    function openAddModal(type) {
        document.getElementById('modalTitle').textContent = 'Add New ' + type.charAt(0).toUpperCase() + type.slice(1);
        document.getElementById('adminItemType').value = type;
        document.getElementById('addRestaurantFields').style.display = type === 'restaurant' ? 'block' : 'none';
        document.getElementById('addDishFields').style.display = type === 'dish' ? 'block' : 'none';
        document.getElementById('addEventFields').style.display = type === 'event' ? 'block' : 'none';
        document.getElementById('addModal').style.display = 'flex';
    }

    function openEditModal(type, id, name, photoUrl, description, address, category, price, tags, isNew, isTrending, slots, eventDate) {
        document.getElementById('editItemType').value = type;
        document.getElementById('editItemId').value = id;
        document.getElementById('editName').value = name || '';
        document.getElementById('editImageUrl').value = photoUrl || '';
        document.getElementById('editDescription').value = description || '';

        var preview = document.getElementById('editPreview');
        if (photoUrl) { preview.src = photoUrl; preview.style.display = 'block'; }
        else preview.style.display = 'none';

        document.getElementById('editRestaurantFields').style.display = 'none';
        document.getElementById('editDishFields').style.display = 'none';
        document.getElementById('editEventFields').style.display = 'none';

        if (type === 'restaurant') {
            document.getElementById('editRestaurantFields').style.display = 'block';
            document.getElementById('editAddress').value = address || '';
            document.getElementById('editCategory').value = category || 'Restaurant';
        } else if (type === 'dish') {
            document.getElementById('editDishFields').style.display = 'block';
            document.getElementById('editPrice').value = price || 0;
            document.getElementById('editTags').value = tags || '';
            document.getElementById('editIsNew').checked = isNew === 'true';
            document.getElementById('editIsTrending').checked = isTrending === 'true';
        } else if (type === 'event') {
            document.getElementById('editEventFields').style.display = 'block';
            document.getElementById('editLocation').value = address || '';
            document.getElementById('editAvailableSlots').value = slots || 0;
            document.getElementById('editEventDate').value = eventDate || '';
        }

        document.getElementById('editModalTitle').textContent = 'Edit ' + type.charAt(0).toUpperCase() + type.slice(1);
        document.getElementById('editModal').style.display = 'flex';
    }

    function closeModal(id) {
        var modal = document.getElementById(id || 'addModal');
        if (modal) modal.style.display = 'none';
    }

    function previewPhoto(input, previewId) {
        var preview = document.getElementById(previewId);
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) { preview.src = e.target.result; preview.style.display = 'block'; };
            reader.readAsDataURL(input.files[0]);
        }
    }

    async function openRegistrantsModal(eventId, title) {
        document.getElementById('registrantsTitle').textContent = 'Registrants: ' + title;
        document.getElementById('registrantsList').innerHTML = '<p style="color:var(--text-muted)">Loading...</p>';
        document.getElementById('registrantsModal').style.display = 'flex';
        try {
            const res = await fetch('/api/events/' + eventId + '/registrants');
            const data = await res.json();
            if (!data.length) {
                document.getElementById('registrantsList').innerHTML = '<p style="color:var(--text-muted)">No registrants yet.</p>';
                return;
            }
            var html = '<table class="admin-table"><thead><tr><th>Name</th><th>Email</th></tr></thead><tbody>';
            data.forEach(function(u) { html += '<tr><td>' + u.fullName + '</td><td>' + u.email + '</td></tr>'; });
            html += '</tbody></table>';
            document.getElementById('registrantsList').innerHTML = html;
        } catch(e) {
            document.getElementById('registrantsList').innerHTML = '<p style="color:red">Failed to load.</p>';
        }
    }

    window.onclick = function(e) {
        var addModal = document.getElementById('addModal');
        var editModal = document.getElementById('editModal');
        if (e.target == addModal) addModal.style.display = 'none';
        if (e.target == editModal) editModal.style.display = 'none';
        var regModal = document.getElementById('registrantsModal');
        if (e.target == regModal) regModal.style.display = 'none';
    }
</script>
