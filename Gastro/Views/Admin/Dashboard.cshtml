@{
    ViewData["Title"] = "Admin Dashboard - TasteCebu";
    var restaurants = ViewData["Restaurants"] as List<GastroCebu.Models.RestaurantListing> ?? new();
    var dishes = ViewData["Dishes"] as List<GastroCebu.Models.DishListing> ?? new();
    var events = ViewData["Events"] as List<GastroCebu.Models.FoodEvent> ?? new();
    var users = ViewData["Users"] as List<GastroCebu.Models.AppUser> ?? new();
    var reviews = ViewData["Reviews"] as List<GastroCebu.Models.ReviewEntry> ?? new();
}

<section class="admin-dashboard">
    <div class="admin-header">
        <h1><i class="fas fa-chart-line"></i> Admin Dashboard</h1>
        <p>Manage your gastro platform content</p>
    </div>

    <!-- STATS CARDS -->
    <div class="stats-grid-admin">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-utensils"></i></div>
            <div class="stat-number">@(ViewData["RestaurantCount"] ?? 0)</div>
            <div class="stat-label">Restaurants</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-drumstick-bite"></i></div>
            <div class="stat-number">@(ViewData["DishCount"] ?? 0)</div>
            <div class="stat-label">Dishes</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
            <div class="stat-number">@(ViewData["EventCount"] ?? 0)</div>
            <div class="stat-label">Events</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-users"></i></div>
            <div class="stat-number">@(ViewData["UserCount"] ?? 0)</div>
            <div class="stat-label">Users</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-star"></i></div>
            <div class="stat-number">@(ViewData["ReviewCount"] ?? 0)</div>
            <div class="stat-label">Reviews</div>
        </div>
    </div>

    <!-- ADMIN SIDEBAR + CONTENT -->
    <div class="admin-layout">
        <div class="admin-sidebar">
            <button class="admin-nav-btn active" onclick="showAdminPanel('restaurants', this)">
                <i class="fas fa-utensils"></i> Restaurants
            </button>
            <button class="admin-nav-btn" onclick="showAdminPanel('dishes', this)">
                <i class="fas fa-drumstick-bite"></i> Dishes
            </button>
            <button class="admin-nav-btn" onclick="showAdminPanel('events', this)">
                <i class="fas fa-calendar-alt"></i> Events
            </button>
            <button class="admin-nav-btn" onclick="showAdminPanel('users', this)">
                <i class="fas fa-users"></i> Users
            </button>
            <button class="admin-nav-btn" onclick="showAdminPanel('reviews', this)">
                <i class="fas fa-star"></i> Reviews
            </button>
        </div>

        <div class="admin-content">

            <!-- RESTAURANTS PANEL -->
            <div id="restaurantsPanel" class="admin-panel active">
                <div class="panel-header">
                    <h3>Manage Restaurants</h3>
                    <button class="btn-add" onclick="openAddModal('restaurant')"><i class="fas fa-plus"></i> Add Restaurant</button>
                </div>
                <table class="admin-table">
                    <thead>
                        <tr><th>ID</th><th>Name</th><th>Location</th><th>Rating</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var restaurant in restaurants)
                        {
                            var rName = restaurant.Name.Replace("'", "\\'").Replace("\"", "&quot;");
                            var rPhoto = restaurant.PhotoUrl.Replace("'", "\\'");
                            var rDesc = restaurant.Description.Replace("'", "\\'");
                            var rAddr = restaurant.Address.Replace("'", "\\'");
                            <tr>
                                <td>@restaurant.Id</td>
                                <td>@restaurant.Name</td>
                                <td>@restaurant.Address</td>
                                <td>@restaurant.Rating.ToString("0.0")</td>
                                <td>
                                    <button class="btn-edit" onclick="openEditModal('restaurant',@restaurant.Id,'@rName','@rPhoto','@rDesc','@rAddr','@restaurant.Category','0','','false','false','0','')">Edit</button>
                                    <form method="post" action="/Admin/DeleteItem" class="inline-form" onsubmit="return confirm('Delete this restaurant?')">
                                        <input type="hidden" name="type" value="restaurant">
                                        <input type="hidden" name="id" value="@restaurant.Id">
                                        <button class="btn-delete">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- DISHES PANEL -->
            <div id="dishesPanel" class="admin-panel">
                <div class="panel-header">
                    <h3>Manage Dishes</h3>
                    <button class="btn-add" onclick="openAddModal('dish')"><i class="fas fa-plus"></i> Add Dish</button>
                </div>
                <table class="admin-table">
                    <thead>
                        <tr><th>ID</th><th>Name</th><th>Price</th><th>Restaurant</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var dish in dishes)
                        {
                            var dName = dish.Name.Replace("'", "\\'");
                            var dPhoto = dish.PhotoUrl.Replace("'", "\\'");
                            var dTags = dish.Tags.Replace("'", "\\'");
                            var dIsNew = dish.IsNewThisMonth ? "true" : "false";
                            var dTrending = dish.IsTrending ? "true" : "false";
                            <tr>
                                @{
                                    var linkedRName = dish.RestaurantId.HasValue ? (restaurants.FirstOrDefault(r => r.Id == dish.RestaurantId.Value)?.Name ?? "--") : "--";
                                }
                                <td>@dish.Id</td>
                                <td>@dish.Name</td>
                                <td>PHP @dish.Price.ToString("0.##")</td>
                                <td>@linkedRName</td>
                                <td>
                                    <button class="btn-edit" onclick="openEditModal('dish',@dish.Id,'@dName','@dPhoto','','','',@dish.Price,'@dTags','@dIsNew','@dTrending','0','')">Edit</button>
                                    <form method="post" action="/Admin/DeleteItem" class="inline-form" onsubmit="return confirm('Delete this dish?')">
                                        <input type="hidden" name="type" value="dish">
                                        <input type="hidden" name="id" value="@dish.Id">
                                        <button class="btn-delete">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- EVENTS PANEL -->
            <div id="eventsPanel" class="admin-panel">
                <div class="panel-header">
                    <h3>Manage Events</h3>
                    <button class="btn-add" onclick="openAddModal('event')"><i class="fas fa-plus"></i> Add Event</button>
                </div>
                <table class="admin-table">
                    <thead>
                        <tr><th>ID</th><th>Title</th><th>Date</th><th>Seats</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var foodEvent in events)
                        {
                            var eTitle = foodEvent.Title.Replace("'", "\\'");
                            var ePhoto = foodEvent.PhotoUrl.Replace("'", "\\'");
                            var eDesc = foodEvent.Description.Replace("'", "\\'");
                            var eLoc = foodEvent.Location.Replace("'", "\\'");
                            var eDate = foodEvent.Date.ToString("yyyy-MM-ddTHH:mm");
                            <tr>
                                <td>@foodEvent.Id</td>
                                <td>@foodEvent.Title</td>
                                <td>@foodEvent.Date.ToString("MMM d, yyyy")</td>
                                <td>@foodEvent.AvailableSlots left</td>
                                <td>
                                    <button class="btn-registrants" onclick="openRegistrantsModal(@foodEvent.Id, '@eTitle')">Registrants</button>
                                    <button class="btn-edit" onclick="openEditModal('event',@foodEvent.Id,'@eTitle','@ePhoto','@eDesc','@eLoc','','0','','false','false','@foodEvent.AvailableSlots','@eDate')">Edit</button>
                                    <form method="post" action="/Admin/DeleteItem" class="inline-form" onsubmit="return confirm('Delete this event?')">
                                        <input type="hidden" name="type" value="event">
                                        <input type="hidden" name="id" value="@foodEvent.Id">
                                        <button class="btn-delete">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- USERS PANEL -->
            <div id="usersPanel" class="admin-panel">
                <div class="panel-header">
                    <h3>Manage Users</h3>
                </div>
                <table class="admin-table">
                    <thead>
                        <tr><th>ID</th><th>Name</th><th>Email</th><th>Role</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var appUser in users)
                        {
                            var isSeededAdmin = appUser.Email == "admin@tastecebu.test";
                            <tr>
                                <td>@appUser.Id</td>
                                <td>@appUser.FullName</td>
                                <td>@appUser.Email</td>
                                <td>
                                    @appUser.Role
                                    @if (isSeededAdmin)
                                    {
                                        <span style="font-size:0.75rem;color:var(--burnt-orange);margin-left:6px;">(system)</span>
                                    }
                                </td>
                                <td>
                                    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                                        @if (isSeededAdmin)
                                        {
                                            <span style="color:var(--text-muted);font-size:0.85rem;">Protected</span>
                                        }
                                        else
                                        {
                                            <button class="btn-edit" onclick="toggleUserEdit(@appUser.Id)">
                                                <i class="fas fa-pen"></i> Edit
                                            </button>
                                            <form method="post" action="/Admin/DeleteUser" class="inline-form" style="display:contents"
                                                  onsubmit="return confirm('Delete @appUser.FullName? This cannot be undone.')">
                                                <input type="hidden" name="id" value="@appUser.Id">
                                                <button class="btn-delete"><i class="fas fa-trash"></i> Delete</button>
                                            </form>
                                            @if (appUser.Role == "Admin")
                                            {
                                                <form method="post" action="/Admin/SetAdmin" class="inline-form" style="display:contents">
                                                    <input type="hidden" name="id" value="@appUser.Id">
                                                    <input type="hidden" name="isAdmin" value="false">
                                                    <button class="btn-delete" style="background:var(--bg-elevated);color:var(--burnt-orange);border:1px solid var(--burnt-orange);">
                                                        Remove Admin
                                                    </button>
                                                </form>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                            @if (!isSeededAdmin)
                            {
                                <tr id="userEditRow-@appUser.Id" style="display:none;background:var(--bg-elevated);">
                                    <td colspan="5" style="padding:1rem;">
                                        <form method="post" action="/Admin/EditUser" style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;">
                                            <input type="hidden" name="id" value="@appUser.Id">
                                            <input type="text" name="fullName" value="@appUser.FullName"
                                                   placeholder="Full name" required
                                                   style="padding:0.5rem;border-radius:8px;border:1px solid var(--navbar-border);background:var(--bg-card);color:var(--text-primary);flex:1;min-width:160px;">
                                            <input type="email" name="email" value="@appUser.Email"
                                                   placeholder="Email" required
                                                   style="padding:0.5rem;border-radius:8px;border:1px solid var(--navbar-border);background:var(--bg-card);color:var(--text-primary);flex:1;min-width:200px;">
                                            <button type="submit" class="btn-edit"><i class="fas fa-save"></i> Save</button>
                                            <button type="button" onclick="toggleUserEdit(@appUser.Id)"
                                                    style="padding:0.4rem 0.9rem;border-radius:8px;border:1px solid var(--navbar-border);background:none;color:var(--text-secondary);cursor:pointer;">
                                                Cancel
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- REVIEWS PANEL -->
            <div id="reviewsPanel" class="admin-panel">
                <div class="panel-header">
                    <h3>Manage Reviews</h3>
                </div>
                <table class="admin-table">
                    <thead>
                        <tr><th>ID</th><th>User</th><th>Target</th><th>Rating</th><th>Review</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @{
                            var reviewUserNames = ViewData["ReviewUserNames"] as Dictionary<int, string> ?? new();
                            var reviewTargetNames = ViewData["ReviewTargetNames"] as Dictionary<int, string> ?? new();
                        }
                        @foreach (var review in reviews)
                        {
                            var rUserName = reviewUserNames.TryGetValue(review.UserId, out var rUn) ? rUn : $"User #{review.UserId}";
                            var rTargetName = reviewTargetNames.TryGetValue(review.Id, out var rTn) ? rTn : $"{review.TargetType} #{review.TargetId}";
                            <tr>
                                <td>@review.Id</td>
                                <td>@rUserName</td>
                                <td>@review.TargetType: @rTargetName</td>
                                <td>@review.Rating stars</td>
                                <td>@review.Text</td>
                                <td>
                                    <form method="post" action="/Admin/DeleteItem" class="inline-form">
                                        <input type="hidden" name="type" value="review">
                                        <input type="hidden" name="id" value="@review.Id">
                                        <button class="btn-delete">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="recent-activity-panel">
                <h3>Recent Activity</h3>
                @{
                    var activities = ViewData["RecentActivities"] as List<GastroCebu.Models.ActivityEntry> ?? new();
                    var allUsers = ViewData["Users"] as List<GastroCebu.Models.AppUser> ?? new();
                    var userDict = allUsers.ToDictionary(u => u.Id, u => u.FullName);
                }
                @if (!activities.Any())
                {
                    <div class="activity-item" style="color:var(--text-muted)">No activity yet.</div>
                }
                @foreach (var act in activities)
                {
                    var actUser = userDict.TryGetValue(act.UserId, out var uName) ? uName : $"User #{act.UserId}";
                    <div class="activity-item">
                        <i class="fas fa-circle-dot"></i>
                        <strong>@actUser</strong> &mdash; @act.Message
                        <span style="font-size:0.75rem;color:var(--text-muted);float:right">@act.CreatedAt.ToString("MMM d, h:mm tt")</span>
                    </div>
                }
            </div>

        </div>
    </div>
</section>

<!-- REGISTRANTS MODAL -->
<div id="registrantsModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="registrantsTitle">Registrants</h2>
            <button class="close-modal" onclick="closeModal('registrantsModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div id="registrantsList" style="margin-top:0.5rem">
                <p style="color:var(--text-muted)">Loading...</p>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-modal-cancel" style="width:100%" onclick="closeModal('registrantsModal')">Close</button>
        </div>
    </div>
</div>

<!-- ADD MODAL -->
<div id="addModal" class="modal">
    <div class="modal-content">
        <div class="modal-header-styled">
            <div class="modal-title-row">
                <div class="modal-icon" id="addModalIcon"><i class="fas fa-plus-circle"></i></div>
                <h2 id="modalTitle">Add New</h2>
            </div>
            <button class="close-modal" onclick="closeModal('addModal')">&times;</button>
        </div>
        <form id="addForm" method="post" action="/Admin/AddItem" enctype="multipart/form-data">
            <div class="modal-body">
                <input type="hidden" name="type" id="adminItemType" value="restaurant">

                <div class="form-group">
                    <label>Name</label>
                    <input type="text" name="name" required placeholder="Enter name...">
                </div>

                <!-- Photo section -->
                <div class="photo-upload-section">
                    <div class="photo-upload-preview" id="addPhotoPreviewBox">
                        <img id="addPreview" src="" alt="" style="display:none">
                        <div class="photo-placeholder" id="addPhotoPlaceholder">
                            <i class="fas fa-image"></i>
                            <span>No photo selected</span>
                        </div>
                    </div>
                    <div class="photo-upload-controls">
                        <div class="form-group">
                            <label><i class="fas fa-upload"></i> Upload Photo</label>
                            <input type="file" name="photo" accept="image/*" onchange="previewPhoto(this,'addPreview','addPhotoPlaceholder')">
                        </div>
                        <div class="photo-divider"><span>or</span></div>
                        <div class="form-group">
                            <label><i class="fas fa-link"></i> Image URL</label>
                            <input type="url" name="imageUrl" placeholder="https://..." oninput="previewUrl(this.value,'addPreview','addPhotoPlaceholder')">
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea rows="3" name="description" placeholder="Write a short description..."></textarea>
                </div>

                <!-- Restaurant-only fields -->
                <div id="addRestaurantFields">
                    <div class="form-group">
                        <label>Address</label>
                        <input type="text" name="address" placeholder="e.g. AS Fortuna, Mandaue City">
                    </div>
                    <div class="form-group">
                        <label>Category</label>
                        <select name="category">
                            <option value="Restaurant">Restaurant</option>
                            <option value="Cafe">Cafe</option>
                            <option value="Bar">Bar</option>
                            <option value="Street Food">Street Food</option>
                        </select>
                    </div>
                </div>

                <!-- Dish-only fields -->
                <div id="addDishFields" style="display:none">
                    <div class="form-group">
                        <label>Linked Restaurant (optional)</label>
                        <select name="restaurantId" id="addDishRestaurant">
                            <option value="">-- None --</option>
                            @foreach (var r in restaurants)
                            {
                                <option value="@r.Id">@r.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Price (PHP)</label>
                            <input type="number" name="price" step="0.01" min="0" value="0">
                        </div>
                        <div class="form-group">
                            <label>Tags (comma-separated)</label>
                            <input type="text" name="tags" placeholder="e.g. Seafood, Spicy">
                        </div>
                    </div>
                    <div class="checkbox-group">
                        <label class="checkbox-pill">
                            <input type="checkbox" name="isNew" value="true">
                            <span><i class="fas fa-sparkles"></i> New This Month</span>
                        </label>
                        <label class="checkbox-pill">
                            <input type="checkbox" name="isTrending" value="true">
                            <span><i class="fas fa-fire"></i> Trending</span>
                        </label>
                    </div>
                </div>

                <!-- Event-only fields -->
                <div id="addEventFields" style="display:none">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Event Date & Time</label>
                            <input type="datetime-local" name="eventDate">
                        </div>
                        <div class="form-group">
                            <label>Available Slots</label>
                            <input type="number" name="availableSlots" min="1" value="20">
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Location</label>
                        <input type="text" name="location" placeholder="e.g. Carbon Market, Cebu City">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modal-cancel" onclick="closeModal('addModal')">Cancel</button>
                <button type="submit" class="btn-submit"><i class="fas fa-save"></i> Save</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT MODAL -->
<div id="editModal" class="modal">
    <div class="modal-content">
        <div class="modal-header-styled">
            <div class="modal-title-row">
                <div class="modal-icon" id="editModalIcon"><i class="fas fa-pen"></i></div>
                <h2 id="editModalTitle">Edit</h2>
            </div>
            <button class="close-modal" onclick="closeModal('editModal')">&times;</button>
        </div>
        <form id="editForm" method="post" action="/Admin/EditItem" enctype="multipart/form-data">
            <div class="modal-body">
                <input type="hidden" name="type" id="editItemType">
                <input type="hidden" name="id" id="editItemId">
                <!-- KEY FIX: keeps existing photo if no new one is uploaded -->
                <input type="hidden" name="currentPhoto" id="editCurrentPhoto">

                <div class="form-group">
                    <label>Name</label>
                    <input type="text" name="name" id="editName" required>
                </div>

                <!-- Photo section with current photo preview -->
                <div class="photo-upload-section">
                    <div class="photo-upload-preview" id="editPhotoPreviewBox">
                        <img id="editPreview" src="" alt="" style="display:none">
                        <div class="photo-placeholder" id="editPhotoPlaceholder">
                            <i class="fas fa-image"></i>
                            <span>No photo</span>
                        </div>
                    </div>
                    <div class="photo-upload-controls">
                        <p class="photo-keep-note"><i class="fas fa-info-circle"></i> Leave blank to keep the current photo</p>
                        <div class="form-group">
                            <label><i class="fas fa-upload"></i> Upload New Photo</label>
                            <input type="file" name="photo" accept="image/*" onchange="previewPhoto(this,'editPreview','editPhotoPlaceholder')">
                        </div>
                        <div class="photo-divider"><span>or</span></div>
                        <div class="form-group">
                            <label><i class="fas fa-link"></i> New Image URL</label>
                            <input type="url" name="imageUrl" id="editImageUrl" placeholder="https://..." oninput="previewUrl(this.value,'editPreview','editPhotoPlaceholder')">
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea rows="3" name="description" id="editDescription"></textarea>
                </div>

                <!-- Restaurant-only fields -->
                <div id="editRestaurantFields" style="display:none">
                    <div class="form-group">
                        <label>Address</label>
                        <input type="text" name="address" id="editAddress">
                    </div>
                    <div class="form-group">
                        <label>Category</label>
                        <select name="category" id="editCategory">
                            <option value="Restaurant">Restaurant</option>
                            <option value="Cafe">Cafe</option>
                            <option value="Bar">Bar</option>
                            <option value="Street Food">Street Food</option>
                        </select>
                    </div>
                </div>

                <!-- Dish-only fields -->
                <div id="editDishFields" style="display:none">
                    <div class="form-group">
                        <label>Linked Restaurant (optional)</label>
                        <select name="restaurantId" id="editDishRestaurant">
                            <option value="">-- None --</option>
                            @foreach (var r in restaurants)
                            {
                                <option value="@r.Id">@r.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Price (PHP)</label>
                            <input type="number" name="price" id="editPrice" step="0.01" min="0">
                        </div>
                        <div class="form-group">
                            <label>Tags (comma-separated)</label>
                            <input type="text" name="tags" id="editTags">
                        </div>
                    </div>
                    <div class="checkbox-group">
                        <label class="checkbox-pill">
                            <input type="checkbox" name="isNew" id="editIsNew" value="true">
                            <span><i class="fas fa-sparkles"></i> New This Month</span>
                        </label>
                        <label class="checkbox-pill">
                            <input type="checkbox" name="isTrending" id="editIsTrending" value="true">
                            <span><i class="fas fa-fire"></i> Trending</span>
                        </label>
                    </div>
                </div>

                <!-- Event-only fields -->
                <div id="editEventFields" style="display:none">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Date & Time</label>
                            <input type="datetime-local" name="eventDate" id="editEventDate">
                        </div>
                        <div class="form-group">
                            <label>Available Slots</label>
                            <input type="number" name="availableSlots" id="editAvailableSlots" min="0">
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Location</label>
                        <input type="text" name="location" id="editLocation">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modal-cancel" onclick="closeModal('editModal')">Cancel</button>
                <button type="submit" class="btn-submit"><i class="fas fa-save"></i> Update</button>
            </div>
        </form>
    </div>
</div>

