@{
    ViewData["Title"] = "Admin Dashboard - TasteCebu";
}

@if (User.IsInRole("Admin"))
{
    <section class="admin-dashboard">
        <div class="admin-header">
            <h1><i class="fas fa-chart-line"></i> Admin Dashboard</h1>
            <p>Manage your gastro platform content</p>
        </div>

        <!-- STATS CARDS -->
        <div class="stats-grid-admin">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-utensils"></i></div>
                <div class="stat-number">127</div>
                <div class="stat-label">Restaurants</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-drumstick-bite"></i></div>
                <div class="stat-number">342</div>
                <div class="stat-label">Dishes</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                <div class="stat-number">23</div>
                <div class="stat-label">Events</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-number">1847</div>
                <div class="stat-label">Users</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-star"></i></div>
                <div class="stat-number">892</div>
                <div class="stat-label">Reviews</div>
            </div>
        </div>

        <!-- ADMIN SIDEBAR + CONTENT -->
        <div class="admin-layout">
            <div class="admin-sidebar">
                <button class="admin-nav-btn active" onclick="showAdminPanel('restaurants')">
                    <i class="fas fa-utensils"></i> Restaurants
                </button>
                <button class="admin-nav-btn" onclick="showAdminPanel('dishes')">
                    <i class="fas fa-drumstick-bite"></i> Dishes
                </button>
                <button class="admin-nav-btn" onclick="showAdminPanel('events')">
                    <i class="fas fa-calendar-alt"></i> Events
                </button>
                <button class="admin-nav-btn" onclick="showAdminPanel('users')">
                    <i class="fas fa-users"></i> Users
                </button>
                <button class="admin-nav-btn" onclick="showAdminPanel('reviews')">
                    <i class="fas fa-star"></i> Reviews
                </button>
            </div>

            <div class="admin-content">
                <!-- RESTAURANTS PANEL -->
                <div id="restaurantsPanel" class="admin-panel active">
                    <div class="panel-header">
                        <h3>Manage Restaurants</h3>
                        <button class="btn-add" onclick="openAddModal('restaurant')"><i class="fas fa-plus"></i> Add Restaurant</button>
                    </div>
                    <table class="admin-table">
                        <thead>
                            <tr><th>ID</th><th>Name</th><th>Location</th><th>Rating</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>House of Lechon</td><td>Capitol Site</td><td>4.9</td><td><button class="btn-edit">Edit</button> <button class="btn-delete">Delete</button></td></tr>
                            <tr><td>2</td><td>Good Cup Coffee</td><td>Mandaue</td><td>4.8</td><td><button class="btn-edit">Edit</button> <button class="btn-delete">Delete</button></td></tr>
                            <tr><td>3</td><td>Pig and Palm</td><td>Lahug</td><td>4.9</td><td><button class="btn-edit">Edit</button> <button class="btn-delete">Delete</button></td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- DISHES PANEL -->
                <div id="dishesPanel" class="admin-panel">
                    <div class="panel-header">
                        <h3>Manage Dishes</h3>
                        <button class="btn-add" onclick="openAddModal('dish')"><i class="fas fa-plus"></i> Add Dish</button>
                    </div>
                    <table class="admin-table">
                        <thead>
                            <tr><th>ID</th><th>Name</th><th>Restaurant</th><th>Price</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Cebu Lechon</td><td>House of Lechon</td><td>$450</td><td><button class="btn-edit">Edit</button> <button class="btn-delete">Delete</button></td></tr>
                            <tr><td>2</td><td>Kinilaw Tacos</td><td>Tales and Feelings</td><td>$320</td><td><button class="btn-edit">Edit</button> <button class="btn-delete">Delete</button></td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- EVENTS PANEL -->
                <div id="eventsPanel" class="admin-panel">
                    <div class="panel-header">
                        <h3>Manage Events</h3>
                        <button class="btn-add" onclick="openAddModal('event')"><i class="fas fa-plus"></i> Add Event</button>
                    </div>
                    <table class="admin-table">
                        <thead>
                            <tr><th>ID</th><th>Title</th><th>Date</th><th>Seats</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Lechon Masterclass</td><td>Jun 15, 2025</td><td>15 left</td><td><button class="btn-edit">Edit</button> <button class="btn-delete">Delete</button></td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- USERS PANEL -->
                <div id="usersPanel" class="admin-panel">
                    <div class="panel-header">
                        <h3>Manage Users</h3>
                        <button class="btn-add" onclick="openAddModal('user')"><i class="fas fa-plus"></i> Add User</button>
                    </div>
                    <table class="admin-table">
                        <thead>
                            <tr><th>ID</th><th>Name</th><th>Email</th><th>Role</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Maria Santos</td><td>maria@email.com</td><td>Admin</td><td><button class="btn-edit">Edit</button> <button class="btn-delete">Delete</button></td></tr>
                            <tr><td>2</td><td>Juan Dela Cruz</td><td>juan@email.com</td><td>User</td><td><button class="btn-edit">Edit</button> <button class="btn-delete">Delete</button></td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- REVIEWS PANEL -->
                <div id="reviewsPanel" class="admin-panel">
                    <div class="panel-header">
                        <h3>Manage Reviews</h3>
                    </div>
                    <table class="admin-table">
                        <thead>
                            <tr><th>ID</th><th>User</th><th>Restaurant</th><th>Rating</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Maria Santos</td><td>House of Lechon</td><td>5 stars</td><td><button class="btn-delete">Delete</button></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- ADD MODAL -->
    <div id="addModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal()">&times;</span>
            <h2 id="modalTitle">Add New</h2>
            <form id="addForm">
                <div class="form-group">
                    <label>Name</label>
                    <input type="text" required>
                </div>
                <div class="form-group">
                    <label>Image URL</label>
                    <input type="url">
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea rows="3"></textarea>
                </div>
                <button type="submit" class="btn-submit">Save</button>
            </form>
        </div>
    </div>
}
else
{
    <div class="access-denied">
        <i class="fas fa-lock"></i>
        <h1>Access Denied</h1>
        <p>You do not have permission to view this page.</p>
        <a href="/" class="btn-primary">Return Home</a>
    </div>
}

<style>
    .admin-dashboard {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem;
    }

    .admin-header {
        margin-bottom: 2rem;
    }

        .admin-header h1 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

    .stats-grid-admin {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: var(--gradient-warm);
        padding: 1.5rem;
        border-radius: 20px;
        text-align: center;
        color: white;
    }

    .stat-icon {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
    }

    .admin-layout {
        display: grid;
        grid-template-columns: 250px 1fr;
        gap: 2rem;
    }

    .admin-sidebar {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 1rem;
    }

    .admin-nav-btn {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        width: 100%;
        padding: 0.8rem 1rem;
        background: none;
        border: none;
        color: var(--text-primary);
        border-radius: 12px;
        cursor: pointer;
        transition: var(--transition);
        margin-bottom: 0.5rem;
    }

        .admin-nav-btn:hover, .admin-nav-btn.active {
            background: var(--burnt-orange);
            color: white;
        }

    .admin-panel {
        display: none;
    }

        .admin-panel.active {
            display: block;
        }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .btn-add {
        background: var(--gradient-warm);
        color: white;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 30px;
        cursor: pointer;
    }

    .admin-table {
        width: 100%;
        background: var(--bg-card);
        border-radius: 16px;
        overflow: hidden;
        border-collapse: collapse;
    }

        .admin-table th, .admin-table td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid var(--text-muted);
        }

        .admin-table th {
            background: var(--bg-elevated);
            font-weight: 600;
        }

    .btn-edit, .btn-delete {
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        border: none;
        cursor: pointer;
        margin-right: 0.5rem;
    }

    .btn-edit {
        background: #3498db;
        color: white;
    }

    .btn-delete {
        background: #e74c3c;
        color: white;
    }

    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.7);
        z-index: 2000;
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: var(--bg-card);
        padding: 2rem;
        border-radius: 24px;
        width: 90%;
        max-width: 500px;
    }

    .close-modal {
        float: right;
        font-size: 1.5rem;
        cursor: pointer;
    }

    .form-group {
        margin-bottom: 1rem;
    }

        .form-group label {
            display: block;
            margin-bottom: 0.3rem;
        }

        .form-group input, .form-group textarea {
            width: 100%;
            padding: 0.8rem;
            background: var(--bg-elevated);
            border: 1px solid var(--text-muted);
            border-radius: 12px;
            color: var(--text-primary);
        }

    .btn-submit {
        background: var(--gradient-warm);
        color: white;
        border: none;
        padding: 0.8rem;
        border-radius: 40px;
        width: 100%;
        cursor: pointer;
    }

    .access-denied {
        text-align: center;
        padding: 4rem;
    }

        .access-denied i {
            font-size: 4rem;
            color: var(--burnt-orange);
            margin-bottom: 1rem;
        }
</style>

<style>
    @@media (max-width: 768px) {
        .admin-layout {
            grid-template-columns: 1fr;
        }

        .admin-table {
            font-size: 0.8rem;
        }

            .admin-table th, .admin-table td {
                padding: 0.5rem;
            }

        .stats-grid-admin {
            gap: 1rem;
        }

        .stat-card {
            padding: 1rem;
        }

        .stat-number {
            font-size: 1.5rem;
        }
    }
</style>

<script>
    function showAdminPanel(panel) {
        var panels = ['restaurants', 'dishes', 'events', 'users', 'reviews'];
        var buttons = document.querySelectorAll('.admin-nav-btn');

        for (var i = 0; i < panels.length; i++) {
            var panelElement = document.getElementById(panels[i] + 'Panel');
            if (panelElement) {
                panelElement.classList.remove('active');
            }
        }

        var activePanel = document.getElementById(panel + 'Panel');
        if (activePanel) {
            activePanel.classList.add('active');
        }

        for (var i = 0; i < buttons.length; i++) {
            buttons[i].classList.remove('active');
        }

        if (event && event.target) {
            var targetBtn = event.target.closest('.admin-nav-btn');
            if (targetBtn) {
                targetBtn.classList.add('active');
            }
        }
    }

    function openAddModal(type) {
        var modal = document.getElementById('addModal');
        var title = document.getElementById('modalTitle');
        if (title) {
            var typeName = type.charAt(0).toUpperCase() + type.slice(1);
            title.textContent = 'Add New ' + typeName;
        }
        if (modal) {
            modal.style.display = 'flex';
        }
    }

    function closeModal() {
        var modal = document.getElementById('addModal');
        if (modal) {
            modal.style.display = 'none';
        }
    }

    var addForm = document.getElementById('addForm');
    if (addForm) {
        addForm.addEventListener('submit', function(e) {
            e.preventDefault();
            showToast('Item added successfully!');
            closeModal();
        });
    }

    function showToast(message) {
        var toast = document.createElement('div');
        toast.className = 'toast-notification';
        toast.innerHTML = message;
        document.body.appendChild(toast);

        setTimeout(function() {
            toast.style.opacity = '0';
            setTimeout(function() {
                toast.remove();
            }, 300);
        }, 3000);
    }

    var closeModalBtn = document.querySelector('.close-modal');
    if (closeModalBtn) {
        closeModalBtn.onclick = closeModal;
    }

    window.onclick = function(event) {
        var modal = document.getElementById('addModal');
        if (event.target == modal) {
            modal.style.display = 'none';
        }
    }
</script>