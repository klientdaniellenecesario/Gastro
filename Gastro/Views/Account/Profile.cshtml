@{
    ViewData["Title"] = "My Food Journey - TasteCebu";
    var profileUser = ViewData["ProfileUser"] as GastroCebu.Models.AppUser;
    var restaurantBookmarks = ViewData["RestaurantBookmarks"] as List<GastroCebu.Models.BookmarkEntry> ?? new();
    var dishBookmarks = ViewData["DishBookmarks"] as List<GastroCebu.Models.BookmarkEntry> ?? new();
    var registrations = ViewData["Registrations"] as List<GastroCebu.Models.EventRegistration> ?? new();
    var reviews = ViewData["Reviews"] as List<GastroCebu.Models.ReviewEntry> ?? new();
    var reviewNames = ViewData["ReviewNames"] as Dictionary<int, string> ?? new();
    var activities = ViewData["Activities"] as List<GastroCebu.Models.ActivityEntry> ?? new();

    // Real stats
    var reviewCount = reviews.Count;
    var savedRestaurants = restaurantBookmarks.Count;
    var eventsJoined = registrations.Count;

    // Foodie level: 1 XP per review + 1 per bookmark + 1 per event
    var xp = reviewCount + restaurantBookmarks.Count + dishBookmarks.Count + eventsJoined;
    var level = Math.Max(1, xp / 10 + 1);
    var xpInLevel = xp % 10;
    var xpToNext = 10 - xpInLevel;
    var barPct = xpInLevel * 10;
}

<section class="profile-section">
    <div class="profile-header">
        <div class="profile-cover">
            <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=1200&h=300&fit=crop" alt="Cover">
        </div>
        <div class="profile-info">
            <div class="profile-avatar">
                <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="Avatar">
                <button class="edit-avatar"><i class="fas fa-camera"></i></button>
            </div>
            <div class="profile-details">
                <h1 id="profileName">@(profileUser?.FullName ?? User.Identity?.Name ?? "User")</h1>
                <p class="profile-location"><i class="fas fa-map-marker-alt"></i> <span id="profileLocation">@(profileUser?.Location ?? "Cebu City, Philippines")</span></p>
                <div class="foodie-level">
                    <span class="level-badge">Foodie Level @level</span>
                    <div class="level-progress">
                        <div class="level-bar" style="width: @barPct%"></div>
                    </div>
                    <span class="next-level">@xpToNext points to Level @(level + 1)</span>
                </div>
            </div>
            <div class="profile-stats">
                <div class="profile-stat">
                    <div class="stat-number">@(dishBookmarks.Count)</div>
                    <div class="stat-label">Dishes Saved</div>
                </div>
                <div class="profile-stat">
                    <div class="stat-number">@savedRestaurants</div>
                    <div class="stat-label">Restaurants</div>
                </div>
                <div class="profile-stat">
                    <div class="stat-number">@reviewCount</div>
                    <div class="stat-label">Reviews</div>
                </div>
                <div class="profile-stat">
                    <div class="stat-number">@eventsJoined</div>
                    <div class="stat-label">Events Joined</div>
                </div>
            </div>
            <div class="profile-actions">
                <button class="profile-action-btn" onclick="openProfileModal()"><i class="fas fa-pen"></i> Edit Profile</button>
                <button class="profile-action-btn" onclick="openPasswordModal()"><i class="fas fa-key"></i> Change Password</button>
            </div>
        </div>
    </div>

    <div class="profile-tabs">
        <button class="profile-tab active" onclick="showProfileTab('reviews')">My Reviews</button>
        <button class="profile-tab" onclick="showProfileTab('cravings')">Cravings List</button>
        <button class="profile-tab" onclick="showProfileTab('events')">My Events</button>
        <button class="profile-tab" onclick="showProfileTab('activity')">Activity Feed</button>
    </div>

    <!-- MY REVIEWS TAB -->
    <div id="reviewsTab" class="profile-tab-content active">
        <div class="reviews-list">
            @if (!reviews.Any())
            {
                <p class="empty-state">No reviews yet. Start exploring and share your thoughts!</p>
            }
            @foreach (var review in reviews)
            {
                var name = reviewNames.TryGetValue(review.Id, out var n) ? n : $"{review.TargetType} #{review.TargetId}";
                <div class="review-item" data-review-id="@review.Id">
                    <div class="review-restaurant">
                        <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=100&h=100&fit=crop" alt="@name">
                        <div>
                            <h4>@name</h4>
                            <div class="review-stars">
                                @for (var i = 0; i < review.Rating; i++)
                                {
                                    <i class="fas fa-star"></i>
                                }
                                @for (var i = review.Rating; i < 5; i++)
                                {
                                    <i class="far fa-star"></i>
                                }
                            </div>
                            <p class="review-date">@review.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</p>
                        </div>
                    </div>
                    <p class="review-text">@review.Text</p>
                    <div class="inline-actions">
                        <button onclick="editReview(this)">Edit</button>
                        <button onclick="deleteReview(this)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- CRAVINGS LIST TAB -->
    <div id="cravingsTab" class="profile-tab-content">

        @* Saved Restaurants *@
        <h3 class="cravings-section-title"><i class="fas fa-store"></i> Saved Restaurants</h3>
        <div class="cravings-list" id="restaurantCravingsList">
            @if (!restaurantBookmarks.Any())
            {
                <p class="empty-state">No saved restaurants yet.</p>
            }
            @foreach (var bookmark in restaurantBookmarks)
            {
                <div class="craving-item" data-item-type="restaurant" data-item-id="@bookmark.ItemId">
                    <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=100&h=100&fit=crop" alt="@bookmark.ItemName">
                    <div class="craving-info">
                        <h4>@bookmark.ItemName</h4>
                        <p>Restaurant &middot; saved @bookmark.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</p>
                    </div>
                    <button class="btn-remove-craving" onclick="removeCraving(this, 'restaurant', @bookmark.ItemId)">Remove</button>
                </div>
            }
        </div>

        @* Saved Dishes *@
        <h3 class="cravings-section-title" style="margin-top:2rem"><i class="fas fa-utensils"></i> Saved Dishes</h3>
        <div class="cravings-list" id="dishCravingsList">
            @if (!dishBookmarks.Any())
            {
                <p class="empty-state">No saved dishes yet.</p>
            }
            @foreach (var bookmark in dishBookmarks)
            {
                <div class="craving-item" data-item-type="dish" data-item-id="@bookmark.ItemId">
                    <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=100&h=100&fit=crop" alt="@bookmark.ItemName">
                    <div class="craving-info">
                        <h4>@bookmark.ItemName</h4>
                        <p>Dish &middot; saved @bookmark.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</p>
                    </div>
                    <button class="btn-remove-craving" onclick="removeCraving(this, 'dish', @bookmark.ItemId)">Remove</button>
                </div>
            }
        </div>

        <div style="display:flex;gap:1rem;margin-top:1.5rem;flex-wrap:wrap">
            <button class="btn-explore-more" onclick="location.href='/Restaurants'" style="flex:1">+ Save Restaurants</button>
            <button class="btn-explore-more" onclick="location.href='/Dishes'" style="flex:1">+ Save Dishes</button>
        </div>
    </div>

    <!-- MY EVENTS TAB -->
    <div id="eventsTab" class="profile-tab-content">
        <div class="events-list" id="registeredEventsList">
            @if (!registrations.Any())
            {
                <p class="empty-state">No events registered yet.</p>
            }
            @foreach (var registration in registrations)
            {
                <div class="event-item" data-event-id="@registration.EventId">
                    <div class="event-date-badge">
                        <span class="event-date-month">EVT</span>
                        <span class="event-date-day">@registration.EventId</span>
                    </div>
                    <div class="event-info">
                        <h4>@registration.EventTitle</h4>
                        <p><i class="fas fa-map-marker-alt"></i> Cebu</p>
                        <p><i class="far fa-clock"></i> Registered @registration.RegisteredAt.ToLocalTime().ToString("MMM d, yyyy")</p>
                    </div>
                    <span class="event-status confirmed">Confirmed</span>
                    <button class="btn-remove-craving" onclick="cancelEvent(this)">Cancel</button>
                </div>
            }
        </div>
    </div>

    <!-- ACTIVITY FEED TAB -->
    <div id="activityTab" class="profile-tab-content">
        <div class="activity-feed">
            @if (!activities.Any())
            {
                <p class="empty-state">No activity yet.</p>
            }
            @foreach (var activity in activities)
            {
                <div class="activity-item">
                    <div class="activity-icon"><i class="fas fa-circle"></i></div>
                    <div class="activity-content">
                        <p>@activity.Message</p>
                        <span class="activity-time">@activity.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<div class="profile-modal" id="profileModal">
    <div class="profile-modal-content">
        <button class="modal-x" onclick="closeProfileModals()">&times;</button>
        <h2>Edit Profile</h2>
        <label>Name</label>
        <input id="editProfileName" type="text">
        <label>Location</label>
        <input id="editProfileLocation" type="text">
        <button class="btn-explore-more" onclick="saveProfile()">Save Profile</button>
    </div>
</div>

<div class="profile-modal" id="passwordModal">
    <div class="profile-modal-content">
        <button class="modal-x" onclick="closeProfileModals()">&times;</button>
        <h2>Change Password</h2>
        <label>Current Password</label>
        <input type="password" id="currentPassword">
        <label>New Password</label>
        <input type="password" id="newPassword">
        <button class="btn-explore-more" onclick="changePassword()">Update Password</button>
    </div>
</div>

<style>
    .profile-section {
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 2rem;
    }

    .profile-header {
        background: var(--bg-card);
        border-radius: 24px;
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .profile-cover {
        height: 150px;
    }

        .profile-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .profile-info {
        padding: 0 2rem 2rem;
        position: relative;
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        align-items: flex-end;
    }

    .profile-avatar {
        position: relative;
        margin-top: -50px;
    }

        .profile-avatar img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid var(--burnt-orange);
            background: var(--bg-card);
        }

    .edit-avatar {
        position: absolute;
        bottom: 0;
        right: 0;
        background: var(--burnt-orange);
        border: none;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        color: white;
        cursor: pointer;
    }

    .profile-details h1 {
        font-size: 1.8rem;
        margin-bottom: 0.3rem;
    }

    .foodie-level {
        margin-top: 0.8rem;
    }

    .level-badge {
        display: inline-block;
        background: var(--gradient-warm);
        padding: 0.2rem 0.8rem;
        border-radius: 20px;
        font-size: 0.8rem;
    }

    .level-progress {
        width: 200px;
        height: 6px;
        background: var(--bg-elevated);
        border-radius: 3px;
        margin: 0.5rem 0 0.3rem;
        overflow: hidden;
    }

    .level-bar {
        height: 100%;
        background: var(--gradient-warm);
        border-radius: 3px;
    }

    .next-level {
        font-size: 0.7rem;
        color: var(--text-secondary);
    }

    .profile-stats {
        display: flex;
        gap: 2rem;
        margin-left: auto;
    }

    .profile-actions {
        display: flex;
        gap: 0.8rem;
        width: 100%;
        justify-content: flex-end;
    }

    .profile-action-btn, .inline-actions button {
        background: var(--bg-elevated);
        color: var(--text-primary);
        border: 1px solid var(--text-muted);
        border-radius: 30px;
        padding: 0.45rem 0.9rem;
        cursor: pointer;
    }

    .inline-actions {
        display: flex;
        gap: 0.5rem;
        margin-left: auto;
    }

    .profile-stat {
        text-align: center;
    }

    .stat-number {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--burnt-orange);
    }

    .profile-tabs {
        display: flex;
        gap: 1rem;
        border-bottom: 1px solid var(--text-muted);
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .profile-tab {
        background: none;
        border: none;
        padding: 0.8rem 1.5rem;
        color: var(--text-secondary);
        cursor: pointer;
        transition: var(--transition);
    }

        .profile-tab.active {
            color: var(--burnt-orange);
            border-bottom: 2px solid var(--burnt-orange);
        }

    .profile-tab-content {
        display: none;
    }

        .profile-tab-content.active {
            display: block;
        }

    .cravings-section-title {
        font-size: 1.1rem;
        margin-bottom: 1rem;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .empty-state {
        color: var(--text-muted);
        padding: 1.5rem;
        text-align: center;
        background: var(--bg-card);
        border-radius: 16px;
    }

    .craving-item, .event-item, .activity-item, .review-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--bg-card);
        padding: 1rem;
        border-radius: 16px;
        margin-bottom: 1rem;
    }

        .craving-item img, .review-restaurant img {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            object-fit: cover;
        }

    .craving-info {
        flex: 1;
    }

    .btn-remove-craving {
        background: none;
        border: 1px solid #e74c3c;
        color: #e74c3c;
        padding: 0.3rem 1rem;
        border-radius: 20px;
        cursor: pointer;
    }

    .btn-explore-more {
        background: var(--gradient-warm);
        color: white;
        border: none;
        padding: 0.8rem 1.5rem;
        border-radius: 40px;
        cursor: pointer;
        width: 100%;
        margin-top: 1rem;
    }

    .review-stars i {
        color: var(--golden-yellow);
        font-size: 0.85rem;
    }

    .review-date {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-top: 0.2rem;
    }

    .review-text {
        flex: 1;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .event-date-badge {
        background: var(--burnt-orange);
        text-align: center;
        padding: 0.5rem;
        border-radius: 12px;
        min-width: 60px;
    }

    .event-date-month {
        display: block;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .event-date-day {
        display: block;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .event-info {
        flex: 1;
    }

    .event-status {
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.75rem;
    }

        .event-status.confirmed {
            background: #27ae60;
            color: white;
        }

        .event-status.pending {
            background: #f39c12;
            color: white;
        }

    .activity-icon {
        width: 40px;
        height: 40px;
        background: var(--bg-elevated);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--burnt-orange);
    }

    .activity-content {
        flex: 1;
    }

    .activity-time {
        font-size: 0.7rem;
        color: var(--text-secondary);
    }

    .profile-modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.7);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        padding: 1rem;
    }

        .profile-modal.open {
            display: flex;
        }

    .profile-modal-content {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 1.5rem;
        max-width: 420px;
        width: 100%;
        position: relative;
    }

        .profile-modal-content label {
            display: block;
            margin-top: 1rem;
        }

        .profile-modal-content input {
            width: 100%;
            background: var(--bg-elevated);
            border: 1px solid var(--text-muted);
            color: var(--text-primary);
            border-radius: 12px;
            padding: 0.8rem;
            margin-top: 0.4rem;
        }

    .modal-x {
        position: absolute;
        top: 0.6rem;
        right: 0.8rem;
        background: none;
        border: none;
        color: var(--text-primary);
        font-size: 1.5rem;
        cursor: pointer;
    }
</style>

<style>
    @@media (max-width: 768px) {
        .profile-info {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .profile-stats {
            margin-left: 0;
            justify-content: center;
        }

        .profile-tabs {
            justify-content: center;
        }

        .profile-actions {
            justify-content: center;
        }
    }
</style>

<script>
    function showProfileTab(tab) {
        document.querySelectorAll('.profile-tab-content').forEach(function(el) { el.classList.remove('active'); });
        document.querySelectorAll('.profile-tab').forEach(function(el) { el.classList.remove('active'); });
        var content = document.getElementById(tab + 'Tab');
        if (content) content.classList.add('active');
        if (event && event.target) event.target.classList.add('active');
    }

    async function removeCraving(btn, itemType, itemId) {
        try {
            var res = await fetch('/api/bookmarks', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemType: itemType, itemId: itemId, itemName: btn.closest('.craving-item').querySelector('h4').innerText })
            });
            if (!res.ok) { showToast('Could not remove bookmark.'); return; }
        } catch (e) { showToast('Could not remove bookmark.'); return; }

        btn.closest('.craving-item').remove();
        showToast('Removed from Cravings');
    }

    async function cancelEvent(btn) {
        var item = btn.closest('.event-item');
        var eventId = item.dataset.eventId;
        if (eventId) {
            await fetch('/api/events/' + eventId + '/register', { method: 'DELETE' });
        }
        item.remove();
        showToast('Event registration cancelled');
    }

    function editReview(btn) {
        var item = btn.closest('.review-item');
        var reviewId = item.dataset.reviewId;
        var textEl = item.querySelector('.review-text');
        var starsEl = item.querySelector('.review-stars');
        var currentRating = starsEl ? starsEl.querySelectorAll('i.fas').length : 5;

        var existing = item.querySelector('.inline-edit-form');
        if (existing) { existing.remove(); return; }

        var form = document.createElement('div');
        form.className = 'inline-edit-form';
        form.innerHTML =
            '<div style="margin-top:0.8rem">' +
            '<label style="display:block;margin-bottom:0.3rem">Rating (1–5)</label>' +
            '<input type="number" min="1" max="5" value="' + currentRating + '" class="edit-rating-input" style="width:60px;padding:0.4rem;border-radius:8px;border:1px solid var(--text-muted);background:var(--bg-elevated);color:var(--text-primary)">' +
            '</div>' +
            '<div style="margin-top:0.6rem">' +
            '<label style="display:block;margin-bottom:0.3rem">Review</label>' +
            '<textarea class="edit-text-input" rows="3" style="width:100%;padding:0.6rem;border-radius:8px;border:1px solid var(--text-muted);background:var(--bg-elevated);color:var(--text-primary)">' + textEl.innerText + '</textarea>' +
            '</div>' +
            '<div style="margin-top:0.6rem;display:flex;gap:0.5rem">' +
            '<button onclick="saveReviewEdit(this,' + reviewId + ')" style="background:var(--burnt-orange);color:#fff;border:none;padding:0.4rem 1rem;border-radius:20px;cursor:pointer">Save</button>' +
            '<button onclick="this.closest(\'.inline-edit-form\').remove()" style="background:var(--bg-elevated);border:1px solid var(--text-muted);padding:0.4rem 1rem;border-radius:20px;cursor:pointer;color:var(--text-primary)">Cancel</button>' +
            '</div>';
        item.appendChild(form);
    }

    async function saveReviewEdit(btn, reviewId) {
        var form = btn.closest('.inline-edit-form');
        var item = form.closest('.review-item');
        var rating = parseInt(form.querySelector('.edit-rating-input').value);
        var text = form.querySelector('.edit-text-input').value.trim();

        if (!text || rating < 1 || rating > 5) { showToast('Please enter a rating (1–5) and review text.'); return; }

        if (reviewId) {
            var res = await fetch('/api/reviews/' + reviewId, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ rating: rating, text: text })
            });
            if (!res.ok) { showToast('Could not update review.'); return; }
        }

        var textEl = item.querySelector('.review-text');
        if (textEl) textEl.innerText = text;

        var starsEl = item.querySelector('.review-stars');
        if (starsEl) {
            starsEl.innerHTML = '';
            for (var i = 0; i < 5; i++) {
                var star = document.createElement('i');
                star.className = i < rating ? 'fas fa-star' : 'far fa-star';
                starsEl.appendChild(star);
            }
        }

        form.remove();
        showToast('Review updated!');
    }

    async function deleteReview(btn) {
        var item = btn.closest('.review-item');
        if (item.dataset.reviewId) {
            await fetch('/api/reviews/' + item.dataset.reviewId, { method: 'DELETE' });
        }
        item.remove();
        showToast('Review deleted');
    }

    function openProfileModal() {
        document.getElementById('editProfileName').value = document.getElementById('profileName').innerText;
        document.getElementById('editProfileLocation').value = document.getElementById('profileLocation').innerText;
        document.getElementById('profileModal').classList.add('open');
    }

    function openPasswordModal() {
        document.getElementById('passwordModal').classList.add('open');
    }

    function closeProfileModals() {
        document.getElementById('profileModal').classList.remove('open');
        document.getElementById('passwordModal').classList.remove('open');
    }

    async function saveProfile() {
        var name = document.getElementById('editProfileName').value.trim();
        var location = document.getElementById('editProfileLocation').value.trim();
        if (!name || !location) { showToast('Please complete the profile fields'); return; }
        await fetch('/Account/UpdateProfile', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ fullName: name, location: location })
        });
        document.getElementById('profileName').innerText = name;
        document.getElementById('profileLocation').innerText = location;
        closeProfileModals();
        showToast('Profile updated');
    }

    async function changePassword() {
        var current = document.getElementById('currentPassword').value.trim();
        var next = document.getElementById('newPassword').value.trim();
        if (!current || next.length < 6) { showToast('New password must be at least 6 characters'); return; }
        await fetch('/Account/ChangePassword', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ currentPassword: current, newPassword: next })
        });
        document.getElementById('currentPassword').value = '';
        document.getElementById('newPassword').value = '';
        closeProfileModals();
        showToast('Password changed');
    }

    function showToast(message) {
        var toast = document.createElement('div');
        toast.className = 'toast-notification';
        toast.innerText = message;
        document.body.appendChild(toast);
        setTimeout(function() {
            toast.style.opacity = '0';
            setTimeout(function() { toast.remove(); }, 300);
        }, 3000);
    }
</script>
