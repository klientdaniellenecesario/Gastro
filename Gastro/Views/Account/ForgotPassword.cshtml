@{
    ViewData["Title"] = "Forgot Password - TasteCebu";
    var resetEmail = TempData["ResetEmail"]?.ToString();
    var forgotError = TempData["ForgotError"]?.ToString();
}

<section class="auth-section">
    <div class="auth-container">
        <div class="auth-image">
            <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=800&h=1000&fit=crop" alt="Delicious food spread">
            <div class="auth-image-overlay">
                <h2>Reset Your Password</h2>
                <p>We'll help you get back to your food journey</p>
            </div>
        </div>

        <div class="auth-form-container">
            <a href="/Account/Login" class="back-link"><i class="fas fa-arrow-left"></i> Back to Sign In</a>

            @if (!string.IsNullOrEmpty(forgotError))
            {
                <div class="auth-alert auth-alert-error">
                    <i class="fas fa-exclamation-circle"></i> @forgotError
                </div>
            }

            @if (string.IsNullOrEmpty(resetEmail))
            {
                <!-- Step 1: Enter Email -->
                <h2>Forgot Password</h2>
                <p class="auth-subtitle">Enter your email and we'll verify your account</p>

                <form method="post" action="/Account/CheckEmail">
                    <div class="input-group">
                        <label><i class="fas fa-envelope"></i> Email Address</label>
                        <input type="email" name="email" placeholder="your@email.com" required>
                    </div>
                    <button type="submit" class="btn-auth">Verify Email</button>
                </form>
            }
            else
            {
                <!-- Step 2: Enter New Password -->
                <h2>Set New Password</h2>
                <p class="auth-subtitle">Account found for <strong>@resetEmail</strong></p>

                <form method="post" action="/Account/ResetPassword">
                    <input type="hidden" name="email" value="@resetEmail">

                    <div class="input-group">
                        <label><i class="fas fa-lock"></i> New Password</label>
                        <div class="password-wrapper">
                            <input type="password" name="newPassword" id="newPassword" placeholder="At least 6 characters" required>
                            <button type="button" class="toggle-password" onclick="togglePassword('newPassword')">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="input-group">
                        <label><i class="fas fa-check-circle"></i> Confirm New Password</label>
                        <div class="password-wrapper">
                            <input type="password" name="confirmPassword" id="confirmPassword" placeholder="Repeat your new password" required>
                            <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword')">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn-auth">Reset Password</button>
                </form>
            }
        </div>
    </div>
</section>

<style>
    .auth-section {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .auth-container {
        max-width: 1100px;
        width: 100%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        background: var(--bg-card);
        border-radius: 32px;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .auth-image {
        position: relative;
        overflow: hidden;
    }

        .auth-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .auth-image-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        padding: 2rem;
        color: white;
    }

        .auth-image-overlay h2 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
        }

    .auth-form-container {
        padding: 2.5rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        transition: var(--transition);
    }

        .back-link:hover {
            color: var(--burnt-orange);
        }

    .auth-alert {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.85rem 1.1rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 1.25rem;
    }

    .auth-alert-error {
        background: rgba(220, 53, 69, 0.12);
        border: 1px solid rgba(220, 53, 69, 0.35);
        color: #c0392b;
    }

    h2 {
        font-size: 1.8rem;
        margin-bottom: 0.5rem;
    }

    .auth-subtitle {
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }

    .input-group {
        margin-bottom: 1rem;
    }

        .input-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
        }

            .input-group label i {
                color: var(--burnt-orange);
                margin-right: 0.5rem;
            }

        .input-group input {
            width: 100%;
            padding: 0.8rem 1rem;
            background: var(--bg-elevated);
            border: 1px solid var(--text-muted);
            border-radius: 12px;
            color: var(--text-primary);
            transition: var(--transition);
        }

            .input-group input:focus {
                outline: none;
                border-color: var(--burnt-orange);
            }

    .password-wrapper {
        position: relative;
    }

        .password-wrapper input {
            padding-right: 3rem;
        }

    .toggle-password {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
    }

    .btn-auth {
        width: 100%;
        padding: 0.8rem;
        background: var(--gradient-warm);
        border: none;
        border-radius: 40px;
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        margin: 1rem 0;
    }

        .btn-auth:hover {
            transform: translateY(-2px);
        }

    @@media (max-width: 768px) {
        .auth-container {
            grid-template-columns: 1fr;
        }

        .auth-image {
            display: none;
        }

        .auth-form-container {
            padding: 1.5rem;
        }
    }
</style>

<script>
    function togglePassword(inputId) {
        var input = document.getElementById(inputId);
        var icon = input.nextElementSibling.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'fas fa-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'fas fa-eye';
        }
    }
</script>
